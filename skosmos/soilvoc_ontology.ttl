	rdfs:label "has component"@en .

agrontology:hasObjectOfActivity a rdf:Property ;
	rdfs:label "has object of activity"@en .

agrontology:hasPart a rdf:Property ;
	rdfs:label "has part"@en .

agrontology:includes a rdf:Property ;
	rdfs:label "includes"@en .

agrontology:isAffectedBy a rdf:Property ;
	rdfs:label "is affected by"@en .

agrontology:isCausedBy a rdf:Property ;
	rdfs:label "is caused by"@en .

agrontology:isComponentOf a rdf:Property ;
	rdfs:label "is component of"@en .

agrontology:isComposedOf a rdf:Property ;
	rdfs:label "is composed of"@en .

agrontology:isIncludedIn a rdf:Property ;
	rdfs:label "is included in"@en .

agrontology:isObjectOfActivity a rdf:Property ;
	rdfs:label "is object of activity"@en .

agrontology:isPartOf a rdf:Property ;
	rdfs:label "is part of"@en .

agrontology:isProcessFor a rdf:Property ;
	rdfs:label "is process for"@en .

agrontology:isStudiedBy a rdf:Property ;
	rdfs:label "is studied by"@en .

agrontology:study a rdf:Property ;
	rdfs:label "study"@en .

agrontology:usesProcess a rdf:Property ;
	rdfs:label "uses process"@en .

dcterms:source a rdf:Property ;
	rdfs:label "source"@en .

sio:equivalentTo a rdf:Property ;
	rdfs:label "equivalent to"@en .

rdf:type a rdf:Property ;
	rdfs:label "type"@en .

rdf:value a rdf:Property ;
	rdfs:label "value"@en .

