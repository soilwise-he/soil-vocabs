    skos:prefLabel "soil chemical functions"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilFunctions .

eusoilvoc:SoilClassificationFAO a skos:Concept ;
    skos:broader eusoilvoc:SoilClassification ;
    skos:broaderTransitive eusoilvoc:SoilClassification ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil classification FAO"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilClassification .

eusoilvoc:SoilClassificationUSDA a skos:Concept ;
    skos:broader eusoilvoc:SoilClassification ;
    skos:broaderTransitive eusoilvoc:SoilClassification ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil classification USDA"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilClassification .

eusoilvoc:SoilClassificationWRB a skos:Concept ;
    skos:broader eusoilvoc:SoilClassification ;
    skos:broaderTransitive eusoilvoc:SoilClassification ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil classification WRB"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilClassification .

eusoilvoc:SoilDepthRootableClass a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:broaderTransitive eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_cm:soilDepthRootableClassProperty ;
            rdf:value "The Soil Depth Rootable Class classifies soils based on the depth of the rootable zone, which excludes impenetrable layers such as bedrock or compacted horizons. Soils are typically classified as shallow, moderately deep, or deep, depending on the depth of the root zone, which directly affects plant growth. Source: FAO (2006). Guidelines for Soil Description (4th ed.). Food and Agriculture Organization of the United Nations."@en ] ;
    skos:exactMatch glosis_cm:soilDepthRootableClassProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil depth rootable class"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilDescription .

eusoilvoc:SoilHydrophobicity a skos:Concept ;
    skos:broader eusoilvoc:SoilPhenomena ;
    skos:broaderTransitive eusoilvoc:SoilPhenomena ;
    skos:exactMatch spp:SoilHydrophobicity ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil hydrophobicity"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilPhenomena .

eusoilvoc:SoilMoistureHysteresis a skos:Concept ;
    skos:broader eusoilvoc:SoilPhenomena ;
    skos:broaderTransitive eusoilvoc:SoilPhenomena ;
    skos:exactMatch spp:SoilMoistureHysteresis ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil moisture hysteresis"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilPhenomena .

eusoilvoc:SoilMoistureRedistribution a skos:Concept ;
    skos:broader eusoilvoc:SoilPhenomena ;
    skos:broaderTransitive eusoilvoc:SoilPhenomena ;
    skos:exactMatch spp:SoilMoistureRedistribution ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil moisture redistribution"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilPhenomena .

eusoilvoc:SoilOrganicMatterClass a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:broaderTransitive eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_cm:organicMatterClassProperty ;
            rdf:value "The Soil Organic Matter Class classifies soil based on the amount and quality of organic matter it contains. Soils with high organic matter are usually fertile, retain moisture better, and support more biological activity. This classification helps in determining soil health and suitability for agricultural purposes. Source: Brady, N. C., & Weil, R. R. (2008). The Nature and Properties of Soils (14th ed.). Pearson Prentice Hall."@en ] ;
    skos:exactMatch glosis_cm:organicMatterClassProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil organic matter class"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilDescription .

eusoilvoc:SoilOxygenDeficiency a skos:Concept ;
    skos:broader eusoilvoc:SoilPhenomena ;
    skos:broaderTransitive eusoilvoc:SoilPhenomena ;
    skos:exactMatch spp:SoilOxygenDeficiency ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil oxygen deficiency"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilPhenomena .

eusoilvoc:SoilPhysicalFunctions a skos:Concept ;
    skos:altLabel "soil physical function"@en ;
    skos:broader eusoilvoc:SoilFunctions ;
    skos:broaderTransitive eusoilvoc:SoilFunctions ;
    skos:exactMatch she:SoilPhysicalFunctions ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil physical functions"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilFunctions .

eusoilvoc:SoilStrainHardening a skos:Concept ;
    skos:broader eusoilvoc:SoilPhenomena ;
    skos:broaderTransitive eusoilvoc:SoilPhenomena ;
    skos:exactMatch spp:SoilStrainHardening ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil strain hardening"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilPhenomena .

eusoilvoc:SoilSurfaceSeal a skos:Concept ;
    skos:broader eusoilvoc:SoilSubstance ;
    skos:broaderTransitive eusoilvoc:SoilSubstance ;
    skos:exactMatch spp:SoilSurfaceSeal ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil surface seal"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilSubstance .

eusoilvoc:SoilWaterInfiltrationRateClass a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:broaderTransitive eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_cm:infiltrationRateClassProperty ;
            rdf:value "The Soil Water Infiltration Rate Class classifies the soil’s ability to absorb water based on observed infiltration rates. This classification is typically divided into categories like slow, moderate, or rapid infiltration, based on how quickly water is absorbed into the soil. It is an essential property for understanding drainage, runoff, and irrigation needs. Source: Hillel, D. (2004). Introduction to Soil Physics. Academic Press."@en ] ;
    skos:exactMatch glosis_cm:infiltrationRateClassProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil water infiltration rate class"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilDescription .

eusoilvoc:SoilWaterRepellency a skos:Concept ;
    skos:broader eusoilvoc:SoilPhenomena ;
    skos:broaderTransitive eusoilvoc:SoilPhenomena ;
    skos:exactMatch spp:SoilWaterRepellency ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil water repellency"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilPhenomena .

eusoilvoc:SupportingServices a skos:Concept ;
    skos:altLabel "supporting service"@en ;
    skos:broader eusoilvoc:EcosystemServices ;
    skos:broaderTransitive eusoilvoc:EcosystemServices ;
    skos:definition [ dcterms:source agrovoc:c_0f955994 ;
            rdf:value "Providing living spaces for plants or animals and maintaining a diversity of plants and animals, are ‘supporting services' and the basis of all ecosystems and their services."@en ] ;
    skos:exactMatch agrovoc:c_0f955994,
        she:SupportingServices ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "supporting services"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:EcosystemServices .

eusoilvoc:TextureFieldClass a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:broaderTransitive eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_lh:textureFieldClassProperty ;
            rdf:value "The Texture Field Class categorizes soil texture based on the relative proportions of sand, silt, and clay, as assessed by field methods like the ribbon test. Field classes include sandy loam, clay loam, etc. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:textureFieldClassProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "texture field class"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilDescription .

eusoilvoc:TextureLabClass a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:broaderTransitive eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_lh:textureLabClassProperty ;
            rdf:value "The Texture Lab Class defines soil texture using laboratory-determined particle size distributions. This property provides a precise classification of soil as sand, silt, or clay using standard methods. Source: Brady, N.C., & Weil, R.R. (2008). The Nature and Properties of Soils."@en ] ;
    skos:exactMatch glosis_lh:textureLabClassProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "texture lab class"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilDescription .

eusoilvoc:VegetationClass a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:broaderTransitive eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_sp:vegetationClassProperty ;
            rdf:value "Vegetation Class refers to the categorization of vegetation types based on species composition and structure, such as forests, grasslands, and wetlands. The class of vegetation affects soil fertility, microbial activity, and water retention, which in turn influences agricultural potential and ecosystem services. Source: FAO, 'Vegetation and Land Use in Arid Zones'"@en ] ;
    skos:exactMatch glosis_sp:vegetationClassProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "vegetation class"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilDescription .

eusoilvoc:WaterRegulation a skos:Concept ;
    skos:broader eusoilvoc:SoilFunctions ;
    skos:broaderTransitive eusoilvoc:SoilFunctions ;
    skos:exactMatch she:WaterRegulation ;
