        eusoilvoc:SoilProperties ;
    skos:exactMatch spp:FriableConsistence ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "friable consistence"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilConsistence .

