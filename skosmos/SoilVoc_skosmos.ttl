    eusoilvoc:skosmosHierarchyParent eusoilvoc:Precipitation .

eusoilvoc:ModulusOfRupture a skos:Concept ;
    skos:broader eusoilvoc:SoilStrengthIndex ;
    skos:broaderTransitive eusoilvoc:SoilIndicators,
