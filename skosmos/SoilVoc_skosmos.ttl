eusoilvoc:CoatingLocation a skos:Concept ;
    skos:broader eusoilvoc:SoilCoating ;
    skos:broaderTransitive eusoilvoc:SoilCoating,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:coatingLocationProperty ;
            rdf:value "The Coating Location identifies where coatings are found within the soil profile, such as along root channels, pore spaces, or on particle surfaces. This property helps determine the movement of water and nutrients in the soil. Source: Soil Survey Staff (2014). Keys to Soil Taxonomy."@en ] ;
    skos:exactMatch glosis_lh:coatingLocationProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "coating location"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilCoating .

eusoilvoc:CoatingNature a skos:Concept ;
    skos:broader eusoilvoc:SoilCoating ;
    skos:broaderTransitive eusoilvoc:SoilCoating,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:coatingNatureProperty ;
            rdf:value "The Coating Nature examines the composition of soil coatings, such as organic, clay, or iron-rich coatings. The nature of these coatings can influence nutrient retention, soil color, and water dynamics. Source: Brady, N.C., & Weil, R.R. (2008). The Nature and Properties of Soils."@en ] ;
    skos:exactMatch glosis_lh:coatingNatureProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "coating nature"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilCoating .

eusoilvoc:ConsistenceDry a skos:Concept ;
    skos:broader eusoilvoc:SoilConsistence ;
    skos:broaderTransitive eusoilvoc:SoilConsistence,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:consistenceDryProperty ;
            rdf:value "The Consistence Dry evaluates the soil's behavior when dry, including its resistance to deformation or crumbling. It ranges from loose to hard and provides information about soil compaction and management practices. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:consistenceDryProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "consistence dry"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilConsistence .

eusoilvoc:ConsistenceMoist a skos:Concept ;
    skos:broader eusoilvoc:SoilConsistence ;
    skos:broaderTransitive eusoilvoc:SoilConsistence,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:consistenceMoistProperty ;
            rdf:value "The Consistence Moist assesses how soil responds to pressure when moist. Categories include friable, firm, or plastic. This property is essential for understanding soil workability and water retention. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:consistenceMoistProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "consistence moist"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilConsistence .

