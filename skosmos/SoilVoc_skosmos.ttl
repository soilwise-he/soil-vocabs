    skos:definition [ dcterms:source glosis_sp:geologyProperty ;
            rdf:value "Geology refers to the underlying geological composition of an area, including rock types, mineral content, and geological processes. The geology of a region influences soil formation, structure, fertility, and drainage properties. Source: AGI, 'Encyclopedia of Geology'"@en ] ;
    skos:exactMatch agrovoc:c_3232,
