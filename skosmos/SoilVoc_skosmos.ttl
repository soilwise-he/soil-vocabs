eusoilvoc:RockAbundance a skos:Concept ;
    skos:broader eusoilvoc:Rock ;
    skos:broaderTransitive eusoilvoc:Fragments,
        eusoilvoc:Rock,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_cm:rockAbundanceProperty ;
            rdf:value "The Rock Abundance refers to the proportion or percentage of rock fragments in the soil profile. High rock abundance can affect soil tillage, water retention, root penetration, and overall soil fertility. It is often used to assess land suitability for agriculture and vegetation. Source: FAO (2006). Guidelines for Soil Description (4th ed.). Food and Agriculture Organization of the United Nations."@en ] ;
    skos:exactMatch glosis_cm:rockAbundanceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "rock abundance"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Rock .

eusoilvoc:RockShape a skos:Concept ;
    skos:broader eusoilvoc:Rock ;
    skos:broaderTransitive eusoilvoc:Fragments,
        eusoilvoc:Rock,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_cm:rockShapeProperty ;
            rdf:value "The Rock Shape describes the physical form of rock fragments in the soil, which can range from angular to rounded. Angular rocks are generally a sign of recent weathering, while rounded rocks have been smoothed by long-term weathering processes. The shape of rocks influences soil texture, drainage, and tillage requirements. Source: FAO (2006). Guidelines for Soil Description (4th ed.). Food and Agriculture Organization of the United Nations."@en ] ;
    skos:exactMatch glosis_cm:rockShapeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "rock shape"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Rock .

eusoilvoc:RockSize a skos:Concept ;
    skos:broader eusoilvoc:Rock ;
    skos:broaderTransitive eusoilvoc:Fragments,
        eusoilvoc:Rock,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_cm:rockSizeProperty ;
            rdf:value "The Rock Size refers to the dimensions of the rock fragments present in the soil. Rocks are typically classified by their size, from small gravel to large boulders. Larger rocks can limit root growth, hinder water infiltration, and complicate soil management practices. Source: Soil Science Society of America. (2008). Soil Science Glossary. Soil Science Society of America."@en ] ;
    skos:exactMatch glosis_cm:rockSizeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "rock size"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Rock .

eusoilvoc:RootAbundance a skos:Concept ;
    skos:altLabel "roots abundance"@en ;
    skos:broader eusoilvoc:Roots ;
    skos:broaderTransitive eusoilvoc:LandCover,
        eusoilvoc:PlantCover,
        eusoilvoc:PlantPart,
        eusoilvoc:Roots ;
    skos:definition [ dcterms:source glosis_lh:rootsAbundanceProperty ;
            rdf:value "The Roots Abundance describes the quantity of plant roots within a soil profile, typically categorized as few, common, or many. Root abundance reflects plant-soil interactions, soil fertility, and the physical structure that supports vegetation. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:rootsAbundanceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "root abundance"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Roots .

eusoilvoc:RootBiomass a skos:Concept ;
    skos:broader eusoilvoc:Biomass ;
    skos:broaderTransitive eusoilvoc:Biomass,
        eusoilvoc:SoilBiologicalProperties,
        eusoilvoc:SoilBiota,
        eusoilvoc:SoilProperties ;
    skos:exactMatch spp:RootBiomass,
        inrae:c_6400 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "root biomass"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Biomass .

eusoilvoc:RootPresence a skos:Concept ;
    skos:altLabel "roots presence"@en ;
    skos:broader eusoilvoc:Roots ;
    skos:broaderTransitive eusoilvoc:LandCover,
        eusoilvoc:PlantCover,
        eusoilvoc:PlantPart,
        eusoilvoc:Roots ;
    skos:definition [ dcterms:source glosis_lh:rootsPresenceProperty ;
            rdf:value "The Roots Presence identifies whether roots are visible in a soil profile or horizon. It indicates biological activity, soil health, and the suitability of the soil for plant growth. Roots are commonly observed during soil surveys and are classified by type and density. Source: Soil Survey Staff (2014). Keys to Soil Taxonomy."@en ] ;
    skos:exactMatch glosis_lh:rootsPresenceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "root presence"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Roots .

