eusoilvoc:CropClass a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:broaderTransitive eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_sp:cropClassProperty ;
            rdf:value "Crop Class refers to the categorization of land based on the type of crops cultivated. This property is used to assess soil management practices and land productivity, as different crops require specific soil conditions for optimal growth. Source: FAO, 'Guidelines for Soil Profile Description'"@en ] ;
    skos:exactMatch glosis_sp:cropClassProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "crop class"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilDescription .

eusoilvoc:CulturalServices a skos:Concept ;
    skos:altLabel "cultural service"@en ;
    skos:broader eusoilvoc:EcosystemServices ;
    skos:broaderTransitive eusoilvoc:EcosystemServices ;
    skos:definition [ dcterms:source agrovoc:c_f359b8d7 ;
            rdf:value "Cultural services are ecosystem services that contribute to humans' emotional or social well-being, such as ecosystem components with spiritual significance, ecosystem components that contribute to aesthetic enjoyment, or ecosystems that offer options for recreation in nature."@en ] ;
    skos:exactMatch agrovoc:c_f359b8d7,
        she:CulturalServices ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "cultural services"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:EcosystemServices .

