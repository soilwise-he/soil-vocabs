    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Ccetot ;
            rdf:value "The total calcium carbonate equivalent measures the full capacity of soil to neutralize acidity, considering all forms of carbonate and bicarbonate minerals. It is essential for managing soil pH and nutrient availability in acidic soils. Source: FAO Soil Bulletin."@en ] ;
    skos:exactMatch glosis_cl:physioChemicalPropertyCode-Ccetot ;
