eusoilvoc:BaseSaturation a skos:Concept,
        sosa:ObservableProperty ;
    agrontology:isIncludedIn eusoilvoc:SoilPhysicalProperties ;
    skos:broader eusoilvoc:SoilChemicalProperties ;
    skos:broaderTransitive eusoilvoc:SoilChemicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source agrovoc:c_dbde833c ;
            rdf:value "The ratio of the quantity of exchangeable bases to the cation exchange capacity."@en ],
        [ dcterms:source glosis_cl:physioChemicalPropertyCode-Bascal ;
            rdf:value "Base saturation represents the percentage of the soil's cation exchange capacity (CEC) occupied by basic cations such as calcium (Ca²⁺), magnesium (Mg²⁺), potassium (K⁺), and sodium (Na⁺). Higher base saturation typically correlates with higher fertility and a greater ability to supply essential nutrients to plants. This parameter also influences soil pH buffering capacity. Source: Brady & Weil (2017)."@en ] ;
    skos:exactMatch agrovoc:c_dbde833c,
        glosis_cl:physioChemicalPropertyCode-Bascal,
        she:BaseSaturation ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "base saturation"@en ;
    sosa:hasProcedure eusoilvoc:baseSaturationProcedure-BSat_calcul-cec,
        eusoilvoc:baseSaturationProcedure-BSat_calcul-ecec ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilChemicalProperties .

