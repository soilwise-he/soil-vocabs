eusoilvoc:BulkDensityMineral a skos:Concept ;
    skos:broader eusoilvoc:SoilBulkDensity ;
    skos:broaderTransitive eusoilvoc:SoilBulkDensity,
        eusoilvoc:SoilDensity,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:bulkDensityMineralProperty ;
            rdf:value "The Bulk Density of Mineral Soil refers specifically to the density of the mineral portion of the soil, excluding organic matter. It provides insights into the physical state and compaction of mineral-dominated soils, influencing water movement and root growth. Source: Brady, N.C., & Weil, R.R. (2008). The Nature and Properties of Soils."@en ] ;
    skos:exactMatch glosis_lh:bulkDensityMineralProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "bulk density mineral"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilBulkDensity .

eusoilvoc:BulkDensityPeat a skos:Concept ;
    skos:broader eusoilvoc:SoilBulkDensity ;
    skos:broaderTransitive eusoilvoc:SoilBulkDensity,
        eusoilvoc:SoilDensity,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:bulkDensityPeatProperty ;
            rdf:value "The Bulk Density of Peat measures the mass of dry organic soil (peat) per unit volume. Peat soils typically have low bulk density due to their high organic matter content and porosity, which significantly affects their water retention and drainage characteristics. Source: Rydin, H., & Jeglum, J. (2006). The Biology of Peatlands."@en ] ;
    skos:exactMatch glosis_lh:bulkDensityPeatProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "bulk density peat"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilBulkDensity .

eusoilvoc:CationExchangeCapacityEffective a skos:Concept ;
    skos:broader eusoilvoc:CationExchangeCapacity ;
    skos:broaderTransitive eusoilvoc:CationExchangeCapacity,
        eusoilvoc:SoilChemicalCapacity,
        eusoilvoc:SoilChemicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:cationExchangeCapacityEffectiveProperty ;
            rdf:value "The Effective Cation Exchange Capacity (ECEC) measures the ability of soil to hold and exchange cations at a given pH, often near field conditions. It provides insight into soil fertility, nutrient availability, and buffering capacity in acidic soils. Source: Soil Survey Staff (2014). Keys to Soil Taxonomy."@en ] ;
    skos:exactMatch glosis_lh:cationExchangeCapacityEffectiveProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "cation exchange capacity effective"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:CationExchangeCapacity .

eusoilvoc:CationSum a skos:Concept ;
    skos:altLabel "cations sum"@en ;
    skos:broader eusoilvoc:ExchangeableCations ;
    skos:broaderTransitive eusoilvoc:ExchangeableCations,
        eusoilvoc:Ions,
        eusoilvoc:SoilChemical,
        eusoilvoc:SoilSubstance ;
    skos:definition [ dcterms:source glosis_lh:cationsSumProperty ;
            rdf:value "The Cations Sum calculates the total concentration of exchangeable cations (e.g., Ca²⁺, Mg²⁺, K⁺, Na⁺) in the soil. It helps determine soil fertility and salinity and is commonly expressed in milliequivalents per 100 grams of soil. Source: Soil Science Society of America (SSSA) Glossary."@en ] ;
    skos:exactMatch glosis_lh:cationsSumProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "cation sum"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:ExchangeableCations .

