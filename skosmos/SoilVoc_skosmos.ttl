eusoilvoc:LandUseBareCover a skos:Concept ;
    skos:broader eusoilvoc:LandUse ;
    skos:broaderTransitive eusoilvoc:ExternalFactors,
        eusoilvoc:LandUse,
        eusoilvoc:NonsoilIndicators,
        eusoilvoc:SoilIndicators ;
    skos:definition [ dcterms:source glosis_sp:bareCoverAbundanceProperty ;
            rdf:value "Bare Cover Abundance refers to the extent of land area without vegetation or artificial cover, such as bare soil or rocky surfaces. High proportions of bare cover increase the risk of soil erosion and desertification, particularly in areas with poor vegetation or human disturbance. Source: FAO, 'Land Use and Land Cover Classification'"@en ] ;
    skos:exactMatch glosis_sp:bareCoverAbundanceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "land use bare cover"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:LandUse .

eusoilvoc:LandUseForests a skos:Concept ;
    skos:altLabel "land use forest"@en ;
    skos:broader eusoilvoc:LandUse ;
    skos:broaderTransitive eusoilvoc:ExternalFactors,
        eusoilvoc:LandUse,
        eusoilvoc:NonsoilIndicators,
        eusoilvoc:SoilIndicators ;
    skos:definition [ dcterms:source glosis_sp:forestAbundanceProperty ;
            rdf:value "Forest Abundance refers to the proportion or extent of land covered by forest vegetation in a given area. It is often quantified as the percentage of land area dominated by tree species, reflecting the ecological importance of forests in influencing soil fertility, moisture retention, and biodiversity. Forested areas typically contribute to soil formation and stabilization through leaf litter and root systems that reduce erosion. Source: FAO, 'Forest Resources Assessment'"@en ] ;
    skos:exactMatch glosis_sp:forestAbundanceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "land use forests"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:LandUse .

eusoilvoc:LandUseGrasses a skos:Concept ;
    skos:altLabel "land use grass"@en ;
    skos:broader eusoilvoc:LandUse ;
    skos:broaderTransitive eusoilvoc:ExternalFactors,
        eusoilvoc:LandUse,
        eusoilvoc:NonsoilIndicators,
        eusoilvoc:SoilIndicators ;
    skos:definition [ dcterms:source glosis_sp:grassAbundanceProperty ;
            rdf:value "Grass Abundance indicates the extent or percentage of land covered by grasses or herbaceous plants. This property is important for understanding land productivity, grazing capacity, and soil health, as grasses play a key role in preventing soil erosion, enhancing organic matter content, and maintaining soil structure. Source: FAO, 'Grassland Ecosystems and Management'"@en ] ;
    skos:exactMatch glosis_sp:grassAbundanceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "land use grasses"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:LandUse .

eusoilvoc:LandUseShrubs a skos:Concept ;
    skos:altLabel "land use shrub"@en ;
    skos:broader eusoilvoc:LandUse ;
    skos:broaderTransitive eusoilvoc:ExternalFactors,
        eusoilvoc:LandUse,
        eusoilvoc:NonsoilIndicators,
        eusoilvoc:SoilIndicators ;
    skos:definition [ dcterms:source glosis_sp:shrubsAbundanceProperty ;
            rdf:value "Shrubs Abundance refers to the extent or abundance of shrub vegetation in a given area. Shrubs influence soil structure by reducing erosion, improving soil organic matter through leaf litter, and enhancing nutrient cycling. They are also indicators of ecosystem health in many terrestrial environments. Source: FAO, 'Vegetation and Land Use in Arid Zones'"@en ] ;
    skos:exactMatch glosis_sp:shrubsAbundanceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "land use shrubs"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:LandUse .

