eusoilvoc:FragmentClass a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:broaderTransitive eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_lh:fragmentsClassProperty ;
            rdf:value "The Fragments Class categorizes the size, shape, and quantity of coarse fragments (e.g., gravel, stones) present in the soil. These fragments affect soil porosity, water retention, and root penetration. The classification includes gravelly, stony, or bouldery soils. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:fragmentsClassProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "fragment class"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilDescription .

