eusoilvoc:Transpiration a skos:Concept ;
    agrontology:isIncludedIn eusoilvoc:Evapotranspiration ;
    skos:broader eusoilvoc:WaterInterchange ;
    skos:broaderTransitive eusoilvoc:PlanetaryPhenomena,
        eusoilvoc:WaterInterchange ;
    skos:definition [ dcterms:source agrovoc:c_7871 ;
            rdf:value "Transpiration consists of the vaporization of liquid water contained in plant tissues and the vapour removal to the atmosphere. Nearly all water taken up is lost by transpiration and only a tiny fraction is used within the plant."@en ] ;
    skos:exactMatch agrovoc:c_7871,
        spp:Transpiration,
        gemet:8630 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "transpiration"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:WaterInterchange .

