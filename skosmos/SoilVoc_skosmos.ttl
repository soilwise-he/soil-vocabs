eusoilvoc:GroundwaterDepth a skos:Concept ;
    skos:broader eusoilvoc:SoilWaterPhysicalProperties ;
    skos:broaderTransitive eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties,
        eusoilvoc:SoilWaterPhysicalProperties ;
    skos:definition [ dcterms:source glosis_sp:groundwaterDepthProperty ;
            rdf:value "Groundwater Depth indicates the depth from the soil surface to the water table, which affects soil moisture levels, plant growth, and root penetration. Shallow groundwater can influence soil salinity and nutrient availability, while deep groundwater may limit water access for plants. Source: USDA NRCS, 'Groundwater and Soil'"@en ] ;
    skos:exactMatch glosis_sp:groundwaterDepthProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "groundwater depth"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilWaterPhysicalProperties .

eusoilvoc:GypsumContents a skos:Concept ;
    skos:altLabel "gypsum content"@en ;
    skos:broader eusoilvoc:Gypsum ;
    skos:broaderTransitive eusoilvoc:Gypsum,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:gypsumContentProperty ;
            rdf:value "The Gypsum Content quantifies the amount of gypsum (calcium sulfate dihydrate) present in the soil. Gypsum affects soil structure, water infiltration, and nutrient availability, especially in arid and semi-arid regions. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:gypsumContentProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "gypsum contents"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Gypsum .

eusoilvoc:GypsumForms a skos:Concept ;
    skos:altLabel "gypsum form"@en ;
    skos:broader eusoilvoc:Gypsum ;
    skos:broaderTransitive eusoilvoc:Gypsum,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:gypsumFormsProperty ;
            rdf:value "The Gypsum Forms describes the morphology of gypsum within the soil, such as crystals, veins, or nodules. The form indicates the processes of soil formation and water movement in gypsum-rich soils. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:gypsumFormsProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "gypsum forms"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Gypsum .

eusoilvoc:GypsumWeight a skos:Concept ;
    skos:broader eusoilvoc:Gypsum ;
    skos:broaderTransitive eusoilvoc:Gypsum,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:gypsumWeightProperty ;
            rdf:value "The Gypsum Weight measures the mass of gypsum in the soil profile. This value helps evaluate the potential for soil salinity issues and influences decisions for agricultural or land reclamation practices. Source: Brady, N.C., & Weil, R.R. (2008). The Nature and Properties of Soils."@en ] ;
    skos:exactMatch glosis_lh:gypsumWeightProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "gypsum weight"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Gypsum .

eusoilvoc:Hail a skos:Concept ;
    skos:broader eusoilvoc:Precipitation ;
    skos:broaderTransitive eusoilvoc:PlanetaryPhenomena,
        eusoilvoc:Precipitation,
        eusoilvoc:WaterInterchange ;
    skos:definition [ dcterms:source agrovoc:c_3469 ;
            rdf:value "Precipitation of particles of ice (hailstones). These can be either transparent, or partly or completely opaque. They are usually spheroidal, conical or irregular in form, and generally 5−50 mm in diameter. The particles may fall from a cloud either separately or agglomerated in irregular lumps."@en ] ;
    skos:exactMatch agrovoc:c_3469,
        spp:Hail,
        inrae:c_11412,
        gemet:3812 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "hail"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Precipitation .

