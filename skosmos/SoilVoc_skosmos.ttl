eusoilvoc:VoidClassification a skos:Concept ;
    skos:altLabel "voids classification"@en ;
    skos:broader eusoilvoc:SoilVoids ;
    skos:broaderTransitive eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilPorePhysicalProperties,
        eusoilvoc:SoilProperties,
        eusoilvoc:SoilVoids ;
    skos:definition [ dcterms:source glosis_lh:voidsClassificationProperty ;
            rdf:value "The Voids Classification categorizes voids or pores in the soil based on size, shape, and arrangement. These voids are critical for water movement, air circulation, and root penetration. They are classified into macropores (large), mesopores (medium), and micropores (small). Source: Hillel, D. (2004). Introduction to Environmental Soil Physics."@en ] ;
    skos:exactMatch glosis_lh:voidsClassificationProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "void classification"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilVoids .

eusoilvoc:VoidDiameter a skos:Concept ;
    skos:altLabel "voids diameter"@en ;
    skos:broader eusoilvoc:SoilVoids ;
    skos:broaderTransitive eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilPorePhysicalProperties,
        eusoilvoc:SoilProperties,
        eusoilvoc:SoilVoids ;
    skos:definition [ dcterms:source glosis_lh:voidsDiameterProperty ;
            rdf:value "The Voids Diameter refers to the size of void spaces in soil, which can range from macro-voids (larger pores) to micro-voids (tiny pores). Voids diameter impacts soil aeration, water retention, and drainage. Source: Soil Science Society of America (SSSA) Glossary."@en ] ;
    skos:exactMatch glosis_lh:voidsDiameterProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "void diameter"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilVoids .

