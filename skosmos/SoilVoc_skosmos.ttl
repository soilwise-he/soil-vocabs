eusoilvoc:MoistConsistency a skos:Concept ;
    skos:broader eusoilvoc:SoilConsistency ;
    skos:broaderTransitive eusoilvoc:SoilConsistency,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:moistConsistencyProperty ;
            rdf:value "The Moist Consistency evaluates the soil's behavior under pressure when moist. Categories include friable, firm, or plastic. It provides insights into soil workability and its ability to support plant growth. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:moistConsistencyProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "moist consistency"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilConsistency .

eusoilvoc:MottleAbundance a skos:Concept ;
    skos:altLabel "mottles abundance"@en ;
    skos:broader eusoilvoc:SoilMottle ;
    skos:broaderTransitive eusoilvoc:SoilMottle,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:mottlesAbundanceProperty ;
            rdf:value "The Mottles Abundance describes the frequency of mottling (spots of contrasting color) in soil horizons. Mottling indicates variations in soil aeration, drainage, or water saturation. Abundance is typically classified as few, common, or many. Source: Soil Survey Staff (2014). Keys to Soil Taxonomy."@en ] ;
    skos:exactMatch glosis_lh:mottlesAbundanceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mottle abundance"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilMottle .

eusoilvoc:MottleBoundaryClassification a skos:Concept ;
    skos:altLabel "mottles boundary classification"@en ;
    skos:broader eusoilvoc:SoilMottle ;
    skos:broaderTransitive eusoilvoc:SoilMottle,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:mottlesBoundaryClassificationProperty ;
            rdf:value "The Mottles Boundary Classification assesses the sharpness and distinctness of boundaries between mottled and non-mottled areas within the soil. It provides clues about soil processes such as oxidation-reduction reactions. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:mottlesBoundaryClassificationProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mottle boundary classification"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilMottle .

eusoilvoc:MottleColour a skos:Concept ;
    skos:altLabel "mottles colour"@en ;
    skos:broader eusoilvoc:SoilMottle ;
    skos:broaderTransitive eusoilvoc:SoilMottle,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:mottlesColourProperty ;
            rdf:value "The Mottles Colour evaluates the color of soil mottles, often indicative of oxidation states of iron or manganese. For example, reddish colors suggest oxidation, while gray colors indicate reduction and poor drainage. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:mottlesColourProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mottle colour"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilMottle .

eusoilvoc:MottleContrast a skos:Concept ;
    skos:altLabel "mottles contrast"@en ;
    skos:broader eusoilvoc:SoilMottle ;
    skos:broaderTransitive eusoilvoc:SoilMottle,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:mottlesContrastProperty ;
            rdf:value "The Mottles Contrast measures the visual distinction between mottles and the surrounding soil matrix. High contrast indicates stark differences, often linked to fluctuating water tables or drainage issues. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:mottlesContrastProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mottle contrast"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilMottle .

eusoilvoc:MottlePresence a skos:Concept ;
    skos:altLabel "mottles presence"@en ;
    skos:broader eusoilvoc:SoilMottle ;
    skos:broaderTransitive eusoilvoc:SoilMottle,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:mottlesPresenceProperty ;
            rdf:value "The Mottles Presence refers to the existence of mottles in soil, often signaling periodic water saturation, drainage problems, or fluctuating redox conditions. This property is essential for wetland delineation and soil health assessment. Source: Soil Survey Staff (2014). Keys to Soil Taxonomy."@en ] ;
    skos:exactMatch glosis_lh:mottlesPresenceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mottle presence"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilMottle .

eusoilvoc:MottleSize a skos:Concept ;
    skos:altLabel "mottles size"@en ;
    skos:broader eusoilvoc:SoilMottle ;
    skos:broaderTransitive eusoilvoc:SoilMottle,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:mottlesSizeProperty ;
            rdf:value "The Mottles Size describes the dimensions of soil mottles, typically classified as fine, medium, or coarse. The size reflects the intensity and scale of soil processes such as oxidation and reduction. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:mottlesSizeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mottle size"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilMottle .

eusoilvoc:ParticleSizeFractionSum a skos:Concept ;
    skos:broader eusoilvoc:SoilParticlePhysicalProperties ;
    skos:broaderTransitive eusoilvoc:SoilParticlePhysicalProperties,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:particleSizeFractionsSumProperty ;
            rdf:value "The Particle Size Fractions Sum refers to the total proportion of sand, silt, and clay particles in soil, expressed as a percentage. It ensures the sum of individual particle size fractions adds up to 100%, a check for accurate soil texture analysis. Particle size distribution impacts water retention, permeability, and soil structure. Source: Hillel, D. (2004). Introduction to Environmental Soil Physics."@en ] ;
    skos:exactMatch glosis_lh:particleSizeFractionsSumProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "particle size fraction sum"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilParticlePhysicalProperties .

eusoilvoc:PeatDecompostion a skos:Concept ;
    skos:broader eusoilvoc:Peat ;
    skos:broaderTransitive eusoilvoc:Peat,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:peatDecompostionProperty ;
            rdf:value "The Peat Decomposition evaluates the degree of decomposition in organic soils or peat. Categories include fibric (least decomposed), hemic (moderately decomposed), and sapric (highly decomposed), which influence soil fertility and drainage. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:peatDecompostionProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "peat decompostion"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Peat .

eusoilvoc:PeatDrainage a skos:Concept ;
    skos:broader eusoilvoc:Peat ;
    skos:broaderTransitive eusoilvoc:Peat,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:peatDrainageProperty ;
            rdf:value "The Peat Drainage assesses the water removal capacity in peat soils, essential for determining their suitability for agriculture, conservation, or other uses. Poorly drained peat often accumulates organic material due to low decomposition rates. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:peatDrainageProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "peat drainage"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Peat .

eusoilvoc:PeatVolume a skos:Concept ;
    skos:broader eusoilvoc:Peat ;
    skos:broaderTransitive eusoilvoc:Peat,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:peatVolumeProperty ;
            rdf:value "The Peat Volume quantifies the proportion of peat material in a given soil volume. It is critical for land use planning, carbon sequestration assessments, and wetland management. Source: Soil Survey Staff (2014). Keys to Soil Taxonomy."@en ] ;
    skos:exactMatch glosis_lh:peatVolumeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "peat volume"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Peat .

eusoilvoc:PercentWaterStableAggregation a skos:Concept ;
    skos:broader eusoilvoc:SoilAggregationIndex ;
    skos:broaderTransitive eusoilvoc:SoilAggregationIndex,
        eusoilvoc:SoilIndicators,
        eusoilvoc:SoilStructureIndex ;
    skos:exactMatch spp:PercentWaterStableAggregation ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "percent water stable aggregation"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilAggregationIndex .

eusoilvoc:PlasticConsistence a skos:Concept ;
    skos:broader eusoilvoc:SoilConsistence ;
    skos:broaderTransitive eusoilvoc:SoilConsistence,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:exactMatch spp:PlasticConsistence ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "plastic consistence"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilConsistence .

eusoilvoc:Rain a skos:Concept ;
    skos:broader eusoilvoc:Precipitation ;
    skos:broaderTransitive eusoilvoc:PlanetaryPhenomena,
        eusoilvoc:Precipitation,
        eusoilvoc:WaterInterchange ;
    skos:exactMatch agrovoc:c_6435,
        spp:Rain,
        inrae:c_11627,
        gemet:6947 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "rain"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Precipitation .

eusoilvoc:SaltCover a skos:Concept ;
    skos:broader eusoilvoc:Salts ;
    skos:broaderTransitive eusoilvoc:Salts,
        eusoilvoc:SoilChemical,
        eusoilvoc:SoilSubstance ;
    skos:definition [ dcterms:source glosis_su:saltCoverProperty ;
            rdf:value "Salt cover refers to the accumulation of salts on the surface of the soil, often visible as a crystalline crust. This phenomenon occurs when capillary action causes soluble salts to move upwards through the soil, where they crystallize as water evaporates. Salt cover can interfere with seed germination, plant growth, and water infiltration, and is commonly found in arid and semi-arid regions with high evaporation rates. Source: Brady, N.C., & Weil, R.R. (2008). The Nature and Properties of Soils (14th ed.). Pearson Education."@en ] ;
    skos:exactMatch glosis_su:saltCoverProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "salt cover"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Salts .

eusoilvoc:SaltPresence a skos:Concept ;
    skos:broader eusoilvoc:Salts ;
    skos:broaderTransitive eusoilvoc:Salts,
        eusoilvoc:SoilChemical,
        eusoilvoc:SoilSubstance ;
    skos:definition [ dcterms:source glosis_su:saltPresenceProperty ;
            rdf:value "The salt presence of soil refers to the concentration of soluble salts, such as sodium, calcium, and magnesium, within the soil profile. High salt levels can lead to soil salinity, negatively affecting plant growth by altering water availability and soil structure. The presence of salts is typically measured using electrical conductivity (EC) or specific ion concentration tests. Soils with high salt presence are often found in arid regions where evaporation exceeds precipitation, leading to salt accumulation at or near the surface. Source: Rhoades, J.D., & Kandiah, A. (1992). Soil Salinity Management in Agriculture. Springer."@en ] ;
    skos:exactMatch glosis_su:saltPresenceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "salt presence"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Salts .

eusoilvoc:SaltThickness a skos:Concept ;
    skos:broader eusoilvoc:Salts ;
    skos:broaderTransitive eusoilvoc:Salts,
        eusoilvoc:SoilChemical,
        eusoilvoc:SoilSubstance ;
    skos:definition [ dcterms:source glosis_su:saltThicknessProperty ;
            rdf:value "Salt thickness refers to the depth of the soil profile at which soluble salts are present in significant concentrations. This property is particularly important in regions subject to evaporation and capillary rise, where salts accumulate near the surface or at specific depths. Salt thickness can impact soil fertility and water retention, as the concentrated salts can inhibit root growth and water uptake. This property is commonly determined through soil sampling and electrical conductivity measurements at various depths. Source: United States Salinity Laboratory Staff. (1954). Diagnosis and Improvement of Saline and Alkali Soils. U.S. Department of Agriculture Handbook No. 60."@en ] ;
    skos:exactMatch glosis_su:saltThicknessProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "salt thickness"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Salts .

eusoilvoc:SandyTexture a skos:Concept ;
    skos:broader eusoilvoc:SoilTexture ;
    skos:broaderTransitive eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties,
        eusoilvoc:SoilTexture ;
    skos:definition [ dcterms:source glosis_lh:sandyTextureProperty ;
            rdf:value "The Sandy Texture refers to soil dominated by sand particles (0.05–2.0 mm in diameter). Sandy soils are well-drained, low in nutrients, and prone to drought due to poor water retention. Source: Soil Science Society of America (SSSA) Glossary."@en ] ;
    skos:exactMatch glosis_lh:sandyTextureProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "sandy texture"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilTexture .

eusoilvoc:SaturatedVapourPressure a skos:Concept ;
    skos:broader eusoilvoc:SoilVapourPressure ;
    skos:broaderTransitive eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties,
        eusoilvoc:SoilVapourPressure ;
    skos:exactMatch spp:SaturatedVaporPressure ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "saturated vapour pressure"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilVapourPressure .

eusoilvoc:Sleet a skos:Concept ;
    skos:broader eusoilvoc:Precipitation ;
    skos:broaderTransitive eusoilvoc:PlanetaryPhenomena,
        eusoilvoc:Precipitation,
        eusoilvoc:WaterInterchange ;
    skos:exactMatch agrovoc:c_14332,
        spp:Sleet ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "sleet"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Precipitation .

eusoilvoc:SlopeGradientNumeric a skos:Concept ;
    skos:broader eusoilvoc:SlopeGradient ;
    skos:broaderTransitive eusoilvoc:Physiography,
        eusoilvoc:Slope,
        eusoilvoc:SlopeGradient ;
    skos:definition [ dcterms:source glosis_sp:slopeGradientProperty ;
            rdf:value "Slope Gradient Property refers to the numerical measurement of the steepness of a slope, usually expressed as a percentage or angle. This property is crucial in determining soil erosion potential, water runoff, and suitability for land use, as steeper slopes are more prone to erosion and less suitable for cultivation without proper soil conservation measures. Source: USDA NRCS, 'Soil Erosion and Conservation'"@en ] ;
    skos:exactMatch glosis_sp:slopeGradientProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "slope gradient numeric"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SlopeGradient .

eusoilvoc:SlopeOrientationNumeric a skos:Concept ;
    skos:broader eusoilvoc:SlopeOrientation ;
    skos:broaderTransitive eusoilvoc:Physiography,
        eusoilvoc:Slope,
        eusoilvoc:SlopeOrientation ;
    skos:definition [ dcterms:source glosis_sp:slopeOrientationProperty ;
            rdf:value "Slope Orientation refers to the precise directional orientation of a slope, measured in degrees from a cardinal direction (e.g., 0° for north, 180° for south). The slope orientation impacts factors such as solar radiation, evaporation rates, and vegetation cover, all of which affect soil temperature, moisture retention, and erosion potential. Source: USDA NRCS, 'Soil Erosion and Landscape Analysis'"@en ] ;
