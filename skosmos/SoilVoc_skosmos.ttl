eusoilvoc:SoilPlasticity a skos:Concept ;
    skos:broader eusoilvoc:SoilPhysicalProperties ;
    skos:broaderTransitive eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:plasticityProperty ;
            rdf:value "The Plasticity measures the soil's ability to deform under stress without cracking or breaking, especially when wet. It is influenced by clay content and mineralogy and is important for engineering and agricultural applications. Source: Hillel, D. (2004). Introduction to Environmental Soil Physics."@en ] ;
    skos:exactMatch spp:SoilPlasticity,
        glosis_lh:plasticityProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:narrower eusoilvoc:WetPlasticity ;
    skos:narrowerTransitive eusoilvoc:WetPlasticity ;
    skos:prefLabel "soil plasticity"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilPhysicalProperties .

eusoilvoc:SoilQuality a skos:Concept ;
    skos:definition [ dcterms:source agrovoc:c_a9645d28 ;
            rdf:value "Ability of soil to provide ecosystem services through its capacities to perform soil functions such as biodiversity, productivity, water filtering and buffering, and nutrient cycling."@en ] ;
    skos:exactMatch agrovoc:c_a9645d28,
        inrae:c_661,
        gemet:7884,
        iso11074:3.466,
        she:SoilQuality ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil quality"@en ;
    skos:related eusoilvoc:SoilProductivity,
        eusoilvoc:SoilWaterRetention ;
    skos:topConceptOf <https://w3id.org/eusoilvoc> .

