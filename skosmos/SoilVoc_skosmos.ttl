    skos:closeMatch she:SoilSalinisation ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "salinisation"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilThreats .

eusoilvoc:SaltSieving a skos:Concept ;
    skos:broader eusoilvoc:SoilPhenomena ;
