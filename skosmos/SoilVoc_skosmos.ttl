    skos:altLabel "soil biological function"@en ;
    skos:broader eusoilvoc:SoilFunctions ;
    skos:broaderTransitive eusoilvoc:SoilFunctions ;
    skos:exactMatch she:SoilBiologicalFunctions ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil biological functions"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilFunctions .

eusoilvoc:SoilChemicalFunctions a skos:Concept ;
    skos:altLabel "soil chemical function"@en ;
