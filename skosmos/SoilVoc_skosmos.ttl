        eusoilvoc:totalElementsProcedure-Total_tp10,
        eusoilvoc:totalElementsProcedure-Total_unkn,
        eusoilvoc:totalElementsProcedure-Total_xrd,
        eusoilvoc:totalElementsProcedure-Total_xrf,
        eusoilvoc:totalElementsProcedure-Total_xrf-p,
