eusoilvoc:SodiumTotalElements a skos:Concept,
        sosa:ObservableProperty ;
    skos:broader eusoilvoc:Sodium ;
    skos:broaderTransitive eusoilvoc:Sodium,
        eusoilvoc:SoilChemicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Sodtot ;
            rdf:value "Total sodium includes all sodium present in soil, both soluble and bound. Excess sodium can lead to sodicity, which disrupts soil structure, reduces permeability, and impairs plant growth. Monitoring sodium levels is crucial for managing soil salinity in arid and irrigated regions. Source: Bohn, H.L., et al. (2001). Soil Chemistry."@en ] ;
    skos:exactMatch glosis_cl:physioChemicalPropertyCode-Sodtot ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "sodium total elements"@en ;
    sosa:hasProcedure eusoilvoc:totalElementsProcedure-Total_h2so4,
        eusoilvoc:totalElementsProcedure-Total_hcl,
        eusoilvoc:totalElementsProcedure-Total_hcl-aquaregia,
