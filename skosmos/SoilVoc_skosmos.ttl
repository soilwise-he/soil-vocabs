eusoilvoc:SoilElectricalConductivity a skos:Concept,
        sosa:ObservableProperty ;
    skos:broader eusoilvoc:SoilPhysicalProperties ;
    skos:broaderTransitive eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Eleccond ;
            rdf:value "Electrical conductivity (EC) measures the ability of soil to conduct an electrical current, which is directly related to the concentration of soluble salts. It is an essential indicator of soil salinity and is used to assess soil's suitability for crop growth. High EC levels can reduce plant water uptake and affect germination, while low levels indicate low salinity and better soil health. Source: USDA NRCS."@en ] ;
    skos:exactMatch spp:SoilElectricalConductivity,
        glosis_cl:physioChemicalPropertyCode-Eleccond ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil electrical conductivity"@en ;
    sosa:hasProcedure eusoilvoc:electricalConductivityProcedure-EC_ratio1-1,
        eusoilvoc:electricalConductivityProcedure-EC_ratio1-10,
        eusoilvoc:electricalConductivityProcedure-EC_ratio1-2,
        eusoilvoc:electricalConductivityProcedure-EC_ratio1-2.5,
        eusoilvoc:electricalConductivityProcedure-EC_ratio1-5,
        eusoilvoc:electricalConductivityProcedure-ECe_sat ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilPhysicalProperties .

