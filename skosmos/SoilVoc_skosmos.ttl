eusoilvoc:RockOutcropCover a skos:Concept ;
    skos:altLabel "rock outcrops cover"@en ;
    skos:broader eusoilvoc:RockOutcrops ;
    skos:broaderTransitive eusoilvoc:Geology,
        eusoilvoc:RockOutcrops ;
    skos:definition [ dcterms:source glosis_sp:rockOutcropsCoverProperty ;
            rdf:value "Rock Outcrops Cover measures the extent to which rock outcrops (exposed bedrock or rock masses) cover the landscape. The presence of rock outcrops can influence soil depth and water retention, as well as contribute to erosion and landscape stability, particularly in areas with minimal soil cover. Source: USDA NRCS, 'Soil Survey Manual'"@en ] ;
    skos:exactMatch glosis_sp:rockOutcropsCoverProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "rock outcrop cover"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:RockOutcrops .

eusoilvoc:RockOutcropDistance a skos:Concept ;
    skos:altLabel "rock outcrops distance"@en ;
    skos:broader eusoilvoc:RockOutcrops ;
    skos:broaderTransitive eusoilvoc:Geology,
        eusoilvoc:RockOutcrops ;
    skos:definition [ dcterms:source glosis_sp:rockOutcropsDistanceProperty ;
            rdf:value "Rock Outcrops Distance quantifies the distance from a given point or area to the nearest rock outcrop. The proximity to rock outcrops can influence soil development, with areas closer to outcrops often having thinner soils and higher vulnerability to erosion. Source: FAO, 'Soil Formation and Classification'"@en ] ;
    skos:exactMatch glosis_sp:rockOutcropsDistanceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "rock outcrop distance"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:RockOutcrops .

