eusoilvoc:Stickiness a skos:Concept ;
    sio:equivalentTo eusoilvoc:SoilAdhesion ;
    skos:broader eusoilvoc:SoilPhysicalProperties ;
    skos:broaderTransitive eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:stickinessProperty ;
            rdf:value "The Stickiness measures the soil’s tendency to adhere to surfaces or objects when wet. It is influenced by clay content and organic matter and affects soil workability and machinery use. Source: Hillel, D. (2004). Introduction to Environmental Soil Physics."@en ] ;
    skos:exactMatch agrovoc:c_7409,
        glosis_lh:stickinessProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "stickiness"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilPhysicalProperties .

eusoilvoc:StructuralPores a skos:Concept ;
    skos:altLabel "structural pore"@en ;
    skos:broader eusoilvoc:SoilPores ;
    skos:broaderTransitive eusoilvoc:SoilPores,
        eusoilvoc:SoilSubstance ;
    skos:exactMatch spp:StructuralPore ;
