eusoilvoc:SoilDepthBedrock a skos:Concept ;
    skos:broader eusoilvoc:SoilDepth ;
    skos:broaderTransitive eusoilvoc:SoilDepth,
        eusoilvoc:SoilProperties,
        eusoilvoc:SoilSpatialProperties ;
    skos:definition [ dcterms:source glosis_cm:soilDepthBedrockProperty ;
            rdf:value "The Soil Depth Bedrock refers to the distance from the soil surface to the underlying bedrock layer. This measurement is important for understanding the soil's capacity to support plant growth, as soils with shallow bedrock tend to have limited rooting depth, affecting water retention and nutrient availability. Source: FAO (2006). Guidelines for Soil Description (4th ed.). Food and Agriculture Organization of the United Nations."@en ] ;
    skos:exactMatch glosis_cm:soilDepthBedrockProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil depth bedrock"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilDepth .

eusoilvoc:SoilDepthRootable a skos:Concept ;
    skos:broader eusoilvoc:SoilDepth ;
    skos:broaderTransitive eusoilvoc:SoilDepth,
        eusoilvoc:SoilProperties,
        eusoilvoc:SoilSpatialProperties ;
    skos:definition [ dcterms:source glosis_cm:soilDepthRootableProperty ;
            rdf:value "The Soil Depth Rootable refers to the actual vertical depth of soil that can support plant roots, excluding any non-rootable layers such as bedrock or a water-impervious horizon. This depth is crucial for determining the suitability of land for agriculture and vegetation. Source: Soil Science Society of America. (2008). Soil Science Glossary. Soil Science Society of America."@en ] ;
    skos:exactMatch glosis_cm:soilDepthRootableProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil depth rootable"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilDepth .

eusoilvoc:SoilDepthSampled a skos:Concept ;
    skos:broader eusoilvoc:SoilDepth ;
    skos:broaderTransitive eusoilvoc:SoilDepth,
        eusoilvoc:SoilProperties,
        eusoilvoc:SoilSpatialProperties ;
    skos:definition [ dcterms:source glosis_cm:soilDepthSampledProperty ;
            rdf:value "The Soil Depth Sampled indicates the specific depth of the soil profile that has been sampled for analysis. This property is important for understanding the representativeness of the sample, as different soil horizons may vary significantly in properties such as texture, fertility, and moisture content. Source: Soil Science Society of America. (2008). Soil Science Glossary. Soil Science Society of America."@en ] ;
    skos:exactMatch glosis_cm:soilDepthSampledProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil depth sampled"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilDepth .

