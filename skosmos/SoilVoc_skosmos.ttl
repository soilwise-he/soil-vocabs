eusoilvoc:WaterStorageCapacity a skos:Concept ;
    skos:broader eusoilvoc:SoilFunctionIndicators ;
    skos:broaderTransitive eusoilvoc:SoilFunctionIndicators,
        eusoilvoc:SoilIndicators ;
    skos:exactMatch she:WaterStorageCapacity ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "water storage capacity"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilFunctionIndicators .

eusoilvoc:WeatherCurrent a skos:Concept ;
    skos:broader eusoilvoc:Weather ;
    skos:broaderTransitive eusoilvoc:PlanetaryPhenomena,
        eusoilvoc:Weather ;
    skos:definition [ dcterms:source glosis_sp:weatherConditionsCurrentProperty ;
            rdf:value "Weather Conditions Current describes the current atmospheric conditions in a specific location, including factors like temperature, humidity, wind speed, and precipitation. These conditions directly affect soil moisture, temperature, and erosion rates, influencing soil fertility and the ability to support plant growth. Source: USGS, 'Meteorological and Soil Interactions'"@en ] ;
    skos:exactMatch glosis_sp:weatherConditionsCurrentProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "weather current"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Weather .

eusoilvoc:WeatherPast a skos:Concept ;
    skos:broader eusoilvoc:Weather ;
    skos:broaderTransitive eusoilvoc:PlanetaryPhenomena,
        eusoilvoc:Weather ;
    skos:definition [ dcterms:source glosis_sp:weatherConditionsPastProperty ;
            rdf:value "Weather Conditions Past refers to historical weather data, including past patterns of temperature, precipitation, and extreme weather events. Understanding past weather conditions helps in predicting soil behavior, erosion patterns, and agricultural productivity, as well as preparing for future changes in soil moisture and temperature. Source: USDA NRCS, 'Climate and Soil Interactions'"@en ] ;
    skos:exactMatch glosis_sp:weatherConditionsPastProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "weather past"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Weather .

eusoilvoc:AerationPorosity a skos:Concept ;
    skos:broader eusoilvoc:SoilPorosityIndex ;
    skos:broaderTransitive eusoilvoc:SoilIndicators,
        eusoilvoc:SoilPorosityIndex,
        eusoilvoc:SoilStructureIndex ;
    skos:exactMatch spp:AerationPorosity ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "aeration porosity"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilPorosityIndex .

eusoilvoc:AggregatedSiltClay a skos:Concept ;
    skos:broader eusoilvoc:SoilStructureIndirectIndex ;
    skos:broaderTransitive eusoilvoc:SoilIndicators,
        eusoilvoc:SoilStructureIndex,
        eusoilvoc:SoilStructureIndirectIndex ;
    skos:exactMatch spp:AggregatedSiltClay ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "aggregated silt clay"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilStructureIndirectIndex .

eusoilvoc:BoundaryDistinctness a skos:Concept ;
    skos:broader eusoilvoc:SoilHorizonBoundary ;
    skos:broaderTransitive eusoilvoc:SoilHorizonBoundary,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:boundaryDistinctnessProperty ;
            rdf:value "The Boundary Distinctness describes the sharpness of transitions between soil horizons. Boundaries can range from abrupt (clear demarcation) to diffuse (gradual blending), providing insights into soil formation processes and profile development. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:boundaryDistinctnessProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "boundary distinctness"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilHorizonBoundary .

eusoilvoc:BoundaryTopography a skos:Concept ;
    skos:broader eusoilvoc:SoilHorizonBoundary ;
    skos:broaderTransitive eusoilvoc:SoilHorizonBoundary,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:boundaryTopographyProperty ;
            rdf:value "The Boundary Topography characterizes the shape of soil horizon boundaries, which may be smooth, wavy, irregular, or broken. It reflects processes like erosion, deposition, or biological activity that influence horizon development. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:boundaryTopographyProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "boundary topography"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilHorizonBoundary .

eusoilvoc:CarbonateContents a skos:Concept ;
    skos:altLabel "carbonate content"@en ;
    skos:broader eusoilvoc:Carbonate ;
    skos:broaderTransitive eusoilvoc:Carbonate,
        eusoilvoc:SoilChemicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:carbonatesContentProperty ;
            rdf:value "The Carbonate Content quantifies the concentration of carbonate minerals (e.g., CaCO₃, MgCO₃) in soil. These compounds influence soil pH, fertility, and structure, and are prevalent in calcareous soils. Source: Brady, N.C., & Weil, R.R. (2008). The Nature and Properties of Soils."@en ] ;
    skos:exactMatch glosis_lh:carbonatesContentProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "carbonate contents"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Carbonate .

eusoilvoc:CarbonateForms a skos:Concept ;
    skos:altLabel "carbonate form"@en ;
    skos:broader eusoilvoc:Carbonate ;
    skos:broaderTransitive eusoilvoc:Carbonate,
        eusoilvoc:SoilChemicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:carbonatesFormsProperty ;
            rdf:value "The Carbonate Form describes the types of carbonate minerals present in soil, such as calcite, dolomite, or aragonite. These forms impact soil chemistry, fertility, and physical characteristics differently depending on their composition and solubility. Source: Sparks, D.L. (2003). Environmental Soil Chemistry."@en ] ;
    skos:exactMatch glosis_lh:carbonatesFormsProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "carbonate forms"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Carbonate .

eusoilvoc:CationExchange a skos:Concept ;
    skos:broader eusoilvoc:IonExchange ;
    skos:broaderTransitive eusoilvoc:IonExchange,
        eusoilvoc:SoilChemicalProcesses,
        eusoilvoc:SoilProcesses ;
    skos:exactMatch spp:CationExchange,
        inrae:c_3a30d01b,
        she:CationExchange ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "cation exchange"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:IonExchange .

eusoilvoc:CementationContinuity a skos:Concept ;
    skos:broader eusoilvoc:Cementation ;
    skos:broaderTransitive eusoilvoc:Cementation,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:cementationContinuityProperty ;
            rdf:value "The Cementation Continuity describes the extent to which soil particles are bound together by cementing agents, such as calcium carbonate, iron oxides, or silica. Cementation affects soil permeability, root penetration, and the development of soil horizons. Continuity can be classified as continuous, discontinuous, or patchy. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:cementationContinuityProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "cementation continuity"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Cementation .

eusoilvoc:CementationDegree a skos:Concept ;
    skos:broader eusoilvoc:Cementation ;
    skos:broaderTransitive eusoilvoc:Cementation,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:cementationDegreeProperty ;
            rdf:value "The Cementation Degree measures how strongly soil particles are bonded by cementing agents. It ranges from weakly cemented (friable) to strongly cemented (hard). This property influences soil strength and its suitability for agricultural and engineering purposes. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:cementationDegreeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "cementation degree"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Cementation .

eusoilvoc:CementationFabric a skos:Concept ;
    skos:broader eusoilvoc:Cementation ;
    skos:broaderTransitive eusoilvoc:Cementation,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:cementationFabricProperty ;
            rdf:value "The Cementation Fabric examines the texture, structure, and arrangement of cementing materials within the soil. It provides insights into soil formation processes and the mechanical stability of the soil matrix. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:cementationFabricProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "cementation fabric"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Cementation .

eusoilvoc:CementationNature a skos:Concept ;
    skos:broader eusoilvoc:Cementation ;
    skos:broaderTransitive eusoilvoc:Cementation,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:cementationNatureProperty ;
            rdf:value "The Cementation Nature identifies the specific type of material responsible for binding soil particles, such as carbonates, silica, or iron oxides. Understanding this helps in soil classification and predicting behavior under varying environmental conditions. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:cementationNatureProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "cementation nature"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Cementation .

eusoilvoc:ClayRatio a skos:Concept ;
    skos:broader eusoilvoc:SoilStructureIndirectIndex ;
    skos:broaderTransitive eusoilvoc:SoilIndicators,
        eusoilvoc:SoilStructureIndex,
        eusoilvoc:SoilStructureIndirectIndex ;
    skos:exactMatch spp:ClayRatio ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "clay ratio"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilStructureIndirectIndex .

eusoilvoc:CoatingAbundance a skos:Concept ;
    skos:broader eusoilvoc:SoilCoating ;
    skos:broaderTransitive eusoilvoc:SoilCoating,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:coatingAbundanceProperty ;
            rdf:value "The Coating Abundance evaluates the quantity of coatings on soil particles, such as organic matter, clay, or iron oxides. Coatings influence soil color, nutrient availability, and water movement. The abundance is typically classified as few, common, or many. Source: Soil Survey Staff (2014). Keys to Soil Taxonomy."@en ] ;
    skos:exactMatch glosis_lh:coatingAbundanceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "coating abundance"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilCoating .

eusoilvoc:CoatingContrast a skos:Concept ;
    skos:broader eusoilvoc:SoilCoating ;
    skos:broaderTransitive eusoilvoc:SoilCoating,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:coatingContrastProperty ;
            rdf:value "The Coating Contrast assesses the visual distinction between coatings on soil particles and the underlying material. High contrast indicates significant differences in composition or color, providing clues about soil processes like illuviation or biological activity. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:coatingContrastProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "coating contrast"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilCoating .

eusoilvoc:CoatingForms a skos:Concept ;
    skos:altLabel "coating form"@en ;
    skos:broader eusoilvoc:SoilCoating ;
    skos:broaderTransitive eusoilvoc:SoilCoating,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:coatingFormProperty ;
            rdf:value "The Coating Form describes the shape and distribution of coatings on soil particles, such as patchy, continuous, or layered. These forms are indicative of soil genesis and chemical weathering processes. Source: Soil Science Society of America (SSSA) Glossary."@en ] ;
    skos:exactMatch glosis_lh:coatingFormProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "coating forms"@en ;
