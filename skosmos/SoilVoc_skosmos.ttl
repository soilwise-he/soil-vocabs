eusoilvoc:NitrogenTotal a skos:Concept,
        sosa:ObservableProperty ;
    skos:broader eusoilvoc:Nitrogen ;
    skos:broaderTransitive eusoilvoc:Macronutrients,
        eusoilvoc:Nitrogen,
