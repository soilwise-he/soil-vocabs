eusoilvoc:BiologicalAbundance a skos:Concept ;
    skos:broader eusoilvoc:SoilBiologicalProperties ;
    skos:broaderTransitive eusoilvoc:SoilBiologicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:biologicalAbundanceProperty ;
            rdf:value "The Biological Abundance evaluates the presence and quantity of soil organisms, such as microbes, insects, and earthworms. This property reflects soil health, nutrient cycling, and organic matter decomposition, which are vital for maintaining soil fertility. Source: Lavelle, P., & Spain, A.V. (2001). Soil Ecology."@en ] ;
    skos:exactMatch glosis_lh:biologicalAbundanceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "biological abundance"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilBiologicalProperties .

eusoilvoc:BiologicalFeatures a skos:Concept ;
    skos:altLabel "biological feature"@en ;
    skos:broader eusoilvoc:SoilBiologicalProperties ;
    skos:broaderTransitive eusoilvoc:SoilBiologicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:biologicalFeaturesProperty ;
            rdf:value "The Biological Features examines qualitative aspects of soil biological activity, including the types of organisms present, their diversity, and their roles in soil ecosystems. It encompasses processes like nitrogen fixation, organic matter decomposition, and bioturbation. Source: Soil Science Society of America (SSSA) Glossary."@en ] ;
    skos:exactMatch glosis_lh:biologicalFeaturesProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "biological features"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilBiologicalProperties .

