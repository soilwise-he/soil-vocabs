eusoilvoc:PoreAbundance a skos:Concept ;
    skos:altLabel "pores abundance"@en ;
    skos:broader eusoilvoc:SoilPores ;
    skos:broaderTransitive eusoilvoc:SoilPores,
        eusoilvoc:SoilSubstance ;
    skos:definition [ dcterms:source glosis_lh:poresAbundanceProperty ;
            rdf:value "The Pores Abundance describes the quantity of soil pores, ranging from few to many. It influences water infiltration, root growth, and soil aeration. Pore abundance is crucial for assessing soil health and productivity. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:poresAbundanceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "pore abundance"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilPores .

