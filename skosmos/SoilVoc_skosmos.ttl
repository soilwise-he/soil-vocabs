    skos:broader eusoilvoc:NonsoilIndicators ;
    skos:broaderTransitive eusoilvoc:NonsoilIndicators,
        eusoilvoc:SoilIndicators ;
    skos:definition [ dcterms:source agrovoc:c_2594 ;
            rdf:value "All factors conditioning structure and form of life within a defined space, both physical and biological."@en ] ;
    skos:exactMatch agrovoc:c_2594,
        she:EnvironmentalFactors ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "environmental factors"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:NonsoilIndicators .

eusoilvoc:FloodDuration a skos:Concept ;
    skos:broader eusoilvoc:Floods ;
    skos:broaderTransitive eusoilvoc:Floods,
        eusoilvoc:Inundation,
        eusoilvoc:PlanetaryPhenomena ;
    skos:definition [ dcterms:source glosis_sp:floodDurationProperty ;
            rdf:value "Flood Duration refers to the length of time during which an area is inundated by floodwaters. The duration of flooding can significantly affect soil structure, nutrient availability, and plant growth, especially in flood-prone regions. Source: USGS, 'Floodplain Management'"@en ] ;
    skos:exactMatch glosis_sp:floodDurationProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "flood duration"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Floods .

eusoilvoc:FloodFrequency a skos:Concept ;
    skos:broader eusoilvoc:Floods ;
    skos:broaderTransitive eusoilvoc:Floods,
        eusoilvoc:Inundation,
        eusoilvoc:PlanetaryPhenomena ;
    skos:definition [ dcterms:source glosis_sp:floodFrequencyProperty ;
            rdf:value "Flood Frequency refers to how often flooding occurs in a particular area, typically expressed in terms of recurrence intervals (e.g., once every 10 years). This property is vital for assessing flood risk, soil erosion, and the potential for soil nutrient loss due to repeated flooding events. Source: USGS, 'Floodplain Management'"@en ] ;
    skos:exactMatch glosis_sp:floodFrequencyProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "flood frequency"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Floods .

eusoilvoc:Fog a skos:Concept ;
    skos:broader eusoilvoc:Precipitation ;
    skos:broaderTransitive eusoilvoc:PlanetaryPhenomena,
        eusoilvoc:Precipitation,
        eusoilvoc:WaterInterchange ;
    skos:definition [ dcterms:source agrovoc:c_3007 ;
            rdf:value "Fog is a visible aerosol consisting of tiny water droplets or ice crystals suspended in the air at or near the Earth's surface."@en ] ;
    skos:exactMatch agrovoc:c_3007,
        spp:Fog,
        gemet:3347 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "fog"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Precipitation .

eusoilvoc:FragmentCover a skos:Concept ;
    skos:broader eusoilvoc:Fragments ;
    skos:broaderTransitive eusoilvoc:Fragments,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_cm:fragmentCoverProperty ;
            rdf:value "The Fragment Cover describes the proportion of the soil surface covered by coarse fragments such as rocks, stones, or other large particles. This property is important because a high fragment cover can reduce soil erosion but may also interfere with water infiltration and root growth. Fragment cover is often used as an indicator of soil stability and erosion potential. Source: FAO (2006). Guidelines for Soil Description (4th ed.). Food and Agriculture Organization of the United Nations."@en ] ;
    skos:exactMatch glosis_cm:fragmentCoverProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "fragment cover"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Fragments .

eusoilvoc:FragmentSize a skos:Concept ;
    skos:broader eusoilvoc:Fragments ;
    skos:broaderTransitive eusoilvoc:Fragments,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_cm:fragmentsSizeProperty ;
            rdf:value "The Fragment Size refers to the dimensions of rock or mineral fragments present in the soil. These fragments are categorized based on their size, ranging from small gravel particles to larger stones and boulders. Larger fragments tend to reduce soil fertility, inhibit root growth, and decrease water retention. Smaller fragments, in contrast, contribute to soil texture and permeability. Source: Soil Science Society of America. (2008). Soil Science Glossary. Soil Science Society of America."@en ] ;
    skos:exactMatch glosis_cm:fragmentsSizeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "fragment size"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Fragments .

eusoilvoc:FriableConsistence a skos:Concept ;
    skos:broader eusoilvoc:SoilConsistence ;
    skos:broaderTransitive eusoilvoc:SoilConsistence,
