    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilOrganicMatter,
        eusoilvoc:SoilTotalCarbon .

eusoilvoc:TotalCarbonateEquivalent a skos:Concept,
        sosa:ObservableProperty ;
    skos:broader eusoilvoc:Carbonate ;
    skos:broaderTransitive eusoilvoc:Carbonate,
        eusoilvoc:SoilChemicalProperties,
