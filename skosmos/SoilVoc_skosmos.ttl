    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilErodibilityIndex .

eusoilvoc:Silt a skos:Concept ;
    skos:broader eusoilvoc:SoilPrimaryParticles ;
    skos:broaderTransitive eusoilvoc:SoilComponents,
        eusoilvoc:SoilParticles,
        eusoilvoc:SoilPrimaryParticles,
        eusoilvoc:SoilSubstance ;
    skos:definition [ dcterms:source agrovoc:c_331558 ;
            rdf:value "Soil particles between 0.002 mm and 0.05 mm (in some countries 0.06 mm is the upper size limit), with high or medium-high specific area influencing stability of soil structure; also used as a texture class name for medium and medium-fine soil materials."@en ] ;
