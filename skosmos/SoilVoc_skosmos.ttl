eusoilvoc:WeatheringFragments a skos:Concept ;
    skos:altLabel "weathering fragment"@en ;
    skos:broader eusoilvoc:Fragments ;
    skos:broaderTransitive eusoilvoc:Fragments,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_cm:weatheringFragmentsProperty ;
            rdf:value "The Weathering Fragment refers to soil particles or rock fragments that have been broken down through physical, chemical, or biological weathering. These fragments play a role in soil texture, structure, and nutrient availability. The degree of weathering can indicate the age and stability of the soil’s mineral content. Source: Brady, N. C., & Weil, R. R. (2008). The Nature and Properties of Soils (14th ed.). Pearson Prentice Hall."@en ] ;
    skos:exactMatch glosis_cm:weatheringFragmentsProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "weathering fragments"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Fragments .

eusoilvoc:WetPlasticity a skos:Concept ;
    skos:broader eusoilvoc:SoilPlasticity ;
    skos:broaderTransitive eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilPlasticity,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:wetPlasticityProperty ;
            rdf:value "The Wet Plasticity measures the soil’s ability to deform under pressure when saturated. Wet plasticity is influenced by clay mineralogy and is important for understanding soil behavior under wet conditions. Source: Hillel, D. (2004). Introduction to Environmental Soil Physics."@en ] ;
    skos:exactMatch glosis_lh:wetPlasticityProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "wet plasticity"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilPlasticity .

