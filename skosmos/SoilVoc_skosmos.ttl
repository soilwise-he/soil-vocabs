eusoilvoc:CopperTotalElements a skos:Concept,
        sosa:ObservableProperty ;
    skos:broader eusoilvoc:Copper ;
    skos:broaderTransitive eusoilvoc:Copper,
        eusoilvoc:Micronutrients,
        eusoilvoc:SoilChemicalProperties,
        eusoilvoc:SoilNutrients,
        eusoilvoc:SoilProperties,
        eusoilvoc:SoilSubstance ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Coptot ;
            rdf:value "Total copper comprises all soil copper, including bound and free forms. Copper is vital for plant enzyme activation and metabolic processes. Deficiencies can lead to reduced growth and yields, while excess copper may inhibit root development. Source: Soil Science Society of America."@en ] ;
    skos:exactMatch glosis_cl:physioChemicalPropertyCode-Coptot ;
