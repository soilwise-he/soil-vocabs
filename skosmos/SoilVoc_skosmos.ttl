        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:mineralConcHardnessProperty ;
            rdf:value "The Mineral Concentration Hardness assesses the physical hardness of mineral deposits in soil. Hardness influences soil strength and resistance to erosion or mechanical disruption. Source: Sparks, D.L. (2003). Environmental Soil Chemistry."@en ] ;
    skos:exactMatch glosis_lh:mineralConcHardnessProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mineral conc hardness"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:MineralConcentration .

eusoilvoc:MineralConcKind a skos:Concept ;
    skos:broader eusoilvoc:MineralConcentration ;
    skos:broaderTransitive eusoilvoc:MineralConcentration,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:mineralConcKindProperty ;
            rdf:value "The Mineral Concentration Kind identifies the specific type of mineral concentrations found in soil, such as gypsum, calcite, or hematite. This classification aids in understanding soil genesis and chemistry. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:mineralConcKindProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mineral conc kind"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:MineralConcentration .

eusoilvoc:MineralConcNature a skos:Concept ;
    skos:broader eusoilvoc:MineralConcentration ;
    skos:broaderTransitive eusoilvoc:MineralConcentration,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:mineralConcNatureProperty ;
            rdf:value "The Mineral Concentration Nature examines the origin and composition of concentrated minerals in soil. It provides clues about weathering, leaching, and other pedogenic processes. Source: Soil Survey Staff (2014). Keys to Soil Taxonomy."@en ] ;
    skos:exactMatch glosis_lh:mineralConcNatureProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mineral conc nature"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:MineralConcentration .

eusoilvoc:MineralConcShape a skos:Concept ;
    skos:broader eusoilvoc:MineralConcentration ;
    skos:broaderTransitive eusoilvoc:MineralConcentration,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:mineralConcShapeProperty ;
            rdf:value "The Mineral Concentration Shape describes the physical shape of mineral accumulations, such as rounded, angular, or irregular. These shapes help infer soil formation processes and transport history. Source: Brady, N.C., & Weil, R.R. (2008). The Nature and Properties of Soils."@en ] ;
    skos:exactMatch glosis_lh:mineralConcShapeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mineral conc shape"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:MineralConcentration .

eusoilvoc:MineralConcSize a skos:Concept ;
    skos:broader eusoilvoc:MineralConcentration ;
    skos:broaderTransitive eusoilvoc:MineralConcentration,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:mineralConcSizeProperty ;
            rdf:value "The Mineral Concentration Size measures the dimensions of concentrated mineral deposits in soil, typically expressed in millimeters. Size categories range from small grains to large nodules or concretions. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:mineralConcSizeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mineral conc size"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:MineralConcentration .

eusoilvoc:MineralConcVolume a skos:Concept ;
    skos:broader eusoilvoc:MineralConcentration ;
    skos:broaderTransitive eusoilvoc:MineralConcentration,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:mineralConcVolumeProperty ;
            rdf:value "The Mineral Concentration Volume quantifies the proportion of soil volume occupied by mineral concentrations. It is used to assess the impact of these materials on soil structure and permeability. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:mineralConcVolumeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mineral conc volume"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:MineralConcentration .

eusoilvoc:MineralContents a skos:Concept ;
    skos:altLabel "mineral content"@en ;
    skos:broader eusoilvoc:MineralParticles ;
    skos:broaderTransitive eusoilvoc:MineralParticles,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:mineralContentProperty ;
            rdf:value "The Mineral Content evaluates the overall abundance of mineral particles in soil, including sand, silt, and clay fractions. It provides essential information about soil texture, fertility, and parent material. Source: Hillel, D. (2004). Introduction to Environmental Soil Physics."@en ] ;
    skos:exactMatch glosis_lh:mineralContentProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mineral contents"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:MineralParticles .

eusoilvoc:MineralFragments a skos:Concept ;
    skos:altLabel "mineral fragment"@en ;
    skos:broader eusoilvoc:MineralParticles ;
    skos:broaderTransitive eusoilvoc:MineralParticles,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:mineralFragmentsProperty ;
            rdf:value "The Mineral Fragments refers to the presence and characteristics of coarse mineral particles (e.g., gravel, pebbles, stones) in the soil. These fragments influence soil drainage, root penetration, and overall physical structure. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:mineralFragmentsProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mineral fragments"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:MineralParticles .

