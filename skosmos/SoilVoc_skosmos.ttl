    skos:exactMatch spp:CriticalSoilOrganicMatterContent ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "critical soil organic matter contents"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilStructureIndirectIndex .

eusoilvoc:DispersionRatio a skos:Concept ;
    skos:broader eusoilvoc:SoilStructureIndirectIndex ;
