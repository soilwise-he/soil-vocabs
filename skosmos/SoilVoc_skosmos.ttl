eusoilvoc:CationExchangeCapacitySoil a skos:Concept,
        sosa:ObservableProperty ;
    skos:broader eusoilvoc:CationExchangeCapacity ;
    skos:broaderTransitive eusoilvoc:CationExchangeCapacity,
        eusoilvoc:SoilChemicalCapacity,
        eusoilvoc:SoilChemicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-CEC ;
            rdf:value "CEC measures the soil’s ability to hold and exchange positively charged ions (cations). It is a critical indicator of soil fertility, as higher CEC values imply greater capacity to retain essential nutrients like calcium, magnesium, and potassium. Clayey and organic-rich soils typically exhibit higher CEC. Source: Soil Science Society of America."@en ] ;
    skos:exactMatch glosis_cl:physioChemicalPropertyCode-CEC ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "cation exchange capacity soil"@en ;
    sosa:hasProcedure eusoilvoc:cationExchangeCapacitySoilProcedure-CEC_ph-unkn-cacl2,
        eusoilvoc:cationExchangeCapacitySoilProcedure-CEC_ph-unkn-lioac,
        eusoilvoc:cationExchangeCapacitySoilProcedure-CEC_ph-unkn-m3,
        eusoilvoc:cationExchangeCapacitySoilProcedure-CEC_ph0-ag-thioura,
        eusoilvoc:cationExchangeCapacitySoilProcedure-CEC_ph0-bacl2,
        eusoilvoc:cationExchangeCapacitySoilProcedure-CEC_ph0-cohex,
        eusoilvoc:cationExchangeCapacitySoilProcedure-CEC_ph0-kcl,
        eusoilvoc:cationExchangeCapacitySoilProcedure-CEC_ph0-nh4cl,
