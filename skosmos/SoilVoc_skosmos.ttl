    skos:broader eusoilvoc:LandCover ;
    skos:broaderTransitive eusoilvoc:LandCover ;
    skos:exactMatch spp:GroundCover,
        inrae:c_3684 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "ground cover"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:LandCover .

eusoilvoc:HumanInfluenceClass a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:broaderTransitive eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_sp:humanInfluenceClassProperty ;
            rdf:value "Human Influence Class classifies the extent of human impact on a landscape or ecosystem, ranging from minimal disturbance to high levels of modification. This classification helps in understanding the effects of urbanization, agriculture, or industrial activity on soil properties and ecosystem functions. Source: FAO, 'Land Degradation Assessment in Drylands'"@en ] ;
    skos:exactMatch glosis_sp:humanInfluenceClassProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "human influence class"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilDescription .

eusoilvoc:KoeppenClass a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:broaderTransitive eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_sp:koeppenClassProperty ;
            rdf:value "Koeppen Class refers to the classification of climate zones based on temperature and precipitation patterns, as defined by the Köppen climate classification system. This classification directly influences soil temperature, moisture content, and vegetation types, which in turn affect soil formation and properties. Source: Köppen, W., 'Geiger's Climate Maps'"@en ] ;
    skos:exactMatch glosis_sp:koeppenClassProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "koeppen class"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilDescription .

eusoilvoc:LandUseClass a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:broaderTransitive eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_sp:landUseClassProperty ;
            rdf:value "Land Use Class refers to the classification of land based on its primary use, such as agricultural, industrial, urban, or natural areas. This property helps assess the impact of land management practices on soil quality, including erosion risks, compaction, and fertility, and is critical for sustainable land-use planning. Source: FAO, 'Land Use and Land Cover Classification'"@en ] ;
    skos:exactMatch glosis_sp:landUseClassProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "land use class"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilDescription .

eusoilvoc:LandformComplex a skos:Concept ;
    skos:broader eusoilvoc:Physiography ;
    skos:broaderTransitive eusoilvoc:Physiography ;
    skos:definition [ dcterms:source glosis_sp:landformComplexProperty ;
            rdf:value "Landform Complex describes a region with multiple interrelated landforms such as ridges, valleys, and hills. This property is essential for understanding how diverse landforms within a landscape influence soil distribution, water flow, and erosion patterns, ultimately affecting soil management strategies. Source: FAO, 'Soil Formation and Classification'"@en ] ;
    skos:exactMatch glosis_sp:landformComplexProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "landform complex"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Physiography .

eusoilvoc:MajorLandForms a skos:Concept ;
    skos:altLabel "major land form"@en ;
    skos:broader eusoilvoc:Physiography ;
    skos:broaderTransitive eusoilvoc:Physiography ;
    skos:definition [ dcterms:source glosis_sp:majorLandFormProperty ;
            rdf:value "Major Land Form refers to the significant physical features of the land, such as mountains, valleys, and plateaus, that influence soil development and landscape processes. These landforms shape the flow of water, sediment transport, and nutrient cycling, directly affecting the types of soils that form in different regions. Source: FAO, 'World Soil Resources Report'"@en ] ;
    skos:exactMatch glosis_sp:majorLandFormProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "major land forms"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Physiography .

eusoilvoc:MulchFarming a skos:Concept ;
    skos:broader eusoilvoc:SoilManagement ;
    skos:broaderTransitive eusoilvoc:SoilManagement ;
    skos:exactMatch spp:MulchFarming ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mulch farming"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilManagement .

eusoilvoc:Mulching a skos:Concept ;
    skos:broader eusoilvoc:SoilManagement ;
    skos:broaderTransitive eusoilvoc:SoilManagement ;
    skos:definition [ dcterms:source agrovoc:c_4978 ;
            rdf:value "Mulching is a very simple and beneficial practice where organic material, such as crop residues and weeds, or inorganic material, like plastic sheets, is spread over the soil surface."@en ] ;
    skos:exactMatch agrovoc:c_4978,
        spp:Mulching,
        inrae:c_1940 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mulching"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilManagement .

eusoilvoc:NoTill a skos:Concept ;
