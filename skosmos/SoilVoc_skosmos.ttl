eusoilvoc:SlopeForms a skos:Concept ;
    skos:altLabel "slope form"@en ;
    skos:broader eusoilvoc:Slope ;
    skos:broaderTransitive eusoilvoc:Physiography,
        eusoilvoc:Slope ;
    skos:definition [ dcterms:source glosis_sp:slopeFormProperty ;
            rdf:value "Slope Form describes the shape or curvature of a slope, including its concave, convex, or straight profile. Slope form affects water runoff, erosion rates, and soil accumulation, influencing both the fertility and stability of the soil in hilly or mountainous regions. Source: FAO, 'Soil and Water Conservation'"@en ] ;
    skos:exactMatch glosis_sp:slopeFormProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "slope forms"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Slope .

eusoilvoc:SlopePathways a skos:Concept ;
    skos:altLabel "slope pathway"@en ;
    skos:broader eusoilvoc:Slope ;
    skos:broaderTransitive eusoilvoc:Physiography,
        eusoilvoc:Slope ;
    skos:definition [ dcterms:source glosis_sp:slopePathwaysProperty ;
            rdf:value "Slope Pathways identifies the natural flow paths of water, sediment, or other materials across a slope. These pathways, often defined by the topography, influence how water moves, erodes soil, and accumulates nutrients or contaminants. Understanding these pathways is critical for effective erosion control and water management in sloped areas. Source: FAO, 'Soil Erosion and Conservation'"@en ] ;
    skos:exactMatch glosis_sp:slopePathwaysProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "slope pathways"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Slope .

