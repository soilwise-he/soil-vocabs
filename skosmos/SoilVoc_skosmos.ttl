eusoilvoc:Cementation a skos:Concept ;
    skos:broader eusoilvoc:SoilPhysicalProperties ;
    skos:broaderTransitive eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source agrovoc:c_88254a16 ;
            rdf:value "During the process of compaction the minerals in the rock are dissolving. These dissolved minerals fill in the spaces between sediment particles. Cementation is the process of sediments being glued tightly together."@en ] ;
    skos:exactMatch agrovoc:c_88254a16 ;
