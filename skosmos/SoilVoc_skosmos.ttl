eusoilvoc:BleachedSand a skos:Concept ;
    skos:broader eusoilvoc:Sand ;
    skos:broaderTransitive eusoilvoc:Sand,
        eusoilvoc:SoilComponents,
        eusoilvoc:SoilParticles,
        eusoilvoc:SoilPrimaryParticles,
        eusoilvoc:SoilSubstance ;
    skos:definition [ dcterms:source glosis_cm:bleachedSandProperty ;
            rdf:value "The Bleached Sand refers to the physical characteristic of sandy soil that has undergone a bleaching process due to leaching, where minerals such as iron and other elements have been removed by water. This process often occurs in areas with high rainfall, leading to a soil that appears lighter in color. Bleached sand typically indicates low fertility and poor nutrient-holding capacity due to the lack of iron and other nutrients that are washed away. Source: Brady, N. C., & Weil, R. R. (2008). The Nature and Properties of Soils (14th ed.). Pearson Prentice Hall."@en ] ;
    skos:exactMatch glosis_cm:bleachedSandProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "bleached sand"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:Sand .

