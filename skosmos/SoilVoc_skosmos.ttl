        eusoilvoc:acidityExchangeableProcedure-ExchAcid_ph0-nh4cl,
        eusoilvoc:acidityExchangeableProcedure-ExchAcid_ph0-unkn,
        eusoilvoc:acidityExchangeableProcedure-ExchAcid_ph7-caoac,
        eusoilvoc:acidityExchangeableProcedure-ExchAcid_ph7-unkn,
        eusoilvoc:acidityExchangeableProcedure-ExchAcid_ph8-bacl2tea,
        eusoilvoc:acidityExchangeableProcedure-ExchAcid_ph8-unkn ;
