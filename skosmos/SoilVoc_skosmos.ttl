eusoilvoc:Gypsum a skos:Concept,
        sosa:ObservableProperty ;
    agrontology:isComponentOf eusoilvoc:Rock ;
    skos:broader eusoilvoc:SoilPhysicalProperties ;
    skos:broaderTransitive eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source agrovoc:c_3453 ;
            rdf:value "Gypsum is a soft sulfate mineral composed of calcium sulfate dihydrate, with the chemical formula CaSO4·2H2O. It is widely mined and is used as a fertilizer and as the main constituent in many forms of plaster, blackboard/sidewalk chalk, and drywall."@en ],
        [ dcterms:source glosis_cl:physioChemicalPropertyCode-Gyp ;
            rdf:value "The gypsum content, expressed as weight, refers to the soil’s calcium sulfate levels. Gypsum improves soil structure, alleviates sodicity, and enhances water infiltration. It is commonly applied to saline-sodic soils for reclamation. Source: FAO Soil Bulletin."@en ] ;
    skos:exactMatch agrovoc:c_3453,
        glosis_cl:physioChemicalPropertyCode-Gyp,
        gemet:3806 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:narrower eusoilvoc:GypsumContents,
        eusoilvoc:GypsumForms,
        eusoilvoc:GypsumWeight ;
    skos:narrowerTransitive eusoilvoc:GypsumContents,
        eusoilvoc:GypsumForms,
        eusoilvoc:GypsumWeight ;
    skos:prefLabel "gypsum"@en ;
    sosa:hasProcedure eusoilvoc:gypsumProcedure-CaSO4_gy01,
        eusoilvoc:gypsumProcedure-CaSO4_gy02,
        eusoilvoc:gypsumProcedure-CaSO4_gy03,
        eusoilvoc:gypsumProcedure-CaSO4_gy04,
        eusoilvoc:gypsumProcedure-CaSO4_gy05,
        eusoilvoc:gypsumProcedure-CaSO4_gy06,
        eusoilvoc:gypsumProcedure-CaSO4_gy07 ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilPhysicalProperties .

