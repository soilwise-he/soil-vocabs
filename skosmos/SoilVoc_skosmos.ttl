eusoilvoc:SoilWaterPotential a skos:Concept ;
    skos:broader eusoilvoc:SoilWaterPhysicalProperties ;
    skos:broaderTransitive eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties,
        eusoilvoc:SoilWaterPhysicalProperties ;
    skos:definition [ dcterms:source agrovoc:c_7210 ;
            rdf:value "Total soil water potential is defined as the amount of work per unit quantity of pure water that must be done by external forces to transfer reversibly and isothermally an infinitesimal amount of water from the standard state to the soil at the point under consideration."@en ] ;
    skos:exactMatch agrovoc:c_7210,
