    skos:exactMatch spp:SoilSedimentation ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil sedimentation"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilPhysicalProcesses .

