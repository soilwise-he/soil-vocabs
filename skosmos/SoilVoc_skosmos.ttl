    skos:definition [ dcterms:source agrovoc:c_35388 ;
            rdf:value "Portion of rainfall, melted snow or irrigation water that flows across the grounds surface and is eventually returned to streams. Run-off can pick up pollutants from air or land and carry them to receiving waters."@en ] ;
