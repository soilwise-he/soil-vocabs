eusoilvoc:SoilBiologicalProperties a skos:Concept ;
    skos:altLabel "soil biological property"@en ;
    skos:broader eusoilvoc:SoilProperties ;
    skos:broaderTransitive eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source <https://www.fao.org/soils-portal/data-hub/soil-properties/biological-properties/en/> ;
            rdf:value "This concerns soil properties related to the microbial and faunal activity in soil. These organisms include earthworms, nematodes, protozoa, fungi, bacteria and different arthropods. Soil biology plays a vital role in determining many soil characteristics, yet, being a relatively new science, much remains unknown about soil biology and about how the nature of soil is affected."@en ],
        [ dcterms:source <https://www.sciencedirect.com/topics/agricultural-and-biological-sciences/soil-biological-properties> ;
            rdf:value "Soil biological properties refer to the biological components in the soil, including microbial life such as bacterial and fungal colonies, which are affected by changes in soil chemical and physical properties, such as acidity and organic matter content. These properties can be assessed through indicators like enzyme activities, which vary with management practices and land use."@en ] ;
    skos:exactMatch she:SoilBiologicalProperties ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:narrower eusoilvoc:BiologicalAbundance,
        eusoilvoc:BiologicalFeatures,
        eusoilvoc:SoilBiota ;
    skos:narrowerTransitive eusoilvoc:BiologicalAbundance,
        eusoilvoc:BiologicalFeatures,
        eusoilvoc:Biomass,
        eusoilvoc:RootBiomass,
        eusoilvoc:SoilBiota,
        eusoilvoc:SoilMicrobialBiomass ;
    skos:prefLabel "soil biological properties"@en ;
    skos:related eusoilvoc:SoilQuality ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilProperties .

