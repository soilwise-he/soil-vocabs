    skos:definition [ dcterms:source agrovoc:c_0c184d6f ;
            rdf:value "Soil depth defines the root space and the volume of soil from where the plants fulfil their water and nutrient demands."@en ],
        [ dcterms:source glosis_cm:soilDepthProperty ;
            rdf:value "The Soil Depth measures the vertical distance from the soil surface to an impenetrable layer, such as bedrock or a hardpan. Soil depth is a crucial factor influencing root development, water storage, and plant growth. Shallow soils may limit root growth, while deep soils can support more extensive root systems. Source: Brady, N. C., & Weil, R. R. (2008). The Nature and Properties of Soils (14th ed.). Pearson Prentice Hall."@en ] ;
    skos:exactMatch agrovoc:c_0c184d6f,
        spp:SoilDepth,
        glosis_cm:soilDepthProperty,
        she:SoilDepth ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:narrower eusoilvoc:SoilDepthBedrock,
        eusoilvoc:SoilDepthRootable,
        eusoilvoc:SoilDepthSampled ;
    skos:narrowerTransitive eusoilvoc:SoilDepthBedrock,
        eusoilvoc:SoilDepthRootable,
        eusoilvoc:SoilDepthSampled ;
    skos:prefLabel "soil depth"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilSpatialProperties .

