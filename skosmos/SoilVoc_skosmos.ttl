    skos:exactMatch spp:SaltSieving ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "salt sieving"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilPhenomena .

eusoilvoc:Season a skos:Concept ;
    skos:broader eusoilvoc:PlanetaryPhenomena ;
    skos:broaderTransitive eusoilvoc:PlanetaryPhenomena ;
    skos:exactMatch spp:Season,
        inrae:c_11384,
        gemet:7529 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "season"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:PlanetaryPhenomena .

eusoilvoc:SeedbedPreparation a skos:Concept ;
    skos:broader eusoilvoc:SoilManagement ;
    skos:broaderTransitive eusoilvoc:SoilManagement ;
    skos:definition [ dcterms:source agrovoc:c_6943 ;
            rdf:value "Tillage carried out after primary tillage and at shallower depths, to provide additional soil pulverisation, crop chemical mixing, soil surface levelling, firming and weed control,"@en ] ;
    skos:exactMatch agrovoc:c_6943,
        spp:SeedbedPreparation ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "seedbed preparation"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilManagement .

eusoilvoc:SlopeGradientClass a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:broaderTransitive eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_sp:slopeGradientClassProperty ;
            rdf:value "Slope Gradient Class refers to the classification of slope steepness, such as flat, moderate, or steep, based on its angle. The gradient of a slope influences soil erosion rates, water drainage, and the suitability of land for agriculture, with steeper slopes typically being more prone to erosion. Source: USDA NRCS, 'Soil Erosion and Conservation'"@en ] ;
    skos:exactMatch glosis_sp:slopeGradientClassProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "slope gradient class"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilDescription .

eusoilvoc:SlopeOrientationClass a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:broaderTransitive eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_sp:slopeOrientationClassProperty ;
            rdf:value "Slope Orientation Class classifies the direction in which a slope faces (north, south, east, west) and can significantly affect local climate conditions, such as sunlight exposure, moisture, and temperature. For instance, south-facing slopes in the Northern Hemisphere receive more sunlight, influencing soil temperature, vegetation types, and soil moisture availability. Source: FAO, 'Soil and Water Conservation'"@en ] ;
    skos:exactMatch glosis_sp:slopeOrientationClassProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "slope orientation class"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilDescription .

eusoilvoc:SoilBiodiversityLoss a skos:Concept ;
    skos:broader eusoilvoc:SoilThreats ;
    skos:broaderTransitive eusoilvoc:SoilThreats ;
    skos:exactMatch she:SoilSoilBiodiversityLoss ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil biodiversity loss"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilThreats .

