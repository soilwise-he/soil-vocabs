eusoilvoc:StructureGrade a skos:Concept ;
    skos:broader eusoilvoc:SoilStructure ;
    skos:broaderTransitive eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties,
        eusoilvoc:SoilStructure ;
    skos:definition [ dcterms:source glosis_lh:structureGradeProperty ;
            rdf:value "The Structure Grade assesses the development and stability of soil aggregates, classified as weak, moderate, or strong. It reflects soil tilth, aeration, and resistance to erosion. Source: Soil Survey Staff (2014). Keys to Soil Taxonomy."@en ] ;
    skos:exactMatch glosis_lh:structureGradeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "structure grade"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilStructure .

eusoilvoc:StructureSize a skos:Concept ;
    skos:broader eusoilvoc:SoilStructure ;
    skos:broaderTransitive eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties,
        eusoilvoc:SoilStructure ;
    skos:definition [ dcterms:source glosis_lh:structureSizeProperty ;
            rdf:value "The Structure Size describes the dimensions of soil aggregates or structural units, such as granular, blocky, or platy. Structure size affects root penetration, water infiltration, and soil stability. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:structureSizeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "structure size"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilStructure .

