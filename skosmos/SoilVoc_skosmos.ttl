eusoilvoc:DryConsistency a skos:Concept ;
    skos:broader eusoilvoc:SoilConsistency ;
    skos:broaderTransitive eusoilvoc:SoilConsistency,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:dryConsistencyProperty ;
            rdf:value "The Dry Consistency is synonymous with the Consistence Dry Property, focusing on the soil's resistance to breaking apart or deforming when dry. It indicates the soil's mechanical strength and susceptibility to erosion. Source: Soil Survey Staff (2014). Keys to Soil Taxonomy."@en ] ;
    skos:exactMatch glosis_lh:dryConsistencyProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "dry consistency"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilConsistency .

