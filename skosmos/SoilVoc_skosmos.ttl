    skos:definition [ dcterms:source agrovoc:c_d79c08d8 ;
            rdf:value "Soil penetration resistance is a soil attribute that identifies areas with restrictions due to compaction, which results in mechanical impedance for root growth and reduced crop yield. It is an appropriate index to evaluate soil compaction problems, limiting plant root development."@en ] ;
