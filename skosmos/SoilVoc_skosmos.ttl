        eusoilvoc:SoilSubstance ;
    skos:definition [ dcterms:source agrovoc:c_7158 ;
            rdf:value "Soil air is the gaseous phase of the soil. Soil pores are filled with air and water, and there is a dynamic equilibrium between water and air content within a soil. The amount and composition of air in soil are dynamic and to a large degree are determined by water content and activity of soil organisms. The main constituents of soil air, as in the atmosphere, are nitrogen, oxygen, and carbon dioxide."@en ] ;
    skos:exactMatch agrovoc:c_7158,
        spp:SoilAir,
        gemet:7845 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil air"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilComponents,
        eusoilvoc:SoilGas .

