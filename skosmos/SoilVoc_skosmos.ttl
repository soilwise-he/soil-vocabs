eusoilvoc:SoilHydraulicConductivity a skos:Concept,
        sosa:ObservableProperty ;
    skos:broader eusoilvoc:SoilWaterPhysicalProperties,
        eusoilvoc:SoilWaterTransmissionIndex ;
    skos:broaderTransitive eusoilvoc:SoilIndicators,
        eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties,
        eusoilvoc:SoilStructureIndex,
        eusoilvoc:SoilWaterPhysicalProperties,
        eusoilvoc:SoilWaterTransmissionIndex ;
    skos:closeMatch agrovoc:c_25579 ;
    skos:definition [ dcterms:source agrovoc:c_25579 ;
            rdf:value "Hydraulic conductivity (K) defines the rate of movement of water through a porous medium such as a soil or aquifer."@en ],
        [ dcterms:source glosis_cl:physioChemicalPropertyCode-Hydcond ;
            rdf:value "Hydraulic conductivity refers to the rate at which water moves through soil pores under a unit hydraulic gradient. It reflects the soil's ability to transmit water, influenced by texture, structure, and porosity. Soils with high hydraulic conductivity, like sandy soils, allow rapid water movement, while clayey soils exhibit slower water flow. This property is critical for understanding water infiltration, drainage, and irrigation management. Source: Brady, N.C., & Weil, R.R. (2017). The Nature and Properties of Soils."@en ] ;
    skos:exactMatch spp:SoilHydraulicConductivity,
        inrae:c_13934,
        glosis_cl:physioChemicalPropertyCode-Hydcond ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:narrower eusoilvoc:SaturatedHydraulicConductivity,
        eusoilvoc:UnsaturatedHydraulicConductivity ;
    skos:narrowerTransitive eusoilvoc:SaturatedHydraulicConductivity,
        eusoilvoc:UnsaturatedHydraulicConductivity ;
    skos:prefLabel "soil hydraulic conductivity"@en ;
    sosa:hasProcedure eusoilvoc:hydraulicConductivityProcedure-KSat_calcul-ptf,
        eusoilvoc:hydraulicConductivityProcedure-KSat_calcul-ptf-genuchten,
        eusoilvoc:hydraulicConductivityProcedure-KSat_calcul-ptf-saxton,
        eusoilvoc:hydraulicConductivityProcedure-Ksat_bhole,
        eusoilvoc:hydraulicConductivityProcedure-Ksat_column,
