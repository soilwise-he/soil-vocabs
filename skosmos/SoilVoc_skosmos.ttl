        eusoilvoc:SoilSubstance ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Aciexc ;
            rdf:value "Exchangeable acidity represents the amount of hydrogen (H⁺) and aluminum (Al³⁺) ions adsorbed onto soil particles that can be exchanged with the soil solution. It is a key factor in determining soil liming requirements and improving nutrient availability in acidic soils. Source: Brady & Weil (2017)."@en ] ;
    skos:exactMatch glosis_cl:physioChemicalPropertyCode-Aciexc ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "acidity exchangeable"@en ;
