        eusoilvoc:SoilProperties,
        eusoilvoc:SoilWaterPhysicalProperties ;
    skos:definition [ dcterms:source glosis_lh:moistureContentProperty ;
            rdf:value "The Moisture Content measures the amount of water present in soil, expressed as a percentage of its dry weight. This property is critical for assessing soil water retention, irrigation needs, and plant-available water. Source: Hillel, D. (2004). Introduction to Environmental Soil Physics."@en ] ;
    skos:exactMatch spp:SoilMoistureContent,
        glosis_lh:moistureContentProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
