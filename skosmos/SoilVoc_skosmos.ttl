    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Caltot ;
            rdf:value "Total calcium in soil includes all forms, from exchangeable calcium to calcium in minerals. It is essential for plant cell wall structure, enzyme activation, and soil aggregation. Calcium levels influence soil pH and nutrient availability. Source: Havlin et al. (2014)."@en ] ;
