eusoilvoc:OxalateExtractableOpticalDensity a skos:Concept ;
    skos:broader eusoilvoc:SoilChemicalProperties ;
    skos:broaderTransitive eusoilvoc:SoilChemicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source glosis_lh:oxalateExtractableOpticalDensityProperty ;
            rdf:value "The Oxalate Extractable Optical Density measures the concentration of poorly crystalline forms of iron, aluminum, and organic matter in soil, often associated with volcanic soils. It is determined using ammonium oxalate extraction. Source: Sparks, D.L. (2003). Environmental Soil Chemistry."@en ] ;
    skos:exactMatch glosis_lh:oxalateExtractableOpticalDensityProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "oxalate extractable optical density"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilChemicalProperties .

eusoilvoc:ParentDeposition a skos:Concept ;
    skos:broader eusoilvoc:ParentMaterial ;
    skos:broaderTransitive eusoilvoc:Geology,
        eusoilvoc:ParentMaterial ;
    skos:definition [ dcterms:source glosis_sp:parentDepositionProperty ;
            rdf:value "Parent Deposition refers to the accumulation of materials, such as sediments or volcanic ash, that contribute to soil formation. These parent materials are deposited through natural processes such as erosion, weathering, or sediment transport, influencing soil texture, nutrient content, and water retention properties. Source: USDA NRCS, 'Soil Genesis and Classification'"@en ] ;
    skos:exactMatch glosis_sp:parentDepositionProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "parent deposition"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:ParentMaterial .

eusoilvoc:ParentLithology a skos:Concept ;
    skos:broader eusoilvoc:ParentMaterial ;
    skos:broaderTransitive eusoilvoc:Geology,
        eusoilvoc:ParentMaterial ;
    skos:definition [ dcterms:source glosis_sp:parentLithologyProperty ;
            rdf:value "Parent Lithology is the specific geological composition of the parent material (e.g., bedrock or sediment) from which the soil develops. The mineral content and texture of this material directly affect the physical and chemical properties of the soil, such as fertility, permeability, and soil depth. Source: USDA NRCS, 'Soil Genesis and Classification'"@en ] ;
    skos:exactMatch glosis_sp:parentLithologyProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "parent lithology"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:ParentMaterial .

eusoilvoc:ParentTextureUnconsolidated a skos:Concept ;
    skos:broader eusoilvoc:ParentMaterial ;
    skos:broaderTransitive eusoilvoc:Geology,
        eusoilvoc:ParentMaterial ;
    skos:definition [ dcterms:source glosis_sp:parentTextureUnconsolidatedProperty ;
            rdf:value "Parent Texture Unconsolidated refers to the texture of the unconsolidated parent material, such as loose sediments or debris, that has not been solidified into rock. This texture affects soil properties such as aeration, drainage, and root penetration, as well as its ability to retain nutrients. Source: USDA NRCS, 'Soil Genesis and Classification'"@en ] ;
    skos:exactMatch glosis_sp:parentTextureUnconsolidatedProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "parent texture unconsolidated"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:ParentMaterial .

