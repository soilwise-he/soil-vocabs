eusoilvoc:SoilTexture a skos:Concept ;
    skos:broader eusoilvoc:SoilPhysicalProperties ;
    skos:broaderTransitive eusoilvoc:SoilPhysicalProperties,
        eusoilvoc:SoilProperties ;
    skos:definition [ dcterms:source agrovoc:c_7199 ;
            rdf:value "The relative proportions of the various sized groups of individual soil grains in a mass of soil. Specifically, it refers to the proportions of clay, silt, and sand below 2 mm in size (fine earth fraction)."@en ],
        [ dcterms:source glosis_cm:textureProperty ;
            rdf:value "The Soil Texture refers to the relative proportions of sand, silt, and clay in a soil. It is a key indicator of the soil’s ability to retain moisture, drain water, and support root growth. Soils can be classified into textures such as sandy, loamy, or clayey, each with distinct characteristics affecting soil management. Source: Soil Science Society of America. (2008). Soil Science Glossary. Soil Science Society of America."@en ] ;
    skos:exactMatch agrovoc:c_7199,
        spp:SoilTexture,
        inrae:c_394,
        glosis_cm:textureProperty,
        gemet:7898,
        iso11074:3.476,
        she:SoilTexture ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:narrower eusoilvoc:SandyTexture ;
    skos:narrowerTransitive eusoilvoc:SandyTexture ;
    skos:prefLabel "soil texture"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilPhysicalProperties .

