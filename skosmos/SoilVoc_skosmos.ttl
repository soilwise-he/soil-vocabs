    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Irotot ;
            rdf:value "Total iron includes all iron forms in the soil, from soluble ferrous iron (Fe²⁺) to insoluble ferric iron (Fe³⁺). Iron is essential for plant chlorophyll synthesis and various enzymatic reactions. Deficiency, often seen in alkaline soils, results in chlorosis, while excessive iron can cause toxicity in acidic soils. Source: Soil Chemistry by Bohn et al."@en ] ;
    skos:exactMatch glosis_cl:physioChemicalPropertyCode-Irotot ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
