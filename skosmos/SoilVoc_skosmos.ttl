eusoilvoc:PesticideUse a skos:Concept ;
    skos:broader eusoilvoc:SoilManagement ;
    skos:broaderTransitive eusoilvoc:SoilManagement ;
    skos:exactMatch spp:PesticideUse ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "pesticide use"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilManagement .

eusoilvoc:PorosityClass a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:broaderTransitive eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_lh:porosityClassProperty ;
            rdf:value "The Porosity Class classifies soil by the proportion of pore spaces, typically expressed as a percentage. Classes include high, medium, or low porosity, influencing water and air movement in the soil. Source: Soil Science Society of America (SSSA) Glossary."@en ] ;
    skos:exactMatch glosis_lh:porosityClassProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "porosity class"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilDescription .

eusoilvoc:ProfileDescriptionStatus a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:broaderTransitive eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_pr:profileDescriptionStatusProperty ;
            rdf:value "The Profile Description Status indicates the level of detail and accuracy in documenting the features of a soil profile, including its horizons, texture, structure, and other observable characteristics. This property ensures that the soil profile description meets standards for completeness, enabling reliable classification and analysis. It is a critical aspect of soil studies, providing the basis for land-use planning, environmental assessment, and agricultural decision-making. Source: Schoeneberger, P.J., Wysocki, D.A., Benham, E.C., & Soil Survey Staff. (2012). Field Book for Describing and Sampling Soils. USDA-NRCS."@en ] ;
    skos:exactMatch glosis_pr:profileDescriptionStatusProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "profile description status"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilDescription .

eusoilvoc:ProvisioningServices a skos:Concept ;
    skos:altLabel "provisioning service"@en ;
    skos:broader eusoilvoc:EcosystemServices ;
    skos:broaderTransitive eusoilvoc:EcosystemServices ;
    skos:definition [ dcterms:source agrovoc:c_7e12eb3f ;
            rdf:value "Provisioning services: Ecosystem services that provide humans with material objects, such as food, feed, fibre or water."@en ] ;
    skos:exactMatch agrovoc:c_7e12eb3f,
        she:ProvisioningServices ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "provisioning services"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:EcosystemServices .

eusoilvoc:RegulatingServices a skos:Concept ;
    skos:altLabel "regulating service"@en ;
    skos:broader eusoilvoc:EcosystemServices ;
    skos:broaderTransitive eusoilvoc:EcosystemServices ;
    skos:definition [ dcterms:source agrovoc:c_eff3625d ;
            rdf:value "Regulation and maintenance services are ecosystem services that regulate biotic- or abiotic ecosystem components in a way that is beneficial for humans, such as climate regulation, pollination or disease control."@en ] ;
    skos:exactMatch agrovoc:c_eff3625d,
        she:RegulatingServices ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "regulating services"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:EcosystemServices .

