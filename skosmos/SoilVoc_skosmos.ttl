        eusoilvoc:SoilProperties,
        eusoilvoc:SoilSubstance ;
    skos:definition [ dcterms:source agrovoc:c_5804 ;
            rdf:value "Phosphorus, an essential mineral, is naturally present in many foods and available as a dietary supplement. Phosphorus is a component of bones, teeth, DNA, and RNA. In the form of phospholipids, phosphorus is also a component of cell membrane structure and of the body’s key energy source, adenosine triphosphate (ATP)."@en ] ;
    skos:exactMatch agrovoc:c_5804,
        inrae:c_15709,
        gemet:6196 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
