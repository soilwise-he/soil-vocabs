eusoilvoc:SoilSorption a skos:Concept ;
    skos:broader eusoilvoc:SoilChemicalProcesses ;
    skos:broaderTransitive eusoilvoc:SoilChemicalProcesses,
        eusoilvoc:SoilProcesses ;
    skos:definition [ dcterms:source agrovoc:c_15868 ;
            rdf:value "Selective process, which occurs on soil particles smaller than 0.002mm (<2µm); these small particles have colloidal properties, are able to hold and exchange ions, water or gases."@en ] ;
    skos:exactMatch agrovoc:c_15868,
        spp:SoilSorption,
        inrae:c_189 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil sorption"@en ;
    eusoilvoc:skosmosHierarchyParent eusoilvoc:SoilChemicalProcesses .

