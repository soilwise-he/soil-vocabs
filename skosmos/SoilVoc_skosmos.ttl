        eusoilvoc:SoilProperties,
        eusoilvoc:SoilSubstance ;
    skos:definition [ dcterms:source agrovoc:c_8517 ;
            rdf:value "A brittle bluish-white metallic element that becomes coated with a corrosion-resistant layer in moist air and occurs chiefly in sphalerite and smithsonite. It is a constituent of several alloys, especially brass and nickel-silver, and is used in die-casting, galvanizing metals, and in battery electrodes."@en ] ;
    skos:exactMatch agrovoc:c_8517,
        inrae:c_15783,
        gemet:9412,
        she:Zinc ;
