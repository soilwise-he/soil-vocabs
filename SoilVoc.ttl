eusoilvoc:SolubleSalts a skos:Concept ;
    skos:altLabel "soluble salt"@en ;
    skos:broader eusoilvoc:Salts,
        eusoilvoc:SoilSolutes ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Solsal ;
            schema:text "Soluble salts refer to dissolved salts in the soil solution, primarily composed of sodium, calcium, magnesium, chloride, and sulfate ions. Excessive soluble salts cause salinity, which can impair plant water uptake and lead to osmotic stress. EC testing helps monitor salinity levels for effective management. Source: Soil Science Society of America."@en ] ;
    skos:exactMatch glosis_cl:physioChemicalPropertyCode-Solsal ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:narrower eusoilvoc:SaltContents ;
    skos:prefLabel "soluble salts"@en ;
    sosa:hasProcedure eusoilvoc:solubleSaltsProcedure-SlbAn_calcul-unkn,
        eusoilvoc:solubleSaltsProcedure-SlbCat_calcul-unkn .

