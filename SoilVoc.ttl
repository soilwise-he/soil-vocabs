    skos:prefLabel "soil depositional crusts"@en .

soilvoc:SoilDepthBedrock a skos:Concept ;
    skos:broader soilvoc:SoilDepth ;
    skos:definition [ dcterms:source glosis_cm:soilDepthBedrockProperty ;
            schema:text "The Soil Depth Bedrock refers to the distance from the soil surface to the underlying bedrock layer. This measurement is important for understanding the soil's capacity to support plant growth, as soils with shallow bedrock tend to have limited rooting depth, affecting water retention and nutrient availability. Source: FAO (2006). Guidelines for Soil Description (4th ed.). Food and Agriculture Organization of the United Nations."@en ] ;
    skos:exactMatch glosis_cm:soilDepthBedrockProperty ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "soil depth bedrock"@en .

soilvoc:SoilDepthRootable a skos:Concept ;
    skos:broader soilvoc:SoilDepth ;
    skos:definition [ dcterms:source glosis_cm:soilDepthRootableProperty ;
            schema:text "The Soil Depth Rootable refers to the actual vertical depth of soil that can support plant roots, excluding any non-rootable layers such as bedrock or a water-impervious horizon. This depth is crucial for determining the suitability of land for agriculture and vegetation. Source: Soil Science Society of America. (2008). Soil Science Glossary. Soil Science Society of America."@en ] ;
    skos:exactMatch glosis_cm:soilDepthRootableProperty ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "soil depth rootable"@en .

soilvoc:SoilDepthRootableClass a skos:Concept ;
    skos:broader soilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_cm:soilDepthRootableClassProperty ;
            schema:text "The Soil Depth Rootable Class classifies soils based on the depth of the rootable zone, which excludes impenetrable layers such as bedrock or compacted horizons. Soils are typically classified as shallow, moderately deep, or deep, depending on the depth of the root zone, which directly affects plant growth. Source: FAO (2006). Guidelines for Soil Description (4th ed.). Food and Agriculture Organization of the United Nations."@en ] ;
    skos:exactMatch glosis_cm:soilDepthRootableClassProperty ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "soil depth rootable class"@en .

soilvoc:SoilDepthSampled a skos:Concept ;
    skos:broader soilvoc:SoilDepth ;
    skos:definition [ dcterms:source glosis_cm:soilDepthSampledProperty ;
            schema:text "The Soil Depth Sampled indicates the specific depth of the soil profile that has been sampled for analysis. This property is important for understanding the representativeness of the sample, as different soil horizons may vary significantly in properties such as texture, fertility, and moisture content. Source: Soil Science Society of America. (2008). Soil Science Glossary. Soil Science Society of America."@en ] ;
    skos:exactMatch glosis_cm:soilDepthSampledProperty ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "soil depth sampled"@en .

soilvoc:SoilDesiccation a skos:Concept ;
    skos:broader soilvoc:SoilDrying ;
    skos:exactMatch spp:SoilDesiccation ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "soil desiccation"@en .

