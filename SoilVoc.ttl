soilvoc:VegetationClass a skos:Concept ;
    skos:broader soilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_sp:vegetationClassProperty ;
            schema:text "Vegetation Class refers to the categorization of vegetation types based on species composition and structure, such as forests, grasslands, and wetlands. The class of vegetation affects soil fertility, microbial activity, and water retention, which in turn influences agricultural potential and ecosystem services. Source: FAO, 'Vegetation and Land Use in Arid Zones'"@en ] ;
    skos:exactMatch glosis_sp:vegetationClassProperty ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "vegetation class"@en .

soilvoc:VoidClassification a skos:Concept ;
    skos:altLabel "voids classification"@en ;
    skos:broader soilvoc:SoilVoids ;
    skos:definition [ dcterms:source glosis_lh:voidsClassificationProperty ;
            schema:text "The Voids Classification categorizes voids or pores in the soil based on size, shape, and arrangement. These voids are critical for water movement, air circulation, and root penetration. They are classified into macropores (large), mesopores (medium), and micropores (small). Source: Hillel, D. (2004). Introduction to Environmental Soil Physics."@en ] ;
    skos:exactMatch glosis_lh:voidsClassificationProperty ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "void classification"@en .

soilvoc:VoidDiameter a skos:Concept ;
    skos:altLabel "voids diameter"@en ;
    skos:broader soilvoc:SoilVoids ;
    skos:definition [ dcterms:source glosis_lh:voidsDiameterProperty ;
            schema:text "The Voids Diameter refers to the size of void spaces in soil, which can range from macro-voids (larger pores) to micro-voids (tiny pores). Voids diameter impacts soil aeration, water retention, and drainage. Source: Soil Science Society of America (SSSA) Glossary."@en ] ;
    skos:exactMatch glosis_lh:voidsDiameterProperty ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "void diameter"@en .

soilvoc:VoidRatio a skos:Concept ;
    skos:broader soilvoc:SoilPorosity ;
    skos:exactMatch spp:VoidRatio ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "void ratio"@en .

soilvoc:WaterPurification a skos:Concept ;
    skos:broader soilvoc:SoilFunctions ;
    skos:exactMatch agrovoc:c_34145,
        gemet:9210,
        she:WaterPurification ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "water purification"@en .

soilvoc:WaterRegulation a skos:Concept ;
    skos:broader soilvoc:SoilFunctions ;
    skos:exactMatch she:WaterRegulation ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "water regulation"@en .

soilvoc:WaterStorageCapacity a skos:Concept ;
    skos:broader soilvoc:SoilFunctionIndicators ;
    skos:exactMatch she:WaterStorageCapacity ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "water storage capacity"@en .

soilvoc:WeatherCurrent a skos:Concept ;
    skos:broader soilvoc:Weather ;
    skos:definition [ dcterms:source glosis_sp:weatherConditionsCurrentProperty ;
            schema:text "Weather Conditions Current describes the current atmospheric conditions in a specific location, including factors like temperature, humidity, wind speed, and precipitation. These conditions directly affect soil moisture, temperature, and erosion rates, influencing soil fertility and the ability to support plant growth. Source: USGS, 'Meteorological and Soil Interactions'"@en ] ;
    skos:exactMatch glosis_sp:weatherConditionsCurrentProperty ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "weather current"@en .

soilvoc:WeatherPast a skos:Concept ;
    skos:broader soilvoc:Weather ;
    skos:definition [ dcterms:source glosis_sp:weatherConditionsPastProperty ;
            schema:text "Weather Conditions Past refers to historical weather data, including past patterns of temperature, precipitation, and extreme weather events. Understanding past weather conditions helps in predicting soil behavior, erosion patterns, and agricultural productivity, as well as preparing for future changes in soil moisture and temperature. Source: USDA NRCS, 'Climate and Soil Interactions'"@en ] ;
    skos:exactMatch glosis_sp:weatherConditionsPastProperty ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "weather past"@en .

soilvoc:WeatheringFragments a skos:Concept ;
    skos:altLabel "weathering fragment"@en ;
    skos:broader soilvoc:Fragments ;
    skos:definition [ dcterms:source glosis_cm:weatheringFragmentsProperty ;
            schema:text "The Weathering Fragment refers to soil particles or rock fragments that have been broken down through physical, chemical, or biological weathering. These fragments play a role in soil texture, structure, and nutrient availability. The degree of weathering can indicate the age and stability of the soil’s mineral content. Source: Brady, N. C., & Weil, R. R. (2008). The Nature and Properties of Soils (14th ed.). Pearson Prentice Hall."@en ] ;
    skos:exactMatch glosis_cm:weatheringFragmentsProperty ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "weathering fragments"@en .

soilvoc:WeatheringRock a skos:Concept ;
    skos:broader soilvoc:Rock ;
    skos:definition [ dcterms:source glosis_sp:weatheringRockProperty ;
            schema:text "Weathering Rock refers to the process of rock decomposition due to environmental factors like temperature changes, water, and chemical reactions. This process is important in soil formation as it contributes to the breakdown of parent material into smaller particles that form soil. Source: AGI, 'Encyclopedia of Geology'"@en ] ;
    skos:exactMatch glosis_sp:weatheringRockProperty ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "weathering rock"@en .

soilvoc:WetPlasticity a skos:Concept ;
    skos:broader soilvoc:SoilPlasticity ;
    skos:definition [ dcterms:source glosis_lh:wetPlasticityProperty ;
            schema:text "The Wet Plasticity measures the soil’s ability to deform under pressure when saturated. Wet plasticity is influenced by clay mineralogy and is important for understanding soil behavior under wet conditions. Source: Hillel, D. (2004). Introduction to Environmental Soil Physics."@en ] ;
    skos:exactMatch glosis_lh:wetPlasticityProperty ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "wet plasticity"@en .

soilvoc:WetSoilBulkDensity a skos:Concept ;
    skos:broader soilvoc:SoilBulkDensity ;
    skos:exactMatch spp:WetSoilBulkDensity ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "wet soil bulk density"@en .

