eusoilvoc:InterstructuralPores a skos:Concept ;
    skos:altLabel "interstructural pore"@en ;
    skos:broader eusoilvoc:SoilPores ;
    skos:exactMatch spp:InterstructuralPore ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "interstructural pores"@en .

