    skos:exactMatch agrovoc:c_a2ef545f,
        spp:AirQuality,
        inrae:c_4762,
        gemet:270,
        she:AirQuality ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "air quality"@en .

eusoilvoc:AirRatio a skos:Concept ;
    skos:broader eusoilvoc:SoilPorosity ;
    skos:exactMatch spp:AirRatio ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "air ratio"@en .

eusoilvoc:AntecedentSoilMoistureContents a skos:Concept ;
    skos:altLabel "antecedent soil moisture content"@en ;
    skos:broader eusoilvoc:SoilMoistureContents ;
    skos:exactMatch spp:AntecedentSoilMoistureContent ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "antecedent soil moisture contents"@en .

eusoilvoc:Biochannel a skos:Concept ;
    skos:broader eusoilvoc:SoilPores ;
    skos:exactMatch spp:Biochannel ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "biochannel"@en .

eusoilvoc:BiologicalAbundance a skos:Concept ;
    skos:broader eusoilvoc:SoilBiologicalProperties ;
    skos:definition [ dcterms:source glosis_lh:biologicalAbundanceProperty ;
            schema:text "The Biological Abundance evaluates the presence and quantity of soil organisms, such as microbes, insects, and earthworms. This property reflects soil health, nutrient cycling, and organic matter decomposition, which are vital for maintaining soil fertility. Source: Lavelle, P., & Spain, A.V. (2001). Soil Ecology."@en ] ;
    skos:exactMatch glosis_lh:biologicalAbundanceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "biological abundance"@en .

eusoilvoc:BiologicalFeatures a skos:Concept ;
    skos:altLabel "biological feature"@en ;
    skos:broader eusoilvoc:SoilBiologicalProperties ;
    skos:definition [ dcterms:source glosis_lh:biologicalFeaturesProperty ;
            schema:text "The Biological Features examines qualitative aspects of soil biological activity, including the types of organisms present, their diversity, and their roles in soil ecosystems. It encompasses processes like nitrogen fixation, organic matter decomposition, and bioturbation. Source: Soil Science Society of America (SSSA) Glossary."@en ] ;
    skos:exactMatch glosis_lh:biologicalFeaturesProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "biological features"@en .

eusoilvoc:BiologicalNitrogenFixation a skos:Concept ;
    skos:broader eusoilvoc:SoilBiologicalProcesses ;
    skos:exactMatch agrovoc:c_27742,
        spp:BiologicalNitrogenFixation,
        gemet:862 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "biological nitrogen fixation"@en .

eusoilvoc:BiomassProductivity a skos:Concept ;
    skos:broader eusoilvoc:SoilFunctionIndicators ;
    skos:exactMatch she:BiomassProductivity ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "biomass productivity"@en .

eusoilvoc:BleachedSand a skos:Concept ;
    skos:broader eusoilvoc:Sand ;
    skos:definition [ dcterms:source glosis_cm:bleachedSandProperty ;
            schema:text "The Bleached Sand refers to the physical characteristic of sandy soil that has undergone a bleaching process due to leaching, where minerals such as iron and other elements have been removed by water. This process often occurs in areas with high rainfall, leading to a soil that appears lighter in color. Bleached sand typically indicates low fertility and poor nutrient-holding capacity due to the lack of iron and other nutrients that are washed away. Source: Brady, N. C., & Weil, R. R. (2008). The Nature and Properties of Soils (14th ed.). Pearson Prentice Hall."@en ] ;
    skos:exactMatch glosis_cm:bleachedSandProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "bleached sand"@en .

eusoilvoc:BoundaryDistinctness a skos:Concept ;
    skos:broader eusoilvoc:SoilHorizonBoundary ;
    skos:definition [ dcterms:source glosis_lh:boundaryDistinctnessProperty ;
            schema:text "The Boundary Distinctness describes the sharpness of transitions between soil horizons. Boundaries can range from abrupt (clear demarcation) to diffuse (gradual blending), providing insights into soil formation processes and profile development. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:boundaryDistinctnessProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "boundary distinctness"@en .

eusoilvoc:BoundaryTopography a skos:Concept ;
    skos:broader eusoilvoc:SoilHorizonBoundary ;
    skos:definition [ dcterms:source glosis_lh:boundaryTopographyProperty ;
            schema:text "The Boundary Topography characterizes the shape of soil horizon boundaries, which may be smooth, wavy, irregular, or broken. It reflects processes like erosion, deposition, or biological activity that influence horizon development. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:boundaryTopographyProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "boundary topography"@en .

eusoilvoc:Building a skos:Concept ;
    skos:broader eusoilvoc:LandCover ;
    skos:closeMatch she:Buildings ;
    skos:exactMatch spp:Building,
        inrae:c_2560,
        gemet:1029 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "building"@en .

eusoilvoc:BuildingStability a skos:Concept ;
    skos:broader eusoilvoc:SoilEngineeringFunctions ;
    skos:exactMatch spp:BuildingStability ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "building stability"@en .

eusoilvoc:BulkDensityMineral a skos:Concept ;
    skos:broader eusoilvoc:SoilBulkDensity ;
    skos:definition [ dcterms:source glosis_lh:bulkDensityMineralProperty ;
            schema:text "The Bulk Density of Mineral Soil refers specifically to the density of the mineral portion of the soil, excluding organic matter. It provides insights into the physical state and compaction of mineral-dominated soils, influencing water movement and root growth. Source: Brady, N.C., & Weil, R.R. (2008). The Nature and Properties of Soils."@en ] ;
    skos:exactMatch glosis_lh:bulkDensityMineralProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "bulk density mineral"@en .

eusoilvoc:BulkDensityPeat a skos:Concept ;
    skos:broader eusoilvoc:SoilBulkDensity ;
    skos:definition [ dcterms:source glosis_lh:bulkDensityPeatProperty ;
            schema:text "The Bulk Density of Peat measures the mass of dry organic soil (peat) per unit volume. Peat soils typically have low bulk density due to their high organic matter content and porosity, which significantly affects their water retention and drainage characteristics. Source: Rydin, H., & Jeglum, J. (2006). The Biology of Peatlands."@en ] ;
    skos:exactMatch glosis_lh:bulkDensityPeatProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "bulk density peat"@en .

eusoilvoc:CarbonPools a skos:Concept ;
    skos:altLabel "carbon pool"@en ;
    skos:broader eusoilvoc:SoilFunctions ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "carbon pools"@en .

eusoilvoc:CarbonStorageCapacity a skos:Concept ;
    skos:broader eusoilvoc:SoilFunctionIndicators ;
    skos:exactMatch she:CarbonStorageCapacity ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "carbon storage capacity"@en .

eusoilvoc:CarbonateContents a skos:Concept ;
    skos:altLabel "carbonate content"@en ;
    skos:broader eusoilvoc:Carbonate ;
    skos:definition [ dcterms:source glosis_lh:carbonatesContentProperty ;
            schema:text "The Carbonate Content quantifies the concentration of carbonate minerals (e.g., CaCO₃, MgCO₃) in soil. These compounds influence soil pH, fertility, and structure, and are prevalent in calcareous soils. Source: Brady, N.C., & Weil, R.R. (2008). The Nature and Properties of Soils."@en ] ;
    skos:exactMatch glosis_lh:carbonatesContentProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "carbonate contents"@en .

eusoilvoc:CarbonateForms a skos:Concept ;
    skos:altLabel "carbonate form"@en ;
    skos:broader eusoilvoc:Carbonate ;
    skos:definition [ dcterms:source glosis_lh:carbonatesFormsProperty ;
            schema:text "The Carbonate Form describes the types of carbonate minerals present in soil, such as calcite, dolomite, or aragonite. These forms impact soil chemistry, fertility, and physical characteristics differently depending on their composition and solubility. Source: Sparks, D.L. (2003). Environmental Soil Chemistry."@en ] ;
    skos:exactMatch glosis_lh:carbonatesFormsProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "carbonate forms"@en .

eusoilvoc:CationExchange a skos:Concept ;
    skos:broader eusoilvoc:IonExchange ;
    skos:exactMatch spp:CationExchange,
        inrae:c_3a30d01b,
        she:CationExchange ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "cation exchange"@en .

eusoilvoc:CationExchangeCapacityEffective a skos:Concept ;
    skos:broader eusoilvoc:CationExchangeCapacity ;
    skos:definition [ dcterms:source glosis_lh:cationExchangeCapacityEffectiveProperty ;
            schema:text "The Effective Cation Exchange Capacity (ECEC) measures the ability of soil to hold and exchange cations at a given pH, often near field conditions. It provides insight into soil fertility, nutrient availability, and buffering capacity in acidic soils. Source: Soil Survey Staff (2014). Keys to Soil Taxonomy."@en ] ;
    skos:exactMatch glosis_lh:cationExchangeCapacityEffectiveProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "cation exchange capacity effective"@en .

eusoilvoc:CationSum a skos:Concept ;
    skos:altLabel "cations sum"@en ;
    skos:broader eusoilvoc:ExchangeableCations ;
    skos:definition [ dcterms:source glosis_lh:cationsSumProperty ;
            schema:text "The Cations Sum calculates the total concentration of exchangeable cations (e.g., Ca²⁺, Mg²⁺, K⁺, Na⁺) in the soil. It helps determine soil fertility and salinity and is commonly expressed in milliequivalents per 100 grams of soil. Source: Soil Science Society of America (SSSA) Glossary."@en ] ;
    skos:exactMatch glosis_lh:cationsSumProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "cation sum"@en .

eusoilvoc:CementationContinuity a skos:Concept ;
    skos:broader eusoilvoc:Cementation ;
    skos:definition [ dcterms:source glosis_lh:cementationContinuityProperty ;
            schema:text "The Cementation Continuity describes the extent to which soil particles are bound together by cementing agents, such as calcium carbonate, iron oxides, or silica. Cementation affects soil permeability, root penetration, and the development of soil horizons. Continuity can be classified as continuous, discontinuous, or patchy. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:cementationContinuityProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "cementation continuity"@en .

eusoilvoc:CementationDegree a skos:Concept ;
    skos:broader eusoilvoc:Cementation ;
    skos:definition [ dcterms:source glosis_lh:cementationDegreeProperty ;
            schema:text "The Cementation Degree measures how strongly soil particles are bonded by cementing agents. It ranges from weakly cemented (friable) to strongly cemented (hard). This property influences soil strength and its suitability for agricultural and engineering purposes. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:cementationDegreeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "cementation degree"@en .

eusoilvoc:CementationFabric a skos:Concept ;
    skos:broader eusoilvoc:Cementation ;
    skos:definition [ dcterms:source glosis_lh:cementationFabricProperty ;
            schema:text "The Cementation Fabric examines the texture, structure, and arrangement of cementing materials within the soil. It provides insights into soil formation processes and the mechanical stability of the soil matrix. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:cementationFabricProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "cementation fabric"@en .

eusoilvoc:CementationNature a skos:Concept ;
    skos:broader eusoilvoc:Cementation ;
    skos:definition [ dcterms:source glosis_lh:cementationNatureProperty ;
            schema:text "The Cementation Nature identifies the specific type of material responsible for binding soil particles, such as carbonates, silica, or iron oxides. Understanding this helps in soil classification and predicting behavior under varying environmental conditions. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:cementationNatureProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "cementation nature"@en .

eusoilvoc:Clay a skos:Concept ;
    skos:broader eusoilvoc:SoilPrimaryParticles ;
    skos:exactMatch agrovoc:c_15619,
        spp:Clay,
        inrae:c_11626,
        gemet:1449,
        she:Clay ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "clay"@en .

eusoilvoc:ClayRatio a skos:Concept ;
    skos:broader eusoilvoc:SoilStructureIndirectIndex ;
    skos:exactMatch spp:ClayRatio ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "clay ratio"@en .

eusoilvoc:ClimateRegulation a skos:Concept ;
    skos:broader eusoilvoc:SoilFunctions ;
    skos:exactMatch gemet:15098,
        she:ClimateRegulation ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "climate regulation"@en .

eusoilvoc:CoarseSand a skos:Concept ;
    skos:broader eusoilvoc:Sand ;
    skos:exactMatch agrovoc:c_c03927e1,
        spp:CoarseSand ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "coarse sand"@en .

eusoilvoc:CoatingAbundance a skos:Concept ;
    skos:broader eusoilvoc:SoilCoating ;
    skos:definition [ dcterms:source glosis_lh:coatingAbundanceProperty ;
            schema:text "The Coating Abundance evaluates the quantity of coatings on soil particles, such as organic matter, clay, or iron oxides. Coatings influence soil color, nutrient availability, and water movement. The abundance is typically classified as few, common, or many. Source: Soil Survey Staff (2014). Keys to Soil Taxonomy."@en ] ;
    skos:exactMatch glosis_lh:coatingAbundanceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "coating abundance"@en .

eusoilvoc:CoatingContrast a skos:Concept ;
    skos:broader eusoilvoc:SoilCoating ;
    skos:definition [ dcterms:source glosis_lh:coatingContrastProperty ;
            schema:text "The Coating Contrast assesses the visual distinction between coatings on soil particles and the underlying material. High contrast indicates significant differences in composition or color, providing clues about soil processes like illuviation or biological activity. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:coatingContrastProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "coating contrast"@en .

eusoilvoc:CoatingForms a skos:Concept ;
    skos:altLabel "coating form"@en ;
    skos:broader eusoilvoc:SoilCoating ;
    skos:definition [ dcterms:source glosis_lh:coatingFormProperty ;
            schema:text "The Coating Form describes the shape and distribution of coatings on soil particles, such as patchy, continuous, or layered. These forms are indicative of soil genesis and chemical weathering processes. Source: Soil Science Society of America (SSSA) Glossary."@en ] ;
    skos:exactMatch glosis_lh:coatingFormProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "coating forms"@en .

eusoilvoc:CoatingLocation a skos:Concept ;
    skos:broader eusoilvoc:SoilCoating ;
    skos:definition [ dcterms:source glosis_lh:coatingLocationProperty ;
            schema:text "The Coating Location identifies where coatings are found within the soil profile, such as along root channels, pore spaces, or on particle surfaces. This property helps determine the movement of water and nutrients in the soil. Source: Soil Survey Staff (2014). Keys to Soil Taxonomy."@en ] ;
    skos:exactMatch glosis_lh:coatingLocationProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "coating location"@en .

eusoilvoc:CoatingNature a skos:Concept ;
    skos:broader eusoilvoc:SoilCoating ;
    skos:definition [ dcterms:source glosis_lh:coatingNatureProperty ;
            schema:text "The Coating Nature examines the composition of soil coatings, such as organic, clay, or iron-rich coatings. The nature of these coatings can influence nutrient retention, soil color, and water dynamics. Source: Brady, N.C., & Weil, R.R. (2008). The Nature and Properties of Soils."@en ] ;
    skos:exactMatch glosis_lh:coatingNatureProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "coating nature"@en .

eusoilvoc:ColloidContentMoistureEquivalentRatio a skos:Concept ;
    skos:broader eusoilvoc:SoilErodibilityIndex ;
    skos:exactMatch spp:ColloidContentMoistureEquivalentRatio ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "colloid content moisture equivalent ratio"@en .

eusoilvoc:ConservationTillage a skos:Concept ;
    skos:broader eusoilvoc:SoilTillage ;
    skos:exactMatch agrovoc:c_33445,
        spp:ConservationTillage ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "conservation tillage"@en .

eusoilvoc:ConservativeSolutes a skos:Concept ;
    skos:altLabel "conservative solute"@en ;
    skos:broader eusoilvoc:SoilSolutes ;
    skos:exactMatch spp:ConservativeSolute ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "conservative solutes"@en .

eusoilvoc:ConsistenceDry a skos:Concept ;
    skos:broader eusoilvoc:SoilConsistence ;
    skos:definition [ dcterms:source glosis_lh:consistenceDryProperty ;
            schema:text "The Consistence Dry evaluates the soil's behavior when dry, including its resistance to deformation or crumbling. It ranges from loose to hard and provides information about soil compaction and management practices. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:consistenceDryProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "consistence dry"@en .

eusoilvoc:ConsistenceMoist a skos:Concept ;
    skos:broader eusoilvoc:SoilConsistence ;
    skos:definition [ dcterms:source glosis_lh:consistenceMoistProperty ;
            schema:text "The Consistence Moist assesses how soil responds to pressure when moist. Categories include friable, firm, or plastic. This property is essential for understanding soil workability and water retention. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:consistenceMoistProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "consistence moist"@en .

eusoilvoc:ControlledDrainage a skos:Concept ;
    skos:broader eusoilvoc:SoilDrainage ;
    skos:exactMatch spp:ControlledDrainage ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "controlled drainage"@en .

eusoilvoc:ConventionalDrainage a skos:Concept ;
    skos:broader eusoilvoc:SoilDrainage ;
    skos:exactMatch spp:ConventionalDrainage ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "conventional drainage"@en .

eusoilvoc:CriticalSoilOrganicMatterContents a skos:Concept ;
    skos:altLabel "critical soil organic matter content"@en ;
    skos:broader eusoilvoc:SoilStructureIndirectIndex ;
    skos:exactMatch spp:CriticalSoilOrganicMatterContent ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "critical soil organic matter contents"@en .

eusoilvoc:Crop a skos:Concept ;
    skos:broader eusoilvoc:PlantCover ;
    skos:closeMatch she:Crops ;
    skos:exactMatch spp:Crop,
        inrae:c_3369 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "crop"@en .

eusoilvoc:CropClass a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_sp:cropClassProperty ;
            schema:text "Crop Class refers to the categorization of land based on the type of crops cultivated. This property is used to assess soil management practices and land productivity, as different crops require specific soil conditions for optimal growth. Source: FAO, 'Guidelines for Soil Profile Description'"@en ] ;
    skos:exactMatch glosis_sp:cropClassProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "crop class"@en .

eusoilvoc:CropResidueMulch a skos:Concept ;
    skos:broader eusoilvoc:Mulch ;
    skos:exactMatch spp:CropResidueMulch ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "crop residue mulch"@en .

eusoilvoc:CropYield a skos:Concept ;
    skos:broader eusoilvoc:SoilAgriculturalFunctions ;
    skos:closeMatch she:CropYields ;
    skos:exactMatch agrovoc:c_10176,
