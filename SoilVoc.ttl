    skos:definition [ dcterms:source glosis_sp:treeDensityProperty ;
            schema:text "Tree Density refers to the number of trees per unit area, usually expressed as trees per hectare. High tree density is often associated with forested ecosystems that contribute to soil fertility through organic matter inputs, root structures that stabilize the soil, and enhanced moisture retention. Source: FAO, 'Forest Resources Assessment'"@en ] ;
