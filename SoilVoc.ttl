soilvoc:SoilChemicalProperties a skos:Concept ;
    skos:altLabel "soil chemical property"@en ;
    skos:broader soilvoc:SoilProperties ;
    skos:definition [ dcterms:source <https://soilhealthnexus.org/resources/soil-properties/soil-chemical-properties/> ;
            schema:text "Chemical properties of soils include the following aspects: inorganic matters of soil, organic matters in soil, colloidal properties of soil particles and soil reactions and buffering action in acidic soils and basic soils."@en ],
        [ dcterms:source <https://www.sciencedirect.com/topics/earth-and-planetary-sciences/soil-chemical-property> ;
            schema:text "Soil chemical properties refer to the chemical attributes of soil that influence its ability to supply nutrients to plants, retain harmful elements, and affect plant growth and microbial populations. These properties include nutrient concentrations, pH levels, and the presence of elements such as nitrogen, phosphorus, and potassium, which are critical for soil quality assessment and agricultural productivity."@en ] ;
    skos:exactMatch spp:SoilChemicalProperty,
        she:SoilChemicalProperties ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:narrower soilvoc:BaseSaturation,
        soilvoc:Carbonate,
        soilvoc:HydrogenExchangeableBases,
        soilvoc:OxalateExtractableOpticalDensity,
        soilvoc:Sodium,
        soilvoc:SoilChargeProperties,
        soilvoc:SoilChemicalCapacity,
        soilvoc:SoilReactivity,
        soilvoc:SoilRedoxPotential,
        soilvoc:SoilSalinity,
        soilvoc:SoilpH ;
    skos:prefLabel "soil chemical properties"@en ;
    skos:related soilvoc:SoilQuality .

