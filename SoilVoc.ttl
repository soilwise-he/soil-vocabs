eusoilvoc:SoilPoreSize a skos:Concept ;
    skos:altLabel "pores size"@en ;
    skos:broader eusoilvoc:SoilPorePhysicalProperties,
        eusoilvoc:SoilPores ;
    skos:definition [ dcterms:source glosis_lh:poresSizeProperty ;
            schema:text "The Pores Size categorizes soil pores by their diameter, such as macro-pores, meso-pores, and micro-pores. This property determines water retention, air movement, and root penetration in soil. Source: Brady, N.C., & Weil, R.R. (2008). The Nature and Properties of Soils."@en ] ;
    skos:exactMatch spp:SoilPoreSize,
        glosis_lh:poresSizeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil pore size"@en .

