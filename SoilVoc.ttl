        eusoilvoc:nitrogenTotalProcedure-TotalN_nelson,
        eusoilvoc:nitrogenTotalProcedure-TotalN_tn04,
        eusoilvoc:nitrogenTotalProcedure-TotalN_tn06,
        eusoilvoc:nitrogenTotalProcedure-TotalN_tn08 .

