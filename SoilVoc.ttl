    skos:exactMatch spp:PlantNutrientUptake ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "plant nutrient uptake"@en .

eusoilvoc:PlantRespiration a skos:Concept ;
    skos:broader eusoilvoc:SoilAgriculturalFunctions ;
    skos:exactMatch spp:PlantRespiration,
        inrae:c_5853 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "plant respiration"@en .

eusoilvoc:PlantWaterUptake a skos:Concept ;
    skos:broader eusoilvoc:SoilAgriculturalFunctions ;
    skos:exactMatch spp:PlantWaterUptake ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "plant water uptake"@en .

eusoilvoc:PlasticConsistence a skos:Concept ;
    skos:broader eusoilvoc:SoilConsistence ;
    skos:exactMatch spp:PlasticConsistence ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "plastic consistence"@en .

eusoilvoc:PoreAbundance a skos:Concept ;
    skos:altLabel "pores abundance"@en ;
    skos:broader eusoilvoc:SoilPores ;
    skos:definition [ dcterms:source glosis_lh:poresAbundanceProperty ;
            schema:text "The Pores Abundance describes the quantity of soil pores, ranging from few to many. It influences water infiltration, root growth, and soil aeration. Pore abundance is crucial for assessing soil health and productivity. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:poresAbundanceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "pore abundance"@en .

eusoilvoc:PorosityClass a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_lh:porosityClassProperty ;
            schema:text "The Porosity Class classifies soil by the proportion of pore spaces, typically expressed as a percentage. Classes include high, medium, or low porosity, influencing water and air movement in the soil. Source: Soil Science Society of America (SSSA) Glossary."@en ] ;
    skos:exactMatch glosis_lh:porosityClassProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "porosity class"@en .

eusoilvoc:ProfileControlledWaterInfiltration a skos:Concept ;
    skos:broader eusoilvoc:SoilWaterInfiltration ;
    skos:exactMatch spp:ProfileControlledWaterInfiltration ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "profile controlled water infiltration"@en .

eusoilvoc:ProfileDescriptionStatus a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_pr:profileDescriptionStatusProperty ;
            schema:text "The Profile Description Status indicates the level of detail and accuracy in documenting the features of a soil profile, including its horizons, texture, structure, and other observable characteristics. This property ensures that the soil profile description meets standards for completeness, enabling reliable classification and analysis. It is a critical aspect of soil studies, providing the basis for land-use planning, environmental assessment, and agricultural decision-making. Source: Schoeneberger, P.J., Wysocki, D.A., Benham, E.C., & Soil Survey Staff. (2012). Field Book for Describing and Sampling Soils. USDA-NRCS."@en ] ;
    skos:exactMatch glosis_pr:profileDescriptionStatusProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "profile description status"@en .

eusoilvoc:ProvisioningServices a skos:Concept ;
    skos:altLabel "provisioning service"@en ;
    skos:broader eusoilvoc:EcosystemServices ;
    skos:exactMatch agrovoc:c_7e12eb3f,
        she:ProvisioningServices ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "provisioning services"@en .

eusoilvoc:Rain a skos:Concept ;
    skos:broader eusoilvoc:Precipitation ;
    skos:exactMatch agrovoc:c_6435,
        spp:Rain,
        inrae:c_11627,
        gemet:6947 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "rain"@en .

