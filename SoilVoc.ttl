    skos:broader eusoilvoc:ExchangeableCations ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Aciexc ;
            schema:text "Exchangeable acidity represents the amount of hydrogen (H⁺) and aluminum (Al³⁺) ions adsorbed onto soil particles that can be exchanged with the soil solution. It is a key factor in determining soil liming requirements and improving nutrient availability in acidic soils. Source: Brady & Weil (2017)."@en ] ;
