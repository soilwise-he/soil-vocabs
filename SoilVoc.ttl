soilvoc:FragmentClass a skos:Concept ;
    skos:broader soilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_lh:fragmentsClassProperty ;
            schema:text "The Fragments Class categorizes the size, shape, and quantity of coarse fragments (e.g., gravel, stones) present in the soil. These fragments affect soil porosity, water retention, and root penetration. The classification includes gravelly, stony, or bouldery soils. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:fragmentsClassProperty ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "fragment class"@en .

soilvoc:FragmentCover a skos:Concept ;
    skos:broader soilvoc:Fragments ;
    skos:definition [ dcterms:source glosis_cm:fragmentCoverProperty ;
            schema:text "The Fragment Cover describes the proportion of the soil surface covered by coarse fragments such as rocks, stones, or other large particles. This property is important because a high fragment cover can reduce soil erosion but may also interfere with water infiltration and root growth. Fragment cover is often used as an indicator of soil stability and erosion potential. Source: FAO (2006). Guidelines for Soil Description (4th ed.). Food and Agriculture Organization of the United Nations."@en ] ;
    skos:exactMatch glosis_cm:fragmentCoverProperty ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "fragment cover"@en .

soilvoc:FragmentSize a skos:Concept ;
    skos:broader soilvoc:Fragments ;
    skos:definition [ dcterms:source glosis_cm:fragmentsSizeProperty ;
            schema:text "The Fragment Size refers to the dimensions of rock or mineral fragments present in the soil. These fragments are categorized based on their size, ranging from small gravel particles to larger stones and boulders. Larger fragments tend to reduce soil fertility, inhibit root growth, and decrease water retention. Smaller fragments, in contrast, contribute to soil texture and permeability. Source: Soil Science Society of America. (2008). Soil Science Glossary. Soil Science Society of America."@en ] ;
    skos:exactMatch glosis_cm:fragmentsSizeProperty ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "fragment size"@en .

soilvoc:FriableConsistence a skos:Concept ;
    skos:broader soilvoc:SoilConsistence ;
    skos:exactMatch spp:FriableConsistence ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "friable consistence"@en .

