eusoilvoc:SoilSurfaceAge a skos:Concept ;
    skos:broader eusoilvoc:SoilAge ;
    skos:definition [ dcterms:source glosis_sp:surfaceAgeProperty ;
            schema:text "Surface Age refers to the estimated age of a surface layer of soil or landform, which is important for understanding the degree of soil weathering, development, and fertility. Older surfaces may have more developed soils, while younger surfaces may be less fertile and more prone to erosion. Source: FAO, 'Soil Formation and Evolution'"@en ] ;
    skos:exactMatch glosis_sp:surfaceAgeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil surface age"@en .

