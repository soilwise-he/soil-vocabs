soilvoc:HumanInfluenceClass a skos:Concept ;
    skos:broader soilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_sp:humanInfluenceClassProperty ;
            schema:text "Human Influence Class classifies the extent of human impact on a landscape or ecosystem, ranging from minimal disturbance to high levels of modification. This classification helps in understanding the effects of urbanization, agriculture, or industrial activity on soil properties and ecosystem functions. Source: FAO, 'Land Degradation Assessment in Drylands'"@en ] ;
    skos:exactMatch glosis_sp:humanInfluenceClassProperty ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "human influence class"@en .

