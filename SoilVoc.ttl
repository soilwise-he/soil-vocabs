soilvoc:SolubleAnionTotal a skos:Concept ;
    skos:altLabel "soluble anions total"@en ;
    skos:broader soilvoc:SoilSolutes ;
    skos:definition [ dcterms:source glosis_lh:solubleAnionsTotalProperty ;
            schema:text "The Soluble Anions Total measures the concentration of anions (e.g., chloride, sulfate, nitrate) in soil solution. High levels may indicate salinity, nutrient availability, or contamination. Source: Sparks, D.L. (2003). Environmental Soil Chemistry."@en ] ;
    skos:exactMatch glosis_lh:solubleAnionsTotalProperty ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "soluble anion total"@en .

soilvoc:SolubleCationTotal a skos:Concept ;
    skos:altLabel "soluble cations total"@en ;
    skos:broader soilvoc:SoilSolutes ;
    skos:definition [ dcterms:source glosis_lh:solubleCationsTotalProperty ;
            schema:text "The Soluble Cations Total evaluates the sum of cations (e.g., sodium, potassium, calcium, magnesium) in soil solution. It is an indicator of soil salinity, fertility, and chemical balance. Source: Brady, N.C., & Weil, R.R. (2008). The Nature and Properties of Soils."@en ] ;
    skos:exactMatch glosis_lh:solubleCationsTotalProperty ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "soluble cation total"@en .

soilvoc:Stickiness a skos:Concept ;
    sio:equivalentTo soilvoc:SoilAdhesion ;
    skos:broader soilvoc:SoilPhysicalProperties ;
    skos:definition [ dcterms:source glosis_lh:stickinessProperty ;
            schema:text "The Stickiness measures the soil’s tendency to adhere to surfaces or objects when wet. It is influenced by clay content and organic matter and affects soil workability and machinery use. Source: Hillel, D. (2004). Introduction to Environmental Soil Physics."@en ] ;
    skos:exactMatch agrovoc:c_7409,
        glosis_lh:stickinessProperty ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "stickiness"@en .

