        soilvoc:exchangeableBasesProcedure-ExchBases_ph7-nh4oac,
        soilvoc:exchangeableBasesProcedure-ExchBases_ph7-nh4oac-aas,
        soilvoc:exchangeableBasesProcedure-ExchBases_ph7-nh4oac-fp,
        soilvoc:exchangeableBasesProcedure-ExchBases_ph7-unkn,
        soilvoc:exchangeableBasesProcedure-ExchBases_ph8-bacl2tea,
        soilvoc:exchangeableBasesProcedure-ExchBases_ph8-unkn .

soilvoc:NitrogenTotal a skos:Concept,
        sosa:ObservableProperty ;
    skos:broader soilvoc:Nitrogen ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Nittot ;
            schema:text "Total nitrogen encompasses all nitrogen forms in soil, including organic nitrogen in humus and inorganic nitrogen such as ammonium (NH₄⁺) and nitrate (NO₃⁻). Nitrogen is essential for plant growth, being a vital component of amino acids, proteins, and chlorophyll. Total nitrogen is a key indicator of soil fertility and its capacity to sustain long-term crop productivity. Source: Brady & Weil (2017)."@en ] ;
    skos:exactMatch glosis_cl:physioChemicalPropertyCode-Nittot ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "nitrogen total"@en ;
    sosa:hasProcedure soilvoc:nitrogenTotalProcedure-TotalN_bremner,
        soilvoc:nitrogenTotalProcedure-TotalN_calcul,
        soilvoc:nitrogenTotalProcedure-TotalN_calcul-oc10,
