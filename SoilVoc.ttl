    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "foundation stability"@en .

eusoilvoc:FoundationStrength a skos:Concept ;
    skos:broader eusoilvoc:SoilEngineeringFunctions ;
    skos:exactMatch spp:FoundationStrength ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "foundation strength"@en .

eusoilvoc:FragmentClass a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_lh:fragmentsClassProperty ;
            schema:text "The Fragments Class categorizes the size, shape, and quantity of coarse fragments (e.g., gravel, stones) present in the soil. These fragments affect soil porosity, water retention, and root penetration. The classification includes gravelly, stony, or bouldery soils. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:fragmentsClassProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "fragment class"@en .

eusoilvoc:FragmentCover a skos:Concept ;
    skos:broader eusoilvoc:Fragments ;
    skos:definition [ dcterms:source glosis_cm:fragmentCoverProperty ;
            schema:text "The Fragment Cover describes the proportion of the soil surface covered by coarse fragments such as rocks, stones, or other large particles. This property is important because a high fragment cover can reduce soil erosion but may also interfere with water infiltration and root growth. Fragment cover is often used as an indicator of soil stability and erosion potential. Source: FAO (2006). Guidelines for Soil Description (4th ed.). Food and Agriculture Organization of the United Nations."@en ] ;
    skos:exactMatch glosis_cm:fragmentCoverProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "fragment cover"@en .

eusoilvoc:FragmentSize a skos:Concept ;
    skos:broader eusoilvoc:Fragments ;
    skos:definition [ dcterms:source glosis_cm:fragmentsSizeProperty ;
            schema:text "The Fragment Size refers to the dimensions of rock or mineral fragments present in the soil. These fragments are categorized based on their size, ranging from small gravel particles to larger stones and boulders. Larger fragments tend to reduce soil fertility, inhibit root growth, and decrease water retention. Smaller fragments, in contrast, contribute to soil texture and permeability. Source: Soil Science Society of America. (2008). Soil Science Glossary. Soil Science Society of America."@en ] ;
    skos:exactMatch glosis_cm:fragmentsSizeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "fragment size"@en .

eusoilvoc:FriableConsistence a skos:Concept ;
    skos:broader eusoilvoc:SoilConsistence ;
    skos:exactMatch spp:FriableConsistence ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "friable consistence"@en .

eusoilvoc:GeometricMeanDiametre a skos:Concept ;
    skos:broader eusoilvoc:SoilAggregationIndex ;
    skos:exactMatch spp:GeometricMeanDiameter ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "geometric mean diametre"@en .

eusoilvoc:Grasses a skos:Concept ;
    skos:altLabel "grass"@en ;
    skos:broader eusoilvoc:Vegetation ;
    skos:exactMatch agrovoc:c_3362,
        spp:Grass ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "grasses"@en .

eusoilvoc:GroundCover a skos:Concept ;
    skos:broader eusoilvoc:LandCover ;
    skos:exactMatch spp:GroundCover,
        inrae:c_3684 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "ground cover"@en .

eusoilvoc:GroundwaterDepth a skos:Concept ;
    skos:broader eusoilvoc:SoilWaterPhysicalProperties ;
    skos:definition [ dcterms:source glosis_sp:groundwaterDepthProperty ;
            schema:text "Groundwater Depth indicates the depth from the soil surface to the water table, which affects soil moisture levels, plant growth, and root penetration. Shallow groundwater can influence soil salinity and nutrient availability, while deep groundwater may limit water access for plants. Source: USDA NRCS, 'Groundwater and Soil'"@en ] ;
    skos:exactMatch glosis_sp:groundwaterDepthProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "groundwater depth"@en .

eusoilvoc:GroundwaterReproduction a skos:Concept ;
    skos:broader eusoilvoc:SoilFunctionIndicators ;
    skos:exactMatch she:GroundwaterReproduction ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "groundwater reproduction"@en .

eusoilvoc:GypsumContents a skos:Concept ;
    skos:altLabel "gypsum content"@en ;
    skos:broader eusoilvoc:Gypsum ;
    skos:definition [ dcterms:source glosis_lh:gypsumContentProperty ;
            schema:text "The Gypsum Content quantifies the amount of gypsum (calcium sulfate dihydrate) present in the soil. Gypsum affects soil structure, water infiltration, and nutrient availability, especially in arid and semi-arid regions. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:gypsumContentProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "gypsum contents"@en .

eusoilvoc:GypsumForms a skos:Concept ;
    skos:altLabel "gypsum form"@en ;
    skos:broader eusoilvoc:Gypsum ;
    skos:definition [ dcterms:source glosis_lh:gypsumFormsProperty ;
            schema:text "The Gypsum Forms describes the morphology of gypsum within the soil, such as crystals, veins, or nodules. The form indicates the processes of soil formation and water movement in gypsum-rich soils. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:gypsumFormsProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "gypsum forms"@en .

eusoilvoc:GypsumWeight a skos:Concept ;
    skos:broader eusoilvoc:Gypsum ;
    skos:definition [ dcterms:source glosis_lh:gypsumWeightProperty ;
            schema:text "The Gypsum Weight measures the mass of gypsum in the soil profile. This value helps evaluate the potential for soil salinity issues and influences decisions for agricultural or land reclamation practices. Source: Brady, N.C., & Weil, R.R. (2008). The Nature and Properties of Soils."@en ] ;
    skos:exactMatch glosis_lh:gypsumWeightProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "gypsum weight"@en .

eusoilvoc:HabitatProvisionCapacity a skos:Concept ;
    skos:broader eusoilvoc:SoilFunctionIndicators ;
    skos:exactMatch she:HabitatProvisionCapacity ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "habitat provision capacity"@en .

eusoilvoc:Habitats a skos:Concept ;
    skos:altLabel "habitat"@en ;
    skos:broader eusoilvoc:SoilFunctions ;
    skos:exactMatch agrovoc:c_3456 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "habitats"@en .

eusoilvoc:Hail a skos:Concept ;
    skos:broader eusoilvoc:Precipitation ;
    skos:exactMatch agrovoc:c_3469,
        spp:Hail,
        inrae:c_11412,
        gemet:3812 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "hail"@en .

eusoilvoc:HarshConsistence a skos:Concept ;
    skos:broader eusoilvoc:SoilConsistence ;
    skos:exactMatch spp:HarshConsistence ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "harsh consistence"@en .

eusoilvoc:HumanInfluenceClass a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_sp:humanInfluenceClassProperty ;
            schema:text "Human Influence Class classifies the extent of human impact on a landscape or ecosystem, ranging from minimal disturbance to high levels of modification. This classification helps in understanding the effects of urbanization, agriculture, or industrial activity on soil properties and ecosystem functions. Source: FAO, 'Land Degradation Assessment in Drylands'"@en ] ;
    skos:exactMatch glosis_sp:humanInfluenceClassProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "human influence class"@en .

eusoilvoc:IndexBasedOnTextureAndCementingAgents a skos:Concept ;
    skos:altLabel "index based on texture and cementing agent"@en ;
    skos:broader eusoilvoc:SoilStructureIndirectIndex ;
    skos:exactMatch spp:IndexBasedOnTextureAndCementingAgents ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "index based on texture and cementing agents"@en .

