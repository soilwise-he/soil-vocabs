eusoilvoc:SoilColourDry a skos:Concept ;
    skos:broader eusoilvoc:SoilColour ;
    skos:definition [ dcterms:source glosis_cm:colourDryProperty ;
            schema:text "The Soil Colour Dry describes the color of soil when it is in a dry state. Soil color in the dry condition is influenced by the soil’s mineral composition and moisture content. For example, soils with high organic matter content typically appear dark brown or black when dry, while sandy or saline soils may appear lighter in color. Dry soil color is used in soil classification and can provide insights into the soil's composition and drainage. Source: Soil Science Society of America. (2008). Soil Science Glossary. Soil Science Society of America."@en ] ;
    skos:exactMatch glosis_cm:colourDryProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil colour dry"@en .

eusoilvoc:SoilColourMoist a skos:Concept ;
    skos:broader eusoilvoc:SoilColour ;
    skos:definition [ dcterms:source glosis_cm:colourMoistProperty ;
            schema:text "The Soil Colour Moist refers to the soil's color when it is in a wet or moist condition. Moisture enhances the color intensity of the soil, which is often darker compared to its dry state. This is particularly helpful in determining organic matter content, iron oxide presence, and soil moisture retention. For instance, moist soils with abundant organic material tend to appear darker, whereas more mineral-rich soils can appear lighter in color. Source: Soil Science Society of America. (2008). Soil Science Glossary. Soil Science Society of America."@en ] ;
    skos:exactMatch glosis_cm:colourMoistProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil colour moist"@en .

eusoilvoc:SoilCompactability a skos:Concept ;
    skos:broader eusoilvoc:SoilPhysicalProperties ;
    skos:exactMatch spp:SoilCompactability ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil compactability"@en .

eusoilvoc:SoilCompressibility a skos:Concept ;
    skos:broader eusoilvoc:SoilPhysicalProperties ;
    skos:exactMatch spp:SoilCompressibility ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil compressibility"@en .

eusoilvoc:SoilConsolidation a skos:Concept ;
    skos:broader eusoilvoc:SoilCompression ;
    skos:exactMatch spp:SoilConsolidation,
        inrae:c_11244 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil consolidation"@en .

eusoilvoc:SoilCrackDepth a skos:Concept ;
    skos:broader eusoilvoc:SoilCracks ;
    skos:definition [ dcterms:source glosis_cm:cracksDepthProperty ;
            schema:text "The Soil Crack Depth refers to the measurement of the vertical depth of cracks formed in soil, which is typically observed in dry conditions when the soil shrinks. Cracks are more common in clayey soils that experience significant shrinkage upon drying. The depth of these cracks can indicate soil moisture levels, compaction, and the ability of the soil to expand and contract, which affects water infiltration and root penetration. Source: McSweeney, K. (2009). Soil and Water Conservation Handbook. CRC Press."@en ] ;
    skos:exactMatch glosis_cm:cracksDepthProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil crack depth"@en .

eusoilvoc:SoilCrackDistance a skos:Concept ;
    skos:broader eusoilvoc:SoilCracks ;
    skos:definition [ dcterms:source glosis_cm:cracksDistanceProperty ;
            schema:text "The Soil Crack Distance refers to the horizontal spacing between cracks in the soil surface, which can occur due to the shrinkage of soil as it dries. Cracks form when water content decreases, and their distance is an indicator of the soil's shrink-swell behavior. Larger distances between cracks generally indicate more severe soil shrinkage, which can affect root growth and water infiltration. Source: McSweeney, K. (2009). Soil and Water Conservation Handbook. CRC Press."@en ] ;
    skos:exactMatch glosis_cm:cracksDistanceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil crack distance"@en .

eusoilvoc:SoilCrackWidth a skos:Concept ;
    skos:broader eusoilvoc:SoilCracks ;
    skos:definition [ dcterms:source glosis_cm:cracksWidthProperty ;
            schema:text "The Soil Crack Width refers to the measurement of the gap or space between the sides of soil cracks. The width of these cracks is typically influenced by soil moisture content and texture. Wider cracks are indicative of drier conditions and are commonly found in soils with high clay content, which tend to shrink and form deep cracks when the moisture content is reduced. Source: McSweeney, K. (2009). Soil and Water Conservation Handbook. CRC Press."@en ] ;
    skos:exactMatch glosis_cm:cracksWidthProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil crack width"@en .

eusoilvoc:SoilCrackingIntensity a skos:Concept ;
    skos:broader eusoilvoc:SoilCrackingPhysicalProperties ;
    skos:exactMatch spp:SoilCrackingIntensity ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil cracking intensity"@en .

eusoilvoc:SoilCrackingNumber a skos:Concept ;
