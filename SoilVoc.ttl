eusoilvoc:TotalCarbonateEquivalent a skos:Concept ;
    skos:broader eusoilvoc:Carbonate ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Ccetot ;
            schema:text "The total calcium carbonate equivalent measures the full capacity of soil to neutralize acidity, considering all forms of carbonate and bicarbonate minerals. It is essential for managing soil pH and nutrient availability in acidic soils. Source: FAO Soil Bulletin."@en ] ;
    skos:exactMatch glosis_cl:physioChemicalPropertyCode-Ccetot ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "total carbonate equivalent"@en ;
