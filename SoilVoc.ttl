eusoilvoc:SoilErodibility a skos:Concept ;
    skos:broader eusoilvoc:SoilPhysicalProperties ;
    skos:exactMatch spp:SoilErodibility,
        she:SoilErodibility ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil erodibility"@en .

eusoilvoc:SoilErosionActivityPeriod a skos:Concept ;
    skos:broader eusoilvoc:SoilErosion ;
    skos:definition [ dcterms:source glosis_sp:erosionActivityPeriodProperty ;
            schema:text "Soil Erosion Activity Period refers to the time frame during which soil erosion processes, such as wind or water erosion, are most active in a given area. This period is influenced by climatic conditions, seasonal rainfall, and land use, and it helps in assessing the vulnerability of soils to degradation. Source: USDA NRCS, 'Soil Erosion and Conservation'"@en ] ;
    skos:exactMatch glosis_sp:erosionActivityPeriodProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil erosion activity period"@en .

eusoilvoc:SoilErosionAreaAffected a skos:Concept ;
    skos:broader eusoilvoc:SoilErosion ;
    skos:definition [ dcterms:source glosis_sp:erosionAreaAffectedProperty ;
            schema:text "Soil Erosion Area Affected refers to the extent of land area that has been impacted by soil erosion processes, such as water or wind erosion. This property is important for evaluating the severity of soil degradation in a given region and helps in identifying areas that require soil conservation measures. Source: USDA NRCS, 'Soil Erosion Research and Technology Transfer'"@en ] ;
    skos:exactMatch glosis_sp:erosionAreaAffectedProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil erosion area affected"@en .

eusoilvoc:SoilErosionCategory a skos:Concept ;
    skos:broader eusoilvoc:SoilErosion ;
    skos:definition [ dcterms:source glosis_sp:erosionCategoryProperty ;
            schema:text "Soil Erosion Category classifies the type and severity of erosion in a given area. Categories are often based on the nature of the erosive forces (e.g., water, wind) and the degree of soil loss, ranging from slight to severe. This classification aids in prioritizing conservation efforts and understanding the potential impacts on soil quality. Source: FAO, 'Soil Erosion and Conservation'"@en ] ;
    skos:exactMatch glosis_sp:erosionCategoryProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil erosion category"@en .

eusoilvoc:SoilErosionDegree a skos:Concept ;
    skos:broader eusoilvoc:SoilErosion ;
    skos:definition [ dcterms:source glosis_sp:erosionDegreeProperty ;
            schema:text "Soil Erosion Degree refers to the level of intensity or severity of soil erosion in an area, categorized into classes such as slight, moderate, or severe. The degree of erosion helps in assessing the extent of soil degradation and informs decisions on soil conservation and land management. Source: FAO, 'Soil Erosion and Conservation'"@en ] ;
    skos:exactMatch glosis_sp:erosionDegreeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil erosion degree"@en .

eusoilvoc:SoilErosionTotalAreaAffected a skos:Concept ;
    skos:broader eusoilvoc:SoilErosion ;
    skos:definition [ dcterms:source glosis_sp:erosionTotalAreaAffectedProperty ;
            schema:text "Soil Erosion Total Area Affected quantifies the total land area affected by erosion processes. It is an important measure in understanding the broader impact of erosion on soil health, productivity, and ecosystem services across a landscape. Source: USDA NRCS, 'Soil Erosion and Landscape Analysis'"@en ] ;
    skos:exactMatch glosis_sp:erosionTotalAreaAffectedProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil erosion total area affected"@en .

