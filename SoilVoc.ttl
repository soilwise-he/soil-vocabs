eusoilvoc:SoilMoistureContents a skos:Concept ;
    skos:altLabel "moisture content"@en,
        "soil moisture content"@en ;
    skos:broader eusoilvoc:SoilWaterPhysicalProperties ;
    skos:definition [ dcterms:source glosis_lh:moistureContentProperty ;
            schema:text "The Moisture Content measures the amount of water present in soil, expressed as a percentage of its dry weight. This property is critical for assessing soil water retention, irrigation needs, and plant-available water. Source: Hillel, D. (2004). Introduction to Environmental Soil Physics."@en ] ;
    skos:exactMatch spp:SoilMoistureContent,
        glosis_lh:moistureContentProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:narrower eusoilvoc:AntecedentSoilMoistureContents,
        eusoilvoc:DegreeOfSaturation,
        eusoilvoc:LeastLimitingWaterRange,
        eusoilvoc:LiquidRatio,
        eusoilvoc:PermanentWiltingPoint,
        eusoilvoc:SoilFieldMoistureCapacity,
        eusoilvoc:SoilGravimetricMoistureContents,
        eusoilvoc:SoilVolumetricMoistureContents ;
    skos:prefLabel "soil moisture contents"@en ;
