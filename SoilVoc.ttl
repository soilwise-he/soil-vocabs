eusoilvoc:EffectiveCEC a skos:Concept ;
    skos:broader eusoilvoc:CationExchangeCapacity ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-ECEC ;
            schema:text "ECEC is the sum of exchangeable cations in soil at its natural pH. It provides a measure of the soil’s fertility under acidic conditions, as it considers both base cations and exchangeable aluminum. Source: Brady & Weil (2017)."@en ] ;
    skos:exactMatch glosis_cl:physioChemicalPropertyCode-ECEC ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
