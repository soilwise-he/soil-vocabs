soilvoc:SoilPhysicalProperties a skos:Concept ;
    skos:altLabel "soil physical property"@en ;
    skos:broader soilvoc:SoilProperties ;
    skos:closeMatch agrovoc:c_7182 ;
    skos:definition [ dcterms:source <https://soilhealthnexus.org/resources/soil-properties/soil-physical-properties/> ;
            schema:text "Soil physical properties include both inherent and dynamic soil properties. Inherent properties include soil texture, soil parent materials and soil depth. Dynamic properties are those that can be influenced by management include infiltration, aggregate stability, available soil water holding capacity, soil organic matter, soil porosity, compaction layers, crusting, bulk density, and structure. Optimal soil physical properties reduce limitations to root growth and productivity, improve seedling emergence, nutrient and water retention, infiltration, and movement of air and water within the soil profile. Physical properties are directly related to optimal chemical and biological properties which together improve nutrient and water cycling and other key soil functions."@en ],
        [ dcterms:source <https://www.cambridge.org/core/books/properties-and-management-of-soils-in-the-tropics/soil-physical-properties/275087D91E8849FA36F347D4964ED835> ;
            schema:text "Soil physical properties are those responsible for the transport of water, solutes, air and heat in the soil. The main physical soil properties are depth, temperature, texture, structure, bulk density and water-holding capacity."@en ],
        [ dcterms:source <https://www.soils.org/publications/soils-glossary?q=publications/soils-glossary/> ;
            schema:text "Those characteristics, processes, or reactions of a soil that are caused by physical forces and that can be described by, or expressed in, physical terms or equations. Examples of physical properties are bulk density, hydraulic conductivity, porosity, pore-size distribution, etc."@en ] ;
    skos:exactMatch spp:SoilPhysicalProperty,
        she:SoilPhysicalProperties ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:narrower soilvoc:Cementation,
        soilvoc:Fragments,
        soilvoc:Gypsum,
        soilvoc:MineralConcentration,
        soilvoc:MineralParticles,
        soilvoc:Peat,
        soilvoc:SoilAdhesion,
        soilvoc:SoilAggregatePhysicalProperties,
        soilvoc:SoilAirPhysicalProperties,
        soilvoc:SoilClayMineralogy,
        soilvoc:SoilCoating,
        soilvoc:SoilCohesion,
        soilvoc:SoilCohesiveness,
        soilvoc:SoilColour,
        soilvoc:SoilCompactability,
        soilvoc:SoilCompressibility,
        soilvoc:SoilConsistence,
        soilvoc:SoilConsistency,
