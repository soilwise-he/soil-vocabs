eusoilvoc:SoilPorosity a skos:Concept ;
    skos:broader eusoilvoc:SoilPorePhysicalProperties ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Por ;
            schema:text "Porosity refers to the percentage of soil volume occupied by pores or voids, which hold air and water. It directly impacts water infiltration, drainage, and root growth. Soils with high porosity are better suited for crop cultivation, as they provide good aeration and water availability. Source: Brady & Weil (2017)."@en ] ;
    skos:exactMatch agrovoc:c_35320,
        spp:SoilPorosity,
        inrae:c_16324,
        glosis_cl:physioChemicalPropertyCode-Por,
        she:SoilPorosity ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:narrower eusoilvoc:AirFilledPorosity,
        eusoilvoc:AirPorosity,
        eusoilvoc:AirRatio,
        eusoilvoc:InterAggregatePorosity,
        eusoilvoc:IntraAggregatePorosity,
        eusoilvoc:Macroporosity,
        eusoilvoc:StructuralPorosity,
        eusoilvoc:TexturalPorosity,
        eusoilvoc:TotalPorosity,
        eusoilvoc:VoidRatio ;
    skos:prefLabel "soil porosity"@en ;
    sosa:hasProcedure eusoilvoc:porosityProcedure-Poros_calcul-pf0 .

