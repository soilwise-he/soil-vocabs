eusoilvoc:BoronTotalElements a skos:Concept ;
    skos:altLabel "boron total element"@en ;
    skos:broader eusoilvoc:Boron ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Bortot ;
            schema:text "Total boron includes all boron forms in soil, crucial for plant cell wall formation and reproductive processes. Deficiency can impair growth, while toxicity is a risk in arid soils or with excessive irrigation. Source: Havlin et al. (2014)."@en ] ;
    skos:exactMatch glosis_cl:physioChemicalPropertyCode-Bortot ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "boron total elements"@en ;
