    skos:exactMatch spp:SurfaceAggregationRatio ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "surface aggregation ratio"@en .

eusoilvoc:SurfaceRunoff a skos:Concept ;
