eusoilvoc:SoilTotalCarbon a skos:Concept ;
    skos:broader eusoilvoc:SoilComponents ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Cartot ;
            schema:text "Total carbon in soil includes both organic carbon (from plant and microbial residues) and inorganic carbon (primarily carbonates). It is a fundamental component of soil organic matter, influencing soil fertility, structure, and water retention. High carbon levels are associated with better soil health and productivity. Source: USDA NRCS."@en ] ;
    skos:exactMatch glosis_cl:physioChemicalPropertyCode-Cartot ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
