    skos:definition [ dcterms:source glosis_lh:textureFieldClassProperty ;
            schema:text "The Texture Field Class categorizes soil texture based on the relative proportions of sand, silt, and clay, as assessed by field methods like the ribbon test. Field classes include sandy loam, clay loam, etc. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:textureFieldClassProperty ;
