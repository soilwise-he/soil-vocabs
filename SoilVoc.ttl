        eusoilvoc:totalElementsProcedure-Total_tp06,
        eusoilvoc:totalElementsProcedure-Total_tp07,
        eusoilvoc:totalElementsProcedure-Total_tp08,
        eusoilvoc:totalElementsProcedure-Total_tp09,
        eusoilvoc:totalElementsProcedure-Total_tp10,
        eusoilvoc:totalElementsProcedure-Total_unkn,
        eusoilvoc:totalElementsProcedure-Total_xrd,
