eusoilvoc:SoilCarbonDensity a skos:Concept ;
    skos:broader eusoilvoc:SoilOrganicCarbon ;
    skos:definition [ dcterms:source glosis_sp:soilCarbonDensityProperty ;
            schema:text "Soil Carbon Density measures the amount of organic carbon stored in a given volume of soil, typically expressed in tons per hectare. This property is a key indicator of soil health, as organic carbon influences soil fertility, structure, and microbial activity, and plays a major role in carbon sequestration to mitigate climate change. Source: IPCC, 'Guidelines for National Greenhouse Gas Inventories'"@en ] ;
    skos:exactMatch glosis_sp:soilCarbonDensityProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil carbon density"@en .

