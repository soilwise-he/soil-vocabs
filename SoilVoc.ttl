soilvoc:SoilTexture a skos:Concept ;
    skos:broader soilvoc:SoilPhysicalProperties ;
    skos:definition [ dcterms:source glosis_cm:textureProperty ;
            schema:text "The Soil Texture refers to the relative proportions of sand, silt, and clay in a soil. It is a key indicator of the soil’s ability to retain moisture, drain water, and support root growth. Soils can be classified into textures such as sandy, loamy, or clayey, each with distinct characteristics affecting soil management. Source: Soil Science Society of America. (2008). Soil Science Glossary. Soil Science Society of America."@en ] ;
    skos:exactMatch agrovoc:c_7199,
        spp:SoilTexture,
        inrae:c_394,
        glosis_cm:textureProperty,
        gemet:7898,
        iso11074:3.476,
        she:SoilTexture ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:narrower soilvoc:SandyTexture ;
    skos:prefLabel "soil texture"@en .

