eusoilvoc:SoilPlasticity a skos:Concept ;
    skos:broader eusoilvoc:SoilPhysicalProperties ;
    skos:definition [ dcterms:source glosis_lh:plasticityProperty ;
            schema:text "The Plasticity measures the soil's ability to deform under stress without cracking or breaking, especially when wet. It is influenced by clay content and mineralogy and is important for engineering and agricultural applications. Source: Hillel, D. (2004). Introduction to Environmental Soil Physics."@en ] ;
    skos:exactMatch spp:SoilPlasticity,
        glosis_lh:plasticityProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:narrower eusoilvoc:WetPlasticity ;
    skos:prefLabel "soil plasticity"@en .

