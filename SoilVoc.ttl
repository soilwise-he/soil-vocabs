eusoilvoc:ZincTotalElements a skos:Concept ;
    skos:broader eusoilvoc:Zinc ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Zin ;
            schema:text "Zinc is a micronutrient essential for plant enzyme systems, protein synthesis, and growth regulation. Deficiency is common in calcareous soils and results in stunted growth and chlorosis. Zinc fertilizers or soil pH adjustments can address deficiencies. Source: Havlin et al. (2014)."@en ] ;
    skos:exactMatch glosis_cl:physioChemicalPropertyCode-Zin ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
