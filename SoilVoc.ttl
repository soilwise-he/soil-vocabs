soilvoc:BaseSaturation a skos:Concept,
        sosa:ObservableProperty ;
    skos:broader soilvoc:SoilChemicalProperties ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Bascal ;
            schema:text "Base saturation represents the percentage of the soil's cation exchange capacity (CEC) occupied by basic cations such as calcium (Ca²⁺), magnesium (Mg²⁺), potassium (K⁺), and sodium (Na⁺). Higher base saturation typically correlates with higher fertility and a greater ability to supply essential nutrients to plants. This parameter also influences soil pH buffering capacity. Source: Brady & Weil (2017)."@en ] ;
    skos:exactMatch agrovoc:c_dbde833c,
        glosis_cl:physioChemicalPropertyCode-Bascal,
        she:BaseSaturation ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "base saturation"@en ;
    sosa:hasProcedure soilvoc:baseSaturationProcedure-BSat_calcul-cec,
        soilvoc:baseSaturationProcedure-BSat_calcul-ecec .

