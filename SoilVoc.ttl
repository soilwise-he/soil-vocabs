soilvoc:CopperTotalElements a skos:Concept,
        sosa:ObservableProperty ;
    skos:broader soilvoc:Copper ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Coptot ;
            schema:text "Total copper comprises all soil copper, including bound and free forms. Copper is vital for plant enzyme activation and metabolic processes. Deficiencies can lead to reduced growth and yields, while excess copper may inhibit root development. Source: Soil Science Society of America."@en ] ;
