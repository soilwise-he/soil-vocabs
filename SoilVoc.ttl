eusoilvoc:CationExchangeCapacity a skos:Concept ;
    skos:broader eusoilvoc:SoilChemicalCapacity ;
    skos:definition [ dcterms:source glosis_lh:cationExchangeCapacityProperty ;
            schema:text "The Cation Exchange Capacity (CEC) measures the soil's total capacity to hold and exchange positively charged ions (cations). It is influenced by clay and organic matter content and is a critical indicator of soil fertility and nutrient retention. Source: Brady, N.C., & Weil, R.R. (2008). The Nature and Properties of Soils."@en ] ;
    skos:exactMatch agrovoc:c_24981,
        spp:CationExchangeCapacity,
        glosis_lh:cationExchangeCapacityProperty,
        she:CationExchangeCapacity ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:narrower eusoilvoc:CationExchangeCapacityEffective,
        eusoilvoc:CationExchangeCapacitySoil,
        eusoilvoc:EffectiveCEC ;
    skos:prefLabel "cation exchange capacity"@en .

eusoilvoc:CoarseFragments a skos:Concept ;
    skos:altLabel "coarse fragment"@en ;
    skos:broader eusoilvoc:SoilParticles ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-CoaFra ;
            schema:text "Coarse fragments are soil particles larger than 2 mm in diameter, such as gravel, cobbles, and stones. They affect soil porosity, water infiltration, and root penetration. Source: Soil Survey Staff (2014). Keys to Soil Taxonomy."@en ] ;
    skos:exactMatch glosis_cl:physioChemicalPropertyCode-CoaFra ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "coarse fragments"@en ;
    sosa:hasProcedure eusoilvoc:coarseFragmentsProcedure-CrsFrg_fld,
        eusoilvoc:coarseFragmentsProcedure-CrsFrg_fldcls,
        eusoilvoc:coarseFragmentsProcedure-CrsFrg_lab .

eusoilvoc:Geology a skos:Concept ;
    skos:definition [ dcterms:source glosis_sp:geologyProperty ;
            schema:text "Geology refers to the underlying geological composition of an area, including rock types, mineral content, and geological processes. The geology of a region influences soil formation, structure, fertility, and drainage properties. Source: AGI, 'Encyclopedia of Geology'"@en ] ;
    skos:exactMatch agrovoc:c_3232,
        inrae:c_11203,
        glosis_sp:geologyProperty,
        gemet:3650 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:narrower eusoilvoc:Lithology,
