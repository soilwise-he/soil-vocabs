        eusoilvoc:moistureContentProcedure-VMC_calcul-ptf-brookscorey,
        eusoilvoc:moistureContentProcedure-VMC_d,
        eusoilvoc:moistureContentProcedure-VMC_d-cl,
        eusoilvoc:moistureContentProcedure-VMC_d-cl-ww,
        eusoilvoc:moistureContentProcedure-VMC_d-ww,
        eusoilvoc:moistureContentProcedure-VMC_ud,
        eusoilvoc:moistureContentProcedure-VMC_ud-cl,
        eusoilvoc:moistureContentProcedure-VMC_ud-co .

