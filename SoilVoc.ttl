soilvoc:AvailableWaterHoldingCapacity a skos:Concept,
        sosa:ObservableProperty ;
    skos:broader soilvoc:SoilWaterHoldingCapacity ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Avavol ;
            schema:text "Available water capacity (AWC) measures the volume of water soil can retain between field capacity and the permanent wilting point. It represents the water accessible to plants for uptake. High AWC supports better plant growth, while low AWC may necessitate irrigation. Source: USDA NRCS."@en ] ;
    skos:exactMatch glosis_cl:physioChemicalPropertyCode-Avavol ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "available water holding capacity"@en ;
