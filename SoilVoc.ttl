eusoilvoc:FloodDuration a skos:Concept ;
    skos:broader eusoilvoc:Floods ;
    skos:definition [ dcterms:source glosis_sp:floodDurationProperty ;
            schema:text "Flood Duration refers to the length of time during which an area is inundated by floodwaters. The duration of flooding can significantly affect soil structure, nutrient availability, and plant growth, especially in flood-prone regions. Source: USGS, 'Floodplain Management'"@en ] ;
    skos:exactMatch glosis_sp:floodDurationProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "flood duration"@en .

eusoilvoc:FloodFrequency a skos:Concept ;
    skos:broader eusoilvoc:Floods ;
    skos:definition [ dcterms:source glosis_sp:floodFrequencyProperty ;
            schema:text "Flood Frequency refers to how often flooding occurs in a particular area, typically expressed in terms of recurrence intervals (e.g., once every 10 years). This property is vital for assessing flood risk, soil erosion, and the potential for soil nutrient loss due to repeated flooding events. Source: USGS, 'Floodplain Management'"@en ] ;
    skos:exactMatch glosis_sp:floodFrequencyProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "flood frequency"@en .

eusoilvoc:FluxControlledWaterInfiltration a skos:Concept ;
    skos:broader eusoilvoc:SoilWaterInfiltration ;
    skos:exactMatch spp:FluxControlledWaterInfiltration ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "flux controlled water infiltration"@en .

