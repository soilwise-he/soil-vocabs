soilvoc:Gypsum a skos:Concept,
        sosa:ObservableProperty ;
    skos:broader soilvoc:SoilPhysicalProperties ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Gyp ;
            schema:text "The gypsum content, expressed as weight, refers to the soil’s calcium sulfate levels. Gypsum improves soil structure, alleviates sodicity, and enhances water infiltration. It is commonly applied to saline-sodic soils for reclamation. Source: FAO Soil Bulletin."@en ] ;
    skos:exactMatch agrovoc:c_3453,
        glosis_cl:physioChemicalPropertyCode-Gyp,
        gemet:3806 ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:narrower soilvoc:GypsumContents,
        soilvoc:GypsumForms,
        soilvoc:GypsumWeight ;
