eusoilvoc:SoilDepth a skos:Concept ;
    skos:broader eusoilvoc:SoilSpatialProperties ;
    skos:definition [ dcterms:source glosis_cm:soilDepthProperty ;
            schema:text "The Soil Depth measures the vertical distance from the soil surface to an impenetrable layer, such as bedrock or a hardpan. Soil depth is a crucial factor influencing root development, water storage, and plant growth. Shallow soils may limit root growth, while deep soils can support more extensive root systems. Source: Brady, N. C., & Weil, R. R. (2008). The Nature and Properties of Soils (14th ed.). Pearson Prentice Hall."@en ] ;
    skos:exactMatch agrovoc:c_0c184d6f,
        spp:SoilDepth,
        glosis_cm:soilDepthProperty,
        she:SoilDepth ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:narrower eusoilvoc:SoilDepthBedrock,
        eusoilvoc:SoilDepthRootable,
        eusoilvoc:SoilDepthSampled ;
    skos:prefLabel "soil depth"@en .

