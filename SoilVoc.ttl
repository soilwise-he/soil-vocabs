soilvoc:MolybdenumTotalElements a skos:Concept,
        sosa:ObservableProperty ;
    skos:broader soilvoc:Molybdenum ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Mol ;
            schema:text "Molybdenum is a micronutrient essential for plant enzymes involved in nitrogen fixation and nitrate reduction. Deficiency, often observed in acidic soils, can lead to stunted growth and poor nitrogen utilization. Its availability increases with higher pH, making liming a common solution for molybdenum deficiencies. Source: Havlin et al. (2014)."@en ] ;
    skos:exactMatch glosis_cl:physioChemicalPropertyCode-Mol ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
