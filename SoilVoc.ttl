    skos:exactMatch spp:SurfaceRunoff,
        gemet:8225 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "surface runoff"@en .

eusoilvoc:Termites a skos:Concept ;
    skos:altLabel "termite"@en ;
