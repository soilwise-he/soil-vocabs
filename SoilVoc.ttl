        spp:SoilOrganicMatter,
        inrae:c_336,
        glosis_cl:physioChemicalPropertyCode-Orgmat,
        she:SoilOrganicMatter ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:narrower eusoilvoc:SoilOrganicCarbon ;
    skos:prefLabel "soil organic matter"@en ;
