    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil water transport"@en .

eusoilvoc:SoilWetness a skos:Concept ;
    skos:broader eusoilvoc:SoilWaterPhysicalProperties ;
    skos:exactMatch spp:SoilWetness ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil wetness"@en .

eusoilvoc:SolubleAnionTotal a skos:Concept ;
    skos:altLabel "soluble anions total"@en ;
    skos:broader eusoilvoc:SoilSolutes ;
    skos:definition [ dcterms:source glosis_lh:solubleAnionsTotalProperty ;
            schema:text "The Soluble Anions Total measures the concentration of anions (e.g., chloride, sulfate, nitrate) in soil solution. High levels may indicate salinity, nutrient availability, or contamination. Source: Sparks, D.L. (2003). Environmental Soil Chemistry."@en ] ;
    skos:exactMatch glosis_lh:solubleAnionsTotalProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soluble anion total"@en .

eusoilvoc:SolubleCationTotal a skos:Concept ;
    skos:altLabel "soluble cations total"@en ;
    skos:broader eusoilvoc:SoilSolutes ;
    skos:definition [ dcterms:source glosis_lh:solubleCationsTotalProperty ;
            schema:text "The Soluble Cations Total evaluates the sum of cations (e.g., sodium, potassium, calcium, magnesium) in soil solution. It is an indicator of soil salinity, fertility, and chemical balance. Source: Brady, N.C., & Weil, R.R. (2008). The Nature and Properties of Soils."@en ] ;
    skos:exactMatch glosis_lh:solubleCationsTotalProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soluble cation total"@en .

eusoilvoc:Stickiness a skos:Concept ;
    sio:equivalentTo eusoilvoc:SoilAdhesion ;
    skos:broader eusoilvoc:SoilPhysicalProperties ;
    skos:definition [ dcterms:source glosis_lh:stickinessProperty ;
            schema:text "The Stickiness measures the soil’s tendency to adhere to surfaces or objects when wet. It is influenced by clay content and organic matter and affects soil workability and machinery use. Source: Hillel, D. (2004). Introduction to Environmental Soil Physics."@en ] ;
    skos:exactMatch agrovoc:c_7409,
        glosis_lh:stickinessProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "stickiness"@en .

eusoilvoc:StickyConsistence a skos:Concept ;
    skos:broader eusoilvoc:SoilConsistence ;
    skos:exactMatch spp:StickyConsistence ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "sticky consistence"@en .

eusoilvoc:StructuralPores a skos:Concept ;
    skos:altLabel "structural pore"@en ;
    skos:broader eusoilvoc:SoilPores ;
    skos:exactMatch spp:StructuralPore ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "structural pores"@en .

eusoilvoc:StructuralPorosity a skos:Concept ;
    skos:broader eusoilvoc:SoilPorosity ;
    skos:exactMatch spp:StructuralPorosity ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "structural porosity"@en .

eusoilvoc:StructureGrade a skos:Concept ;
    skos:broader eusoilvoc:SoilStructure ;
    skos:definition [ dcterms:source glosis_lh:structureGradeProperty ;
            schema:text "The Structure Grade assesses the development and stability of soil aggregates, classified as weak, moderate, or strong. It reflects soil tilth, aeration, and resistance to erosion. Source: Soil Survey Staff (2014). Keys to Soil Taxonomy."@en ] ;
    skos:exactMatch glosis_lh:structureGradeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "structure grade"@en .

eusoilvoc:StructureSize a skos:Concept ;
    skos:broader eusoilvoc:SoilStructure ;
    skos:definition [ dcterms:source glosis_lh:structureSizeProperty ;
            schema:text "The Structure Size describes the dimensions of soil aggregates or structural units, such as granular, blocky, or platy. Structure size affects root penetration, water infiltration, and soil stability. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:structureSizeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "structure size"@en .

eusoilvoc:SupportingServices a skos:Concept ;
    skos:altLabel "supporting service"@en ;
    skos:broader eusoilvoc:EcosystemServices ;
    skos:exactMatch agrovoc:c_0f955994,
        she:SupportingServices ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "supporting services"@en .

