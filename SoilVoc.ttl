        eusoilvoc:totalElementsProcedure-Total_xtf-t .

eusoilvoc:CalciumTotalElements a skos:Concept ;
    skos:broader eusoilvoc:Calcium ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Caltot ;
            schema:text "Total calcium in soil includes all forms, from exchangeable calcium to calcium in minerals. It is essential for plant cell wall structure, enzyme activation, and soil aggregation. Calcium levels influence soil pH and nutrient availability. Source: Havlin et al. (2014)."@en ] ;
    skos:exactMatch glosis_cl:physioChemicalPropertyCode-Caltot ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "calcium total elements"@en ;
    sosa:hasProcedure eusoilvoc:totalElementsProcedure-Total_h2so4,
        eusoilvoc:totalElementsProcedure-Total_hcl,
