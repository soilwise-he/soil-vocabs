        eusoilvoc:carbonOrganicProcedure-OrgC_dc,
        eusoilvoc:carbonOrganicProcedure-OrgC_dc-ht,
        eusoilvoc:carbonOrganicProcedure-OrgC_dc-ht-analyser,
        eusoilvoc:carbonOrganicProcedure-OrgC_dc-lt,
        eusoilvoc:carbonOrganicProcedure-OrgC_dc-lt-loi,
        eusoilvoc:carbonOrganicProcedure-OrgC_dc-mt,
