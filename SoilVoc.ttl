    skos:exactMatch spp:SoilWaterTableDepth ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil water table depth"@en .

eusoilvoc:SoilWaterTablePosition a skos:Concept ;
    skos:broader eusoilvoc:SoilSpatialProperties ;
    skos:exactMatch spp:SoilWaterTablePosition ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil water table position"@en .

