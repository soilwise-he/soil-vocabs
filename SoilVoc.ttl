        soilvoc:nitrogenTotalProcedure-TotalN_kjeldahl-nh4,
        soilvoc:nitrogenTotalProcedure-TotalN_nelson,
        soilvoc:nitrogenTotalProcedure-TotalN_tn04,
        soilvoc:nitrogenTotalProcedure-TotalN_tn06,
        soilvoc:nitrogenTotalProcedure-TotalN_tn08 .

