eusoilvoc:ManganeseTotalElements a skos:Concept ;
    skos:broader eusoilvoc:Manganese ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Mantot ;
            schema:text "Total manganese refers to all forms of manganese in the soil, which is critical for photosynthesis, enzyme activation, and nitrogen metabolism in plants. Manganese deficiencies or toxicities are influenced by soil pH, with deficiencies occurring in high-pH soils and toxicities in low-pH, waterlogged soils.  Source: Brady & Weil (2017)."@en ] ;
    skos:exactMatch glosis_cl:physioChemicalPropertyCode-Mantot ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "manganese total elements"@en ;
