soilvoc:SoilHydraulicConductivity a skos:Concept,
        sosa:ObservableProperty ;
    skos:broader soilvoc:SoilWaterPhysicalProperties,
        soilvoc:SoilWaterTransmissionIndex ;
    skos:closeMatch agrovoc:c_25579 ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Hydcond ;
            schema:text "Hydraulic conductivity refers to the rate at which water moves through soil pores under a unit hydraulic gradient. It reflects the soil's ability to transmit water, influenced by texture, structure, and porosity. Soils with high hydraulic conductivity, like sandy soils, allow rapid water movement, while clayey soils exhibit slower water flow. This property is critical for understanding water infiltration, drainage, and irrigation management. Source: Brady, N.C., & Weil, R.R. (2017). The Nature and Properties of Soils."@en ] ;
    skos:exactMatch spp:SoilHydraulicConductivity,
        inrae:c_13934,
        glosis_cl:physioChemicalPropertyCode-Hydcond ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:narrower soilvoc:SaturatedHydraulicConductivity,
        soilvoc:UnsaturatedHydraulicConductivity ;
    skos:prefLabel "soil hydraulic conductivity"@en ;
    sosa:hasProcedure soilvoc:hydraulicConductivityProcedure-KSat_calcul-ptf,
        soilvoc:hydraulicConductivityProcedure-KSat_calcul-ptf-genuchten,
        soilvoc:hydraulicConductivityProcedure-KSat_calcul-ptf-saxton,
        soilvoc:hydraulicConductivityProcedure-Ksat_bhole,
        soilvoc:hydraulicConductivityProcedure-Ksat_column,
        soilvoc:hydraulicConductivityProcedure-Ksat_dblring,
        soilvoc:hydraulicConductivityProcedure-Ksat_invbhole .

