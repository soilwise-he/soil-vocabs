        soilvoc:carbonOrganicProcedure-OrgC_dc,
        soilvoc:carbonOrganicProcedure-OrgC_dc-ht,
        soilvoc:carbonOrganicProcedure-OrgC_dc-ht-analyser,
        soilvoc:carbonOrganicProcedure-OrgC_dc-lt,
        soilvoc:carbonOrganicProcedure-OrgC_dc-lt-loi,
        soilvoc:carbonOrganicProcedure-OrgC_dc-mt,
        soilvoc:carbonOrganicProcedure-OrgC_dc-spec,
