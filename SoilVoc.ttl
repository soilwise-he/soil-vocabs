    skos:exactMatch agrovoc:c_b8039965,
        spp:Termite ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "termites"@en .

eusoilvoc:TexturalPores a skos:Concept ;
