    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "residual shrinkage"@en .

eusoilvoc:Road a skos:Concept ;
    skos:broader eusoilvoc:Pavements ;
    skos:exactMatch spp:Road,
        inrae:c_21732,
        gemet:7272 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "road"@en .

eusoilvoc:RockAbundance a skos:Concept ;
    skos:broader eusoilvoc:Rock ;
    skos:definition [ dcterms:source glosis_cm:rockAbundanceProperty ;
            schema:text "The Rock Abundance refers to the proportion or percentage of rock fragments in the soil profile. High rock abundance can affect soil tillage, water retention, root penetration, and overall soil fertility. It is often used to assess land suitability for agriculture and vegetation. Source: FAO (2006). Guidelines for Soil Description (4th ed.). Food and Agriculture Organization of the United Nations."@en ] ;
    skos:exactMatch glosis_cm:rockAbundanceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "rock abundance"@en .

eusoilvoc:RockOutcropCover a skos:Concept ;
    skos:altLabel "rock outcrops cover"@en ;
    skos:broader eusoilvoc:RockOutcrops ;
    skos:definition [ dcterms:source glosis_sp:rockOutcropsCoverProperty ;
            schema:text "Rock Outcrops Cover measures the extent to which rock outcrops (exposed bedrock or rock masses) cover the landscape. The presence of rock outcrops can influence soil depth and water retention, as well as contribute to erosion and landscape stability, particularly in areas with minimal soil cover. Source: USDA NRCS, 'Soil Survey Manual'"@en ] ;
    skos:exactMatch glosis_sp:rockOutcropsCoverProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "rock outcrop cover"@en .

eusoilvoc:RockOutcropDistance a skos:Concept ;
    skos:altLabel "rock outcrops distance"@en ;
    skos:broader eusoilvoc:RockOutcrops ;
    skos:definition [ dcterms:source glosis_sp:rockOutcropsDistanceProperty ;
            schema:text "Rock Outcrops Distance quantifies the distance from a given point or area to the nearest rock outcrop. The proximity to rock outcrops can influence soil development, with areas closer to outcrops often having thinner soils and higher vulnerability to erosion. Source: FAO, 'Soil Formation and Classification'"@en ] ;
    skos:exactMatch glosis_sp:rockOutcropsDistanceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "rock outcrop distance"@en .

eusoilvoc:RockShape a skos:Concept ;
    skos:broader eusoilvoc:Rock ;
    skos:definition [ dcterms:source glosis_cm:rockShapeProperty ;
            schema:text "The Rock Shape describes the physical form of rock fragments in the soil, which can range from angular to rounded. Angular rocks are generally a sign of recent weathering, while rounded rocks have been smoothed by long-term weathering processes. The shape of rocks influences soil texture, drainage, and tillage requirements. Source: FAO (2006). Guidelines for Soil Description (4th ed.). Food and Agriculture Organization of the United Nations."@en ] ;
    skos:exactMatch glosis_cm:rockShapeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "rock shape"@en .

eusoilvoc:RockSize a skos:Concept ;
    skos:broader eusoilvoc:Rock ;
    skos:definition [ dcterms:source glosis_cm:rockSizeProperty ;
            schema:text "The Rock Size refers to the dimensions of the rock fragments present in the soil. Rocks are typically classified by their size, from small gravel to large boulders. Larger rocks can limit root growth, hinder water infiltration, and complicate soil management practices. Source: Soil Science Society of America. (2008). Soil Science Glossary. Soil Science Society of America."@en ] ;
    skos:exactMatch glosis_cm:rockSizeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "rock size"@en .

eusoilvoc:RootAbundance a skos:Concept ;
    skos:altLabel "roots abundance"@en ;
    skos:broader eusoilvoc:Roots ;
    skos:definition [ dcterms:source glosis_lh:rootsAbundanceProperty ;
            schema:text "The Roots Abundance describes the quantity of plant roots within a soil profile, typically categorized as few, common, or many. Root abundance reflects plant-soil interactions, soil fertility, and the physical structure that supports vegetation. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:rootsAbundanceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "root abundance"@en .

eusoilvoc:RootBiomass a skos:Concept ;
    skos:broader eusoilvoc:Biomass ;
    skos:exactMatch spp:RootBiomass,
        inrae:c_6400 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "root biomass"@en .

eusoilvoc:RootPresence a skos:Concept ;
    skos:altLabel "roots presence"@en ;
    skos:broader eusoilvoc:Roots ;
    skos:definition [ dcterms:source glosis_lh:rootsPresenceProperty ;
            schema:text "The Roots Presence identifies whether roots are visible in a soil profile or horizon. It indicates biological activity, soil health, and the suitability of the soil for plant growth. Roots are commonly observed during soil surveys and are classified by type and density. Source: Soil Survey Staff (2014). Keys to Soil Taxonomy."@en ] ;
    skos:exactMatch glosis_lh:rootsPresenceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "root presence"@en .

eusoilvoc:RootRespiration a skos:Concept ;
    skos:broader eusoilvoc:SoilBiologicalProcesses ;
    skos:exactMatch spp:RootRespiration,
        inrae:c_8243 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "root respiration"@en .

eusoilvoc:SOCLoss a skos:Concept ;
    skos:altLabel "SOC loss"@en ;
    skos:broader eusoilvoc:SoilThreats ;
    skos:closeMatch she:SOCLosses ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil organic carbon loss"@en .

eusoilvoc:Salinisation a skos:Concept ;
    skos:broader eusoilvoc:SoilThreats ;
    skos:closeMatch she:SoilSalinisation ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "salinisation"@en .

eusoilvoc:SaltContents a skos:Concept ;
    skos:altLabel "salt content"@en ;
    skos:broader eusoilvoc:SolubleSalts ;
    skos:definition [ dcterms:source glosis_lh:saltContentProperty ;
            schema:text "The Salt Content measures the concentration of soluble salts in soil, critical for assessing salinity. Excess salts can hinder plant growth by affecting osmotic potential, leading to reduced water uptake by roots. Source: Brady, N.C., & Weil, R.R. (2008). The Nature and Properties of Soils."@en ] ;
    skos:exactMatch glosis_lh:saltContentProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "salt contents"@en .

eusoilvoc:SaltCover a skos:Concept ;
    skos:broader eusoilvoc:Salts ;
    skos:definition [ dcterms:source glosis_su:saltCoverProperty ;
            schema:text "Salt cover refers to the accumulation of salts on the surface of the soil, often visible as a crystalline crust. This phenomenon occurs when capillary action causes soluble salts to move upwards through the soil, where they crystallize as water evaporates. Salt cover can interfere with seed germination, plant growth, and water infiltration, and is commonly found in arid and semi-arid regions with high evaporation rates. Source: Brady, N.C., & Weil, R.R. (2008). The Nature and Properties of Soils (14th ed.). Pearson Education."@en ] ;
    skos:exactMatch glosis_su:saltCoverProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "salt cover"@en .

eusoilvoc:SaltIncrustation a skos:Concept ;
    skos:broader eusoilvoc:SoilChemicalProcesses ;
    skos:exactMatch spp:SaltIncrustation ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "salt incrustation"@en .

eusoilvoc:SaltPresence a skos:Concept ;
    skos:broader eusoilvoc:Salts ;
    skos:definition [ dcterms:source glosis_su:saltPresenceProperty ;
            schema:text "The salt presence of soil refers to the concentration of soluble salts, such as sodium, calcium, and magnesium, within the soil profile. High salt levels can lead to soil salinity, negatively affecting plant growth by altering water availability and soil structure. The presence of salts is typically measured using electrical conductivity (EC) or specific ion concentration tests. Soils with high salt presence are often found in arid regions where evaporation exceeds precipitation, leading to salt accumulation at or near the surface. Source: Rhoades, J.D., & Kandiah, A. (1992). Soil Salinity Management in Agriculture. Springer."@en ] ;
    skos:exactMatch glosis_su:saltPresenceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "salt presence"@en .

eusoilvoc:SaltSieving a skos:Concept ;
    skos:broader eusoilvoc:SoilPhenomena ;
    skos:exactMatch spp:SaltSieving ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "salt sieving"@en .

eusoilvoc:SaltThickness a skos:Concept ;
    skos:broader eusoilvoc:Salts ;
    skos:definition [ dcterms:source glosis_su:saltThicknessProperty ;
            schema:text "Salt thickness refers to the depth of the soil profile at which soluble salts are present in significant concentrations. This property is particularly important in regions subject to evaporation and capillary rise, where salts accumulate near the surface or at specific depths. Salt thickness can impact soil fertility and water retention, as the concentrated salts can inhibit root growth and water uptake. This property is commonly determined through soil sampling and electrical conductivity measurements at various depths. Source: United States Salinity Laboratory Staff. (1954). Diagnosis and Improvement of Saline and Alkali Soils. U.S. Department of Agriculture Handbook No. 60."@en ] ;
    skos:exactMatch glosis_su:saltThicknessProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "salt thickness"@en .

eusoilvoc:SandyTexture a skos:Concept ;
    skos:broader eusoilvoc:SoilTexture ;
    skos:definition [ dcterms:source glosis_lh:sandyTextureProperty ;
            schema:text "The Sandy Texture refers to soil dominated by sand particles (0.05–2.0 mm in diameter). Sandy soils are well-drained, low in nutrients, and prone to drought due to poor water retention. Source: Soil Science Society of America (SSSA) Glossary."@en ] ;
    skos:exactMatch glosis_lh:sandyTextureProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "sandy texture"@en .

eusoilvoc:SaturatedHydraulicConductivity a skos:Concept ;
    skos:broader eusoilvoc:SoilHydraulicConductivity ;
    skos:exactMatch spp:SaturatedHydraulicConductivity,
        she:SaturatedHydraulicConductivity ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "saturated hydraulic conductivity"@en .

eusoilvoc:SaturatedVapourPressure a skos:Concept ;
    skos:broader eusoilvoc:SoilVapourPressure ;
    skos:exactMatch spp:SaturatedVaporPressure ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "saturated vapour pressure"@en .

eusoilvoc:SaturatedWaterFlow a skos:Concept ;
    skos:broader eusoilvoc:SoilWaterFlow ;
    skos:exactMatch spp:SaturatedWaterFlow ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "saturated water flow"@en .

eusoilvoc:Season a skos:Concept ;
    skos:broader eusoilvoc:PlanetaryPhenomena ;
    skos:exactMatch spp:Season,
        inrae:c_11384,
        gemet:7529 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "season"@en .

eusoilvoc:SeedbedPreparation a skos:Concept ;
    skos:broader eusoilvoc:SoilManagement ;
    skos:exactMatch agrovoc:c_6943,
        spp:SeedbedPreparation ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "seedbed preparation"@en .

eusoilvoc:SeedlingEmergence a skos:Concept ;
    skos:broader eusoilvoc:SoilBiologicalProcesses ;
    skos:exactMatch agrovoc:c_2547,
        spp:SeedlingEmergence,
        inrae:c_8199,
        iso11074:3.434 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "seedling emergence"@en .

eusoilvoc:SilicaSesquioxideRatio a skos:Concept ;
    skos:broader eusoilvoc:SoilErodibilityIndex ;
    skos:exactMatch spp:SilicaSesquioxideRatio ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "silica sesquioxide ratio"@en .

eusoilvoc:Silt a skos:Concept ;
    skos:broader eusoilvoc:SoilPrimaryParticles ;
    skos:exactMatch agrovoc:c_331558,
        spp:Silt,
        inrae:c_11574,
        gemet:7698 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "silt"@en .

eusoilvoc:Sleet a skos:Concept ;
    skos:broader eusoilvoc:Precipitation ;
    skos:exactMatch agrovoc:c_14332,
        spp:Sleet ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "sleet"@en .

eusoilvoc:SlopeForms a skos:Concept ;
    skos:altLabel "slope form"@en ;
    skos:broader eusoilvoc:Slope ;
    skos:definition [ dcterms:source glosis_sp:slopeFormProperty ;
            schema:text "Slope Form describes the shape or curvature of a slope, including its concave, convex, or straight profile. Slope form affects water runoff, erosion rates, and soil accumulation, influencing both the fertility and stability of the soil in hilly or mountainous regions. Source: FAO, 'Soil and Water Conservation'"@en ] ;
    skos:exactMatch glosis_sp:slopeFormProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "slope forms"@en .

eusoilvoc:SlopeGradientClass a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_sp:slopeGradientClassProperty ;
            schema:text "Slope Gradient Class refers to the classification of slope steepness, such as flat, moderate, or steep, based on its angle. The gradient of a slope influences soil erosion rates, water drainage, and the suitability of land for agriculture, with steeper slopes typically being more prone to erosion. Source: USDA NRCS, 'Soil Erosion and Conservation'"@en ] ;
    skos:exactMatch glosis_sp:slopeGradientClassProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "slope gradient class"@en .

eusoilvoc:SlopeGradientNumeric a skos:Concept ;
    skos:broader eusoilvoc:SlopeGradient ;
    skos:definition [ dcterms:source glosis_sp:slopeGradientProperty ;
            schema:text "Slope Gradient Property refers to the numerical measurement of the steepness of a slope, usually expressed as a percentage or angle. This property is crucial in determining soil erosion potential, water runoff, and suitability for land use, as steeper slopes are more prone to erosion and less suitable for cultivation without proper soil conservation measures. Source: USDA NRCS, 'Soil Erosion and Conservation'"@en ] ;
    skos:exactMatch glosis_sp:slopeGradientProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "slope gradient numeric"@en .

eusoilvoc:SlopeOrientationClass a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_sp:slopeOrientationClassProperty ;
            schema:text "Slope Orientation Class classifies the direction in which a slope faces (north, south, east, west) and can significantly affect local climate conditions, such as sunlight exposure, moisture, and temperature. For instance, south-facing slopes in the Northern Hemisphere receive more sunlight, influencing soil temperature, vegetation types, and soil moisture availability. Source: FAO, 'Soil and Water Conservation'"@en ] ;
    skos:exactMatch glosis_sp:slopeOrientationClassProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "slope orientation class"@en .

eusoilvoc:SlopeOrientationNumeric a skos:Concept ;
    skos:broader eusoilvoc:SlopeOrientation ;
    skos:definition [ dcterms:source glosis_sp:slopeOrientationProperty ;
            schema:text "Slope Orientation refers to the precise directional orientation of a slope, measured in degrees from a cardinal direction (e.g., 0° for north, 180° for south). The slope orientation impacts factors such as solar radiation, evaporation rates, and vegetation cover, all of which affect soil temperature, moisture retention, and erosion potential. Source: USDA NRCS, 'Soil Erosion and Landscape Analysis'"@en ] ;
    skos:exactMatch glosis_sp:slopeOrientationProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "slope orientation numeric"@en .

eusoilvoc:SlopePathways a skos:Concept ;
    skos:altLabel "slope pathway"@en ;
    skos:broader eusoilvoc:Slope ;
    skos:definition [ dcterms:source glosis_sp:slopePathwaysProperty ;
            schema:text "Slope Pathways identifies the natural flow paths of water, sediment, or other materials across a slope. These pathways, often defined by the topography, influence how water moves, erodes soil, and accumulates nutrients or contaminants. Understanding these pathways is critical for effective erosion control and water management in sloped areas. Source: FAO, 'Soil Erosion and Conservation'"@en ] ;
    skos:exactMatch glosis_sp:slopePathwaysProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "slope pathways"@en .

eusoilvoc:Snow a skos:Concept ;
    skos:broader eusoilvoc:Precipitation ;
    skos:exactMatch agrovoc:c_7124,
        spp:Snow,
        inrae:c_584,
        gemet:7769 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "snow"@en .

eusoilvoc:SoftConsistence a skos:Concept ;
    skos:broader eusoilvoc:SoilConsistence ;
    skos:exactMatch spp:SoftConsistence ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soft consistence"@en .

eusoilvoc:Soil a skos:Concept ;
    skos:closeMatch she:Soils ;
    skos:exactMatch agrovoc:c_7156,
        spp:Soil,
        inrae:c_1524,
        gemet:7843,
        iso11074:3.448 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil"@en ;
