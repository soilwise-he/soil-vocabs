        eusoilvoc:totalElementsProcedure-Total_tp08,
        eusoilvoc:totalElementsProcedure-Total_tp09,
        eusoilvoc:totalElementsProcedure-Total_tp10,
        eusoilvoc:totalElementsProcedure-Total_unkn,
        eusoilvoc:totalElementsProcedure-Total_xrd,
        eusoilvoc:totalElementsProcedure-Total_xrf,
        eusoilvoc:totalElementsProcedure-Total_xrf-p,
        eusoilvoc:totalElementsProcedure-Total_xtf-t .

eusoilvoc:CadmiumTotalElements a skos:Concept ;
    skos:altLabel "cadmium total element"@en ;
    skos:broader eusoilvoc:Cadmium ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Cad ;
            schema:text "Cadmium is a heavy metal present in trace amounts in soils, often introduced through industrial pollution or phosphate fertilizers. It is toxic to plants, animals, and humans even at low concentrations. Monitoring cadmium levels is crucial to ensure soil safety and reduce contamination risks in the food chain. Source: Sparks, D.L. (2003)."@en ] ;
    skos:exactMatch glosis_cl:physioChemicalPropertyCode-Cad ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "cadmium total elements"@en ;
    sosa:hasProcedure eusoilvoc:totalElementsProcedure-Total_h2so4,
        eusoilvoc:totalElementsProcedure-Total_hcl,
        eusoilvoc:totalElementsProcedure-Total_hcl-aquaregia,
