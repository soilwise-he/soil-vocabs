soilvoc:SoilOrganicCarbon a skos:Concept,
        sosa:ObservableProperty ;
    skos:broader soilvoc:SoilOrganicMatter,
        soilvoc:SoilTotalCarbon ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Carorg ;
            schema:text "Organic carbon refers to the carbon component of soil organic matter, derived from decomposed plant and microbial residues. It serves as a key energy source for soil microbes and influences nutrient cycling, soil structure, and water retention. Organic carbon is a primary indicator of soil fertility and health. Source: Brady & Weil (2017)."@en ] ;
    skos:exactMatch agrovoc:c_389fe908,
        inrae:c_13665,
        glosis_cl:physioChemicalPropertyCode-Carorg,
        she:SoilOrganicCarbon ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:narrower soilvoc:SoilCarbonDensity ;
    skos:prefLabel "soil organic carbon"@en ;
    sosa:hasProcedure soilvoc:carbonOrganicProcedure-OrgC_acid-dc,
        soilvoc:carbonOrganicProcedure-OrgC_acid-dc-ht,
        soilvoc:carbonOrganicProcedure-OrgC_acid-dc-ht-analyser,
