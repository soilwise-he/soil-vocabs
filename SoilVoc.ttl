soilvoc:SoilMoistureContents a skos:Concept,
        sosa:ObservableProperty ;
    skos:altLabel "moisture content"@en,
        "soil moisture content"@en ;
    skos:broader soilvoc:SoilWaterPhysicalProperties ;
    skos:definition [ dcterms:source glosis_lh:moistureContentProperty ;
            schema:text "The Moisture Content measures the amount of water present in soil, expressed as a percentage of its dry weight. This property is critical for assessing soil water retention, irrigation needs, and plant-available water. Source: Hillel, D. (2004). Introduction to Environmental Soil Physics."@en ] ;
    skos:exactMatch spp:SoilMoistureContent,
        glosis_lh:moistureContentProperty ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:narrower soilvoc:AntecedentSoilMoistureContents,
        soilvoc:DegreeOfSaturation,
        soilvoc:LeastLimitingWaterRange,
        soilvoc:LiquidRatio,
        soilvoc:PermanentWiltingPoint,
        soilvoc:SoilFieldMoistureCapacity,
        soilvoc:SoilGravimetricMoistureContents,
        soilvoc:SoilVolumetricMoistureContents ;
    skos:prefLabel "soil moisture contents"@en ;
    sosa:hasProcedure soilvoc:moistureContentProcedure-VMC_calcul-ptf,
        soilvoc:moistureContentProcedure-VMC_calcul-ptf-brookscorey,
        soilvoc:moistureContentProcedure-VMC_d,
        soilvoc:moistureContentProcedure-VMC_d-cl,
        soilvoc:moistureContentProcedure-VMC_d-cl-ww,
        soilvoc:moistureContentProcedure-VMC_d-ww,
