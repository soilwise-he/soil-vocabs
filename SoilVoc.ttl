eusoilvoc:SoilThreats a skos:Concept ;
    skos:altLabel "soil threat"@en ;
    skos:definition [ dcterms:source <https://soilhealthbenchmarks.eu/glossary/soil-threat/> ;
            schema:text "Soil threats are processes that could degrade (some of) the functions of soils and the services that soils provide. Examples of soil threats are: acidification, compaction, contamination (pollution), decline in soil organic matter, decline in soil biodiversity, desertification, erosion, flooding and water logging, landslides, salinization."@en ] ;
    skos:exactMatch she:SoilThreats ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:narrower eusoilvoc:SOCLoss,
        eusoilvoc:Salinisation,
        eusoilvoc:SoilAcidification,
        eusoilvoc:SoilBiodiversityLoss,
        eusoilvoc:SoilCompaction,
        eusoilvoc:SoilDegradation,
        eusoilvoc:SoilErosion,
        eusoilvoc:SoilNutrientLoss,
        eusoilvoc:SoilPollution,
        eusoilvoc:SoilSealing ;
    skos:prefLabel "soil threats"@en ;
    skos:topConceptOf <https://w3id.org/eusoilvoc> .

