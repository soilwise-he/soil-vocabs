    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil water diffusivity"@en .

eusoilvoc:SoilWaterEvapourationRate a skos:Concept ;
    skos:broader eusoilvoc:SoilWaterTransmissionIndex ;
    skos:exactMatch spp:SoilWaterEvaporationRate ;
