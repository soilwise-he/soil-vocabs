soilvoc:SoilPorosity a skos:Concept,
        sosa:ObservableProperty ;
    skos:broader soilvoc:SoilPorePhysicalProperties ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Por ;
            schema:text "Porosity refers to the percentage of soil volume occupied by pores or voids, which hold air and water. It directly impacts water infiltration, drainage, and root growth. Soils with high porosity are better suited for crop cultivation, as they provide good aeration and water availability. Source: Brady & Weil (2017)."@en ] ;
    skos:exactMatch agrovoc:c_35320,
        spp:SoilPorosity,
        inrae:c_16324,
        glosis_cl:physioChemicalPropertyCode-Por,
        she:SoilPorosity ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:narrower soilvoc:AirFilledPorosity,
        soilvoc:AirPorosity,
        soilvoc:AirRatio,
        soilvoc:InterAggregatePorosity,
        soilvoc:IntraAggregatePorosity,
        soilvoc:Macroporosity,
        soilvoc:StructuralPorosity,
        soilvoc:TexturalPorosity,
        soilvoc:TotalPorosity,
        soilvoc:VoidRatio ;
    skos:prefLabel "soil porosity"@en ;
