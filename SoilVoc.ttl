eusoilvoc:SoilInorganicCarbon a skos:Concept ;
    skos:broader eusoilvoc:SoilInorganicComponents,
        eusoilvoc:SoilTotalCarbon ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Carinorg ;
            schema:text "Inorganic carbon in soil primarily consists of carbonates like calcium carbonate and magnesium carbonate. It contributes to soil pH buffering and is a significant feature of arid and calcareous soils. Excess inorganic carbon can immobilize certain nutrients, requiring careful management in agricultural systems. Source: Soil Science Society of America."@en ] ;
    skos:exactMatch glosis_cl:physioChemicalPropertyCode-Carinorg ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil inorganic carbon"@en ;
    sosa:hasProcedure eusoilvoc:carbonInorganicProcedure-InOrgC_calcul-caco3,
        eusoilvoc:carbonInorganicProcedure-InOrgC_calcul-tc-oc .

