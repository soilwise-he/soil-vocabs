soilvoc:SoilWaterInfiltrationRateClass a skos:Concept ;
    skos:broader soilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_cm:infiltrationRateClassProperty ;
            schema:text "The Soil Water Infiltration Rate Class classifies the soil’s ability to absorb water based on observed infiltration rates. This classification is typically divided into categories like slow, moderate, or rapid infiltration, based on how quickly water is absorbed into the soil. It is an essential property for understanding drainage, runoff, and irrigation needs. Source: Hillel, D. (2004). Introduction to Soil Physics. Academic Press."@en ] ;
    skos:exactMatch glosis_cm:infiltrationRateClassProperty ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "soil water infiltration rate class"@en .

soilvoc:SoilWaterInfiltrationRateNumeric a skos:Concept ;
    skos:broader soilvoc:SoilWaterInfiltrationRate ;
    skos:definition [ dcterms:source glosis_cm:infiltrationRateNumericProperty ;
            schema:text "The Soil Water Infiltration Rate Numeric provides a quantitative measure of the rate at which water enters the soil, usually expressed in units such as millimeters per hour (mm/h). This numeric value is essential for determining soil permeability, irrigation management, and runoff prediction. Higher infiltration rates indicate well-drained soils, while lower rates suggest compacted or clay-rich soils. Source: Bouwer, H. (2000). Integrated Water Management for the 21st Century. Water Resources Research."@en ] ;
    skos:exactMatch glosis_cm:infiltrationRateNumericProperty ;
    skos:inScheme <https://soilwise-he.github.io/soil-vocabs> ;
    skos:prefLabel "soil water infiltration rate numeric"@en .

soilvoc:SoilWaterLoss a skos:Concept ;
