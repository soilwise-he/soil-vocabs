eusoilvoc:ManganeseExchangeableBases a skos:Concept ;
    skos:altLabel "manganese exchangeable base"@en ;
    skos:broader eusoilvoc:Manganese ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Mantot ;
            schema:text "Total manganese refers to all forms of manganese in the soil, which is critical for photosynthesis, enzyme activation, and nitrogen metabolism in plants. Manganese deficiencies or toxicities are influenced by soil pH, with deficiencies occurring in high-pH soils and toxicities in low-pH, waterlogged soils.  Source: Brady & Weil (2017)."@en ] ;
    skos:exactMatch glosis_cl:physioChemicalPropertyCode-Mantot ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "manganese exchangeable bases"@en ;
    sosa:hasProcedure eusoilvoc:exchangeableBasesProcedure-ExchBases_ph-unkn-edta,
        eusoilvoc:exchangeableBasesProcedure-ExchBases_ph-unkn-m3,
        eusoilvoc:exchangeableBasesProcedure-ExchBases_ph-unkn-m3-spec,
        eusoilvoc:exchangeableBasesProcedure-ExchBases_ph0-cohex,
        eusoilvoc:exchangeableBasesProcedure-ExchBases_ph0-nh4cl,
        eusoilvoc:exchangeableBasesProcedure-ExchBases_ph7-nh4oac,
        eusoilvoc:exchangeableBasesProcedure-ExchBases_ph7-nh4oac-aas,
        eusoilvoc:exchangeableBasesProcedure-ExchBases_ph7-nh4oac-fp,
        eusoilvoc:exchangeableBasesProcedure-ExchBases_ph7-unkn,
        eusoilvoc:exchangeableBasesProcedure-ExchBases_ph8-bacl2tea,
        eusoilvoc:exchangeableBasesProcedure-ExchBases_ph8-unkn .

eusoilvoc:NitrogenTotal a skos:Concept ;
    skos:broader eusoilvoc:Nitrogen ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Nittot ;
            schema:text "Total nitrogen encompasses all nitrogen forms in soil, including organic nitrogen in humus and inorganic nitrogen such as ammonium (NH₄⁺) and nitrate (NO₃⁻). Nitrogen is essential for plant growth, being a vital component of amino acids, proteins, and chlorophyll. Total nitrogen is a key indicator of soil fertility and its capacity to sustain long-term crop productivity. Source: Brady & Weil (2017)."@en ] ;
    skos:exactMatch glosis_cl:physioChemicalPropertyCode-Nittot ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "nitrogen total"@en ;
    sosa:hasProcedure eusoilvoc:nitrogenTotalProcedure-TotalN_bremner,
        eusoilvoc:nitrogenTotalProcedure-TotalN_calcul,
        eusoilvoc:nitrogenTotalProcedure-TotalN_calcul-oc10,
