eusoilvoc:PhosphorusTotalElements a skos:Concept ;
    skos:broader eusoilvoc:Phosphorus ;
    skos:definition [ dcterms:source glosis_cl:physioChemicalPropertyCode-Photot ;
            schema:text "Total phosphorus includes all forms of phosphorus in the soil, both organic and inorganic. While only a fraction is plant-available, total phosphorus serves as a long-term reserve for crop nutrition. Adequate phosphorus levels are crucial for energy transfer, photosynthesis, and root development in plants. Source: Soil Chemistry by Bohn et al."@en ] ;
    skos:exactMatch glosis_cl:physioChemicalPropertyCode-Photot ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
