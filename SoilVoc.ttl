    skos:exactMatch spp:SoilWaterCondensation ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "soil water condensation"@en .

eusoilvoc:SoilWaterConductivity a skos:Concept ;
    skos:broader eusoilvoc:SoilWaterPhysicalProperties ;
    skos:exactMatch spp:SoilWaterConductivity ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
