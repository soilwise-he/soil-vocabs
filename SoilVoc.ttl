eusoilvoc:AerationPorosity a skos:Concept ;
    skos:broader eusoilvoc:SoilPorosityIndex ;
    skos:exactMatch spp:AerationPorosity ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "aeration porosity"@en .

