eusoilvoc:Irrigation a skos:Concept ;
    skos:broader eusoilvoc:SoilManagement ;
    skos:exactMatch agrovoc:c_3954,
        spp:Irrigation,
        inrae:c_3899,
        gemet:4505 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "irrigation"@en .

eusoilvoc:KoeppenClass a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_sp:koeppenClassProperty ;
            schema:text "Koeppen Class refers to the classification of climate zones based on temperature and precipitation patterns, as defined by the Köppen climate classification system. This classification directly influences soil temperature, moisture content, and vegetation types, which in turn affect soil formation and properties. Source: Köppen, W., 'Geiger's Climate Maps'"@en ] ;
    skos:exactMatch glosis_sp:koeppenClassProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "koeppen class"@en .

eusoilvoc:LabileSolutes a skos:Concept ;
    skos:altLabel "labile solute"@en ;
    skos:broader eusoilvoc:NonconservativeSolutes ;
    skos:exactMatch spp:LabileSolute ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "labile solutes"@en .

eusoilvoc:LandUseBareCover a skos:Concept ;
    skos:broader eusoilvoc:LandUse ;
    skos:definition [ dcterms:source glosis_sp:bareCoverAbundanceProperty ;
            schema:text "Bare Cover Abundance refers to the extent of land area without vegetation or artificial cover, such as bare soil or rocky surfaces. High proportions of bare cover increase the risk of soil erosion and desertification, particularly in areas with poor vegetation or human disturbance. Source: FAO, 'Land Use and Land Cover Classification'"@en ] ;
    skos:exactMatch glosis_sp:bareCoverAbundanceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "land use bare cover"@en .

eusoilvoc:LandUseClass a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source glosis_sp:landUseClassProperty ;
            schema:text "Land Use Class refers to the classification of land based on its primary use, such as agricultural, industrial, urban, or natural areas. This property helps assess the impact of land management practices on soil quality, including erosion risks, compaction, and fertility, and is critical for sustainable land-use planning. Source: FAO, 'Land Use and Land Cover Classification'"@en ] ;
    skos:exactMatch glosis_sp:landUseClassProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "land use class"@en .

eusoilvoc:LandUseForests a skos:Concept ;
    skos:altLabel "land use forest"@en ;
    skos:broader eusoilvoc:LandUse ;
    skos:definition [ dcterms:source glosis_sp:forestAbundanceProperty ;
            schema:text "Forest Abundance refers to the proportion or extent of land covered by forest vegetation in a given area. It is often quantified as the percentage of land area dominated by tree species, reflecting the ecological importance of forests in influencing soil fertility, moisture retention, and biodiversity. Forested areas typically contribute to soil formation and stabilization through leaf litter and root systems that reduce erosion. Source: FAO, 'Forest Resources Assessment'"@en ] ;
    skos:exactMatch glosis_sp:forestAbundanceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "land use forests"@en .

eusoilvoc:LandUseGrasses a skos:Concept ;
    skos:altLabel "land use grass"@en ;
    skos:broader eusoilvoc:LandUse ;
    skos:definition [ dcterms:source glosis_sp:grassAbundanceProperty ;
            schema:text "Grass Abundance indicates the extent or percentage of land covered by grasses or herbaceous plants. This property is important for understanding land productivity, grazing capacity, and soil health, as grasses play a key role in preventing soil erosion, enhancing organic matter content, and maintaining soil structure. Source: FAO, 'Grassland Ecosystems and Management'"@en ] ;
    skos:exactMatch glosis_sp:grassAbundanceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "land use grasses"@en .

eusoilvoc:LandUseShrubs a skos:Concept ;
    skos:altLabel "land use shrub"@en ;
    skos:broader eusoilvoc:LandUse ;
    skos:definition [ dcterms:source glosis_sp:shrubsAbundanceProperty ;
            schema:text "Shrubs Abundance refers to the extent or abundance of shrub vegetation in a given area. Shrubs influence soil structure by reducing erosion, improving soil organic matter through leaf litter, and enhancing nutrient cycling. They are also indicators of ecosystem health in many terrestrial environments. Source: FAO, 'Vegetation and Land Use in Arid Zones'"@en ] ;
    skos:exactMatch glosis_sp:shrubsAbundanceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "land use shrubs"@en .

eusoilvoc:LandformComplex a skos:Concept ;
    skos:broader eusoilvoc:Physiography ;
    skos:definition [ dcterms:source glosis_sp:landformComplexProperty ;
            schema:text "Landform Complex describes a region with multiple interrelated landforms such as ridges, valleys, and hills. This property is essential for understanding how diverse landforms within a landscape influence soil distribution, water flow, and erosion patterns, ultimately affecting soil management strategies. Source: FAO, 'Soil Formation and Classification'"@en ] ;
    skos:exactMatch glosis_sp:landformComplexProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "landform complex"@en .

eusoilvoc:LiquidConsistence a skos:Concept ;
    skos:broader eusoilvoc:SoilConsistence ;
    skos:exactMatch spp:LiquidConsistence ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "liquid consistence"@en .

eusoilvoc:LiquidRatio a skos:Concept ;
    skos:broader eusoilvoc:SoilMoistureContents ;
    skos:exactMatch spp:LiquidRatio ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "liquid ratio"@en .

eusoilvoc:LiquidWasteDisposal a skos:Concept ;
    skos:broader eusoilvoc:WasteDisposal ;
    skos:exactMatch spp:LiquidWasteDisposal ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "liquid waste disposal"@en .

eusoilvoc:Lithology a skos:Concept ;
    skos:broader eusoilvoc:Geology ;
    skos:closeMatch agrovoc:c_5748 ;
    skos:definition [ dcterms:source glosis_sp:lithologyProperty ;
            schema:text "Lithology refers to the physical characteristics of the parent material, such as the mineral composition, texture, and structure of the underlying rocks or sediments. The lithology of an area influences soil formation by affecting drainage, nutrient content, and the ability of the soil to support vegetation. Source: AGI, 'Encyclopedia of Geology'"@en ] ;
    skos:exactMatch inrae:c_11570,
        glosis_sp:lithologyProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "lithology"@en .

eusoilvoc:LongitudinalDispersion a skos:Concept ;
    skos:broader eusoilvoc:SoilSoluteDispersiveTransport ;
    skos:exactMatch spp:LongitudinalDispersion ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "longitudinal dispersion"@en .

eusoilvoc:Macroporosity a skos:Concept ;
    skos:broader eusoilvoc:SoilPorosity ;
    skos:exactMatch spp:Macroporosity,
        inrae:c_5012 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "macroporosity"@en .

eusoilvoc:MajorLandForms a skos:Concept ;
    skos:altLabel "major land form"@en ;
    skos:broader eusoilvoc:Physiography ;
    skos:definition [ dcterms:source glosis_sp:majorLandFormProperty ;
            schema:text "Major Land Form refers to the significant physical features of the land, such as mountains, valleys, and plateaus, that influence soil development and landscape processes. These landforms shape the flow of water, sediment transport, and nutrient cycling, directly affecting the types of soils that form in different regions. Source: FAO, 'World Soil Resources Report'"@en ] ;
    skos:exactMatch glosis_sp:majorLandFormProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "major land forms"@en .

eusoilvoc:MatrixPores a skos:Concept ;
    skos:altLabel "matrix pore"@en ;
    skos:broader eusoilvoc:SoilPores ;
    skos:exactMatch spp:MatrixPore ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "matrix pores"@en .

eusoilvoc:MeanWeightDiametre a skos:Concept ;
    skos:broader eusoilvoc:SoilAggregationIndex ;
    skos:exactMatch spp:MeanWeightDiameter ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mean weight diametre"@en .

eusoilvoc:MechanicalRatio a skos:Concept ;
    skos:broader eusoilvoc:SoilStructureIndirectIndex ;
    skos:exactMatch spp:MechanicalRatio ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mechanical ratio"@en .

eusoilvoc:MediumSand a skos:Concept ;
    skos:broader eusoilvoc:Sand ;
    skos:exactMatch agrovoc:c_7b64842d,
        spp:MediumSand ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "medium sand"@en .

eusoilvoc:Microbes a skos:Concept ;
    skos:altLabel "microbe"@en ;
    skos:broader eusoilvoc:SoilOrganisms ;
    skos:closeMatch agrovoc:c_4807 ;
    skos:exactMatch spp:Microbe,
        she:Microbes ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "microbes"@en .

eusoilvoc:Microorganisms a skos:Concept ;
    skos:altLabel "microorganism"@en ;
    skos:broader eusoilvoc:SoilOrganisms ;
    skos:exactMatch agrovoc:c_4807,
        she:Microorganisms ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "microorganisms"@en .

eusoilvoc:MineralConcAbundance a skos:Concept ;
    skos:broader eusoilvoc:MineralConcentration ;
    skos:definition [ dcterms:source glosis_lh:mineralConcAbundanceProperty ;
            schema:text "The Mineral Concentration Abundance evaluates the amount of specific minerals, such as quartz, feldspar, or mica, in the soil. This property provides insights into soil parent material and fertility. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:mineralConcAbundanceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mineral conc abundance"@en .

eusoilvoc:MineralConcColour a skos:Concept ;
    skos:broader eusoilvoc:MineralConcentration ;
    skos:definition [ dcterms:source glosis_lh:mineralConcColourProperty ;
            schema:text "The Mineral Concentration Colour describes the color of concentrated mineral deposits in the soil, such as iron oxides (red) or manganese nodules (black). It helps identify soil processes like oxidation or leaching. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:mineralConcColourProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mineral conc colour"@en .

eusoilvoc:MineralConcHardness a skos:Concept ;
    skos:broader eusoilvoc:MineralConcentration ;
    skos:definition [ dcterms:source glosis_lh:mineralConcHardnessProperty ;
            schema:text "The Mineral Concentration Hardness assesses the physical hardness of mineral deposits in soil. Hardness influences soil strength and resistance to erosion or mechanical disruption. Source: Sparks, D.L. (2003). Environmental Soil Chemistry."@en ] ;
    skos:exactMatch glosis_lh:mineralConcHardnessProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mineral conc hardness"@en .

eusoilvoc:MineralConcKind a skos:Concept ;
    skos:broader eusoilvoc:MineralConcentration ;
    skos:definition [ dcterms:source glosis_lh:mineralConcKindProperty ;
            schema:text "The Mineral Concentration Kind identifies the specific type of mineral concentrations found in soil, such as gypsum, calcite, or hematite. This classification aids in understanding soil genesis and chemistry. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:mineralConcKindProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mineral conc kind"@en .

eusoilvoc:MineralConcNature a skos:Concept ;
    skos:broader eusoilvoc:MineralConcentration ;
    skos:definition [ dcterms:source glosis_lh:mineralConcNatureProperty ;
            schema:text "The Mineral Concentration Nature examines the origin and composition of concentrated minerals in soil. It provides clues about weathering, leaching, and other pedogenic processes. Source: Soil Survey Staff (2014). Keys to Soil Taxonomy."@en ] ;
    skos:exactMatch glosis_lh:mineralConcNatureProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mineral conc nature"@en .

eusoilvoc:MineralConcShape a skos:Concept ;
    skos:broader eusoilvoc:MineralConcentration ;
    skos:definition [ dcterms:source glosis_lh:mineralConcShapeProperty ;
            schema:text "The Mineral Concentration Shape describes the physical shape of mineral accumulations, such as rounded, angular, or irregular. These shapes help infer soil formation processes and transport history. Source: Brady, N.C., & Weil, R.R. (2008). The Nature and Properties of Soils."@en ] ;
    skos:exactMatch glosis_lh:mineralConcShapeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mineral conc shape"@en .

eusoilvoc:MineralConcSize a skos:Concept ;
    skos:broader eusoilvoc:MineralConcentration ;
    skos:definition [ dcterms:source glosis_lh:mineralConcSizeProperty ;
            schema:text "The Mineral Concentration Size measures the dimensions of concentrated mineral deposits in soil, typically expressed in millimeters. Size categories range from small grains to large nodules or concretions. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:mineralConcSizeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mineral conc size"@en .

eusoilvoc:MineralConcVolume a skos:Concept ;
    skos:broader eusoilvoc:MineralConcentration ;
    skos:definition [ dcterms:source glosis_lh:mineralConcVolumeProperty ;
            schema:text "The Mineral Concentration Volume quantifies the proportion of soil volume occupied by mineral concentrations. It is used to assess the impact of these materials on soil structure and permeability. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:mineralConcVolumeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mineral conc volume"@en .

eusoilvoc:MineralContents a skos:Concept ;
    skos:altLabel "mineral content"@en ;
    skos:broader eusoilvoc:MineralParticles ;
    skos:definition [ dcterms:source glosis_lh:mineralContentProperty ;
            schema:text "The Mineral Content evaluates the overall abundance of mineral particles in soil, including sand, silt, and clay fractions. It provides essential information about soil texture, fertility, and parent material. Source: Hillel, D. (2004). Introduction to Environmental Soil Physics."@en ] ;
    skos:exactMatch glosis_lh:mineralContentProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mineral contents"@en .

eusoilvoc:MineralFragments a skos:Concept ;
    skos:altLabel "mineral fragment"@en ;
    skos:broader eusoilvoc:MineralParticles ;
    skos:definition [ dcterms:source glosis_lh:mineralFragmentsProperty ;
            schema:text "The Mineral Fragments refers to the presence and characteristics of coarse mineral particles (e.g., gravel, pebbles, stones) in the soil. These fragments influence soil drainage, root penetration, and overall physical structure. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:mineralFragmentsProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mineral fragments"@en .

eusoilvoc:Mist a skos:Concept ;
    skos:broader eusoilvoc:Precipitation ;
    skos:exactMatch spp:Mist,
        gemet:3348 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mist"@en .

eusoilvoc:ModulusOfRupture a skos:Concept ;
    skos:broader eusoilvoc:SoilStrengthIndex ;
    skos:exactMatch spp:ModulusOfRupture ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "modulus of rupture"@en .

eusoilvoc:MoistConsistency a skos:Concept ;
    skos:broader eusoilvoc:SoilConsistency ;
    skos:definition [ dcterms:source glosis_lh:moistConsistencyProperty ;
            schema:text "The Moist Consistency evaluates the soil's behavior under pressure when moist. Categories include friable, firm, or plastic. It provides insights into soil workability and its ability to support plant growth. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:moistConsistencyProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "moist consistency"@en .

eusoilvoc:MottleAbundance a skos:Concept ;
    skos:altLabel "mottles abundance"@en ;
    skos:broader eusoilvoc:SoilMottle ;
    skos:definition [ dcterms:source glosis_lh:mottlesAbundanceProperty ;
            schema:text "The Mottles Abundance describes the frequency of mottling (spots of contrasting color) in soil horizons. Mottling indicates variations in soil aeration, drainage, or water saturation. Abundance is typically classified as few, common, or many. Source: Soil Survey Staff (2014). Keys to Soil Taxonomy."@en ] ;
    skos:exactMatch glosis_lh:mottlesAbundanceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mottle abundance"@en .

eusoilvoc:MottleBoundaryClassification a skos:Concept ;
    skos:altLabel "mottles boundary classification"@en ;
    skos:broader eusoilvoc:SoilMottle ;
    skos:definition [ dcterms:source glosis_lh:mottlesBoundaryClassificationProperty ;
            schema:text "The Mottles Boundary Classification assesses the sharpness and distinctness of boundaries between mottled and non-mottled areas within the soil. It provides clues about soil processes such as oxidation-reduction reactions. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:mottlesBoundaryClassificationProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mottle boundary classification"@en .

eusoilvoc:MottleColour a skos:Concept ;
    skos:altLabel "mottles colour"@en ;
    skos:broader eusoilvoc:SoilMottle ;
    skos:definition [ dcterms:source glosis_lh:mottlesColourProperty ;
            schema:text "The Mottles Colour evaluates the color of soil mottles, often indicative of oxidation states of iron or manganese. For example, reddish colors suggest oxidation, while gray colors indicate reduction and poor drainage. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:mottlesColourProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mottle colour"@en .

eusoilvoc:MottleContrast a skos:Concept ;
    skos:altLabel "mottles contrast"@en ;
    skos:broader eusoilvoc:SoilMottle ;
    skos:definition [ dcterms:source glosis_lh:mottlesContrastProperty ;
            schema:text "The Mottles Contrast measures the visual distinction between mottles and the surrounding soil matrix. High contrast indicates stark differences, often linked to fluctuating water tables or drainage issues. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:mottlesContrastProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mottle contrast"@en .

eusoilvoc:MottlePresence a skos:Concept ;
    skos:altLabel "mottles presence"@en ;
    skos:broader eusoilvoc:SoilMottle ;
    skos:definition [ dcterms:source glosis_lh:mottlesPresenceProperty ;
            schema:text "The Mottles Presence refers to the existence of mottles in soil, often signaling periodic water saturation, drainage problems, or fluctuating redox conditions. This property is essential for wetland delineation and soil health assessment. Source: Soil Survey Staff (2014). Keys to Soil Taxonomy."@en ] ;
    skos:exactMatch glosis_lh:mottlesPresenceProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mottle presence"@en .

eusoilvoc:MottleSize a skos:Concept ;
    skos:altLabel "mottles size"@en ;
    skos:broader eusoilvoc:SoilMottle ;
    skos:definition [ dcterms:source glosis_lh:mottlesSizeProperty ;
            schema:text "The Mottles Size describes the dimensions of soil mottles, typically classified as fine, medium, or coarse. The size reflects the intensity and scale of soil processes such as oxidation and reduction. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:mottlesSizeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mottle size"@en .

eusoilvoc:MulchFarming a skos:Concept ;
    skos:broader eusoilvoc:SoilManagement ;
    skos:exactMatch spp:MulchFarming ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mulch farming"@en .

eusoilvoc:Mulching a skos:Concept ;
    skos:broader eusoilvoc:SoilManagement ;
    skos:exactMatch agrovoc:c_4978,
        spp:Mulching,
        inrae:c_1940 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "mulching"@en .

eusoilvoc:NoTill a skos:Concept ;
    skos:broader eusoilvoc:SoilManagement ;
    skos:exactMatch spp:NoTill ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "no till"@en .

eusoilvoc:NonMatrixPores a skos:Concept ;
    skos:altLabel "non matrix pore"@en ;
    skos:broader eusoilvoc:SoilPores ;
    skos:exactMatch spp:NonMatrixPore ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "non matrix pores"@en .

eusoilvoc:NormalShrinkage a skos:Concept ;
    skos:broader eusoilvoc:SoilShrinkage ;
    skos:exactMatch spp:NormalShrinkage ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "normal shrinkage"@en .

eusoilvoc:NutrientBufferingCapacity a skos:Concept ;
    skos:broader eusoilvoc:SoilFunctionIndicators ;
    skos:exactMatch she:NutrientBufferingCapacity ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "nutrient buffering capacity"@en .

eusoilvoc:NutrientDynamics a skos:Concept ;
    skos:altLabel "nutrient dynamic"@en ;
    skos:broader eusoilvoc:SoilFunctions ;
    skos:exactMatch she:NutrientDynamics ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "nutrient dynamics"@en .

eusoilvoc:NutrientMobilisationCapacity a skos:Concept ;
    skos:broader eusoilvoc:SoilFunctionIndicators ;
    skos:exactMatch she:NutrientMobilisationCapacity ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "nutrient mobilisation capacity"@en .

eusoilvoc:OverlandFlow a skos:Concept ;
    skos:broader eusoilvoc:WaterInterchange ;
    skos:exactMatch spp:OverlandFlow ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "overland flow"@en .

eusoilvoc:OxalateExtractableOpticalDensity a skos:Concept ;
    skos:broader eusoilvoc:SoilChemicalProperties ;
    skos:definition [ dcterms:source glosis_lh:oxalateExtractableOpticalDensityProperty ;
            schema:text "The Oxalate Extractable Optical Density measures the concentration of poorly crystalline forms of iron, aluminum, and organic matter in soil, often associated with volcanic soils. It is determined using ammonium oxalate extraction. Source: Sparks, D.L. (2003). Environmental Soil Chemistry."@en ] ;
    skos:exactMatch glosis_lh:oxalateExtractableOpticalDensityProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "oxalate extractable optical density"@en .

eusoilvoc:ParentDeposition a skos:Concept ;
    skos:broader eusoilvoc:ParentMaterial ;
    skos:definition [ dcterms:source glosis_sp:parentDepositionProperty ;
            schema:text "Parent Deposition refers to the accumulation of materials, such as sediments or volcanic ash, that contribute to soil formation. These parent materials are deposited through natural processes such as erosion, weathering, or sediment transport, influencing soil texture, nutrient content, and water retention properties. Source: USDA NRCS, 'Soil Genesis and Classification'"@en ] ;
    skos:exactMatch glosis_sp:parentDepositionProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "parent deposition"@en .

eusoilvoc:ParentLithology a skos:Concept ;
    skos:broader eusoilvoc:ParentMaterial ;
    skos:definition [ dcterms:source glosis_sp:parentLithologyProperty ;
            schema:text "Parent Lithology is the specific geological composition of the parent material (e.g., bedrock or sediment) from which the soil develops. The mineral content and texture of this material directly affect the physical and chemical properties of the soil, such as fertility, permeability, and soil depth. Source: USDA NRCS, 'Soil Genesis and Classification'"@en ] ;
    skos:exactMatch glosis_sp:parentLithologyProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "parent lithology"@en .

eusoilvoc:ParentTextureUnconsolidated a skos:Concept ;
    skos:broader eusoilvoc:ParentMaterial ;
    skos:definition [ dcterms:source glosis_sp:parentTextureUnconsolidatedProperty ;
            schema:text "Parent Texture Unconsolidated refers to the texture of the unconsolidated parent material, such as loose sediments or debris, that has not been solidified into rock. This texture affects soil properties such as aeration, drainage, and root penetration, as well as its ability to retain nutrients. Source: USDA NRCS, 'Soil Genesis and Classification'"@en ] ;
    skos:exactMatch glosis_sp:parentTextureUnconsolidatedProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "parent texture unconsolidated"@en .

eusoilvoc:ParticleSizeFractionSum a skos:Concept ;
    skos:broader eusoilvoc:SoilParticlePhysicalProperties ;
    skos:definition [ dcterms:source glosis_lh:particleSizeFractionsSumProperty ;
            schema:text "The Particle Size Fractions Sum refers to the total proportion of sand, silt, and clay particles in soil, expressed as a percentage. It ensures the sum of individual particle size fractions adds up to 100%, a check for accurate soil texture analysis. Particle size distribution impacts water retention, permeability, and soil structure. Source: Hillel, D. (2004). Introduction to Environmental Soil Physics."@en ] ;
    skos:exactMatch glosis_lh:particleSizeFractionsSumProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "particle size fraction sum"@en .

eusoilvoc:PavementStability a skos:Concept ;
    skos:broader eusoilvoc:SoilEngineeringFunctions ;
    skos:exactMatch spp:PavementStability ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "pavement stability"@en .

eusoilvoc:PeatDecompostion a skos:Concept ;
    skos:broader eusoilvoc:Peat ;
    skos:definition [ dcterms:source glosis_lh:peatDecompostionProperty ;
            schema:text "The Peat Decomposition evaluates the degree of decomposition in organic soils or peat. Categories include fibric (least decomposed), hemic (moderately decomposed), and sapric (highly decomposed), which influence soil fertility and drainage. Source: Soil Survey Manual (USDA, 2017)."@en ] ;
    skos:exactMatch glosis_lh:peatDecompostionProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "peat decompostion"@en .

eusoilvoc:PeatDrainage a skos:Concept ;
    skos:broader eusoilvoc:Peat ;
    skos:definition [ dcterms:source glosis_lh:peatDrainageProperty ;
            schema:text "The Peat Drainage assesses the water removal capacity in peat soils, essential for determining their suitability for agriculture, conservation, or other uses. Poorly drained peat often accumulates organic material due to low decomposition rates. Source: FAO (2006). Guidelines for Soil Description."@en ] ;
    skos:exactMatch glosis_lh:peatDrainageProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "peat drainage"@en .

eusoilvoc:PeatVolume a skos:Concept ;
    skos:broader eusoilvoc:Peat ;
    skos:definition [ dcterms:source glosis_lh:peatVolumeProperty ;
            schema:text "The Peat Volume quantifies the proportion of peat material in a given soil volume. It is critical for land use planning, carbon sequestration assessments, and wetland management. Source: Soil Survey Staff (2014). Keys to Soil Taxonomy."@en ] ;
    skos:exactMatch glosis_lh:peatVolumeProperty ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "peat volume"@en .

eusoilvoc:PercentWaterStableAggregation a skos:Concept ;
    skos:broader eusoilvoc:SoilAggregationIndex ;
    skos:exactMatch spp:PercentWaterStableAggregation ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "percent water stable aggregation"@en .

eusoilvoc:Percolation a skos:Concept ;
    skos:broader eusoilvoc:WaterInterchange ;
    skos:exactMatch spp:Percolation,
        inrae:c_13237 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:prefLabel "percolation"@en .

