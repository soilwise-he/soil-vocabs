    skos:broader eusoilvoc:SoilBiota ;
    skos:exactMatch agrovoc:c_926,
        spp:Biomass,
        inrae:c_432,
        gemet:883,
        iso11074:3.49 ;
    skos:inScheme <https://w3id.org/eusoilvoc> ;
    skos:narrower eusoilvoc:RootBiomass,
        eusoilvoc:SoilMicrobialBiomass ;
    skos:prefLabel "biomass"@en .

