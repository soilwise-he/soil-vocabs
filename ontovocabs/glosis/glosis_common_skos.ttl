@prefix glosis_cm: <http://w3id.org/glosis/model/common/> .
@prefix she: <https://soilwise-he.github.io/soil-health#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

she:BleachedSand a skos:Concept ;
    skos:exactMatch glosis_cm:bleachedSandProperty ;
    skos:prefLabel "bleached sand"@en .

she:ColourDry a skos:Concept ;
    skos:exactMatch glosis_cm:colourDryProperty ;
    skos:prefLabel "colour dry"@en .

she:ColourMoist a skos:Concept ;
    skos:exactMatch glosis_cm:colourMoistProperty ;
    skos:prefLabel "colour moist"@en .

she:CracksDepth a skos:Concept ;
    skos:exactMatch glosis_cm:cracksDepthProperty ;
    skos:prefLabel "cracks depth"@en .

she:CracksDistance a skos:Concept ;
    skos:exactMatch glosis_cm:cracksDistanceProperty ;
    skos:prefLabel "cracks distance"@en .

she:CracksWidth a skos:Concept ;
    skos:exactMatch glosis_cm:cracksWidthProperty ;
    skos:prefLabel "cracks width"@en .

she:FragmentCover a skos:Concept ;
    skos:exactMatch glosis_cm:fragmentCoverProperty ;
    skos:prefLabel "fragment cover"@en .

she:FragmentsSize a skos:Concept ;
    skos:exactMatch glosis_cm:fragmentsSizeProperty ;
    skos:prefLabel "fragments size"@en .

she:InfiltrationRateClass a skos:Concept ;
    skos:exactMatch glosis_cm:infiltrationRateClassProperty ;
    skos:prefLabel "infiltration rate class"@en .

she:InfiltrationRateNumeric a skos:Concept ;
    skos:exactMatch glosis_cm:infiltrationRateNumericProperty ;
    skos:prefLabel "infiltration rate numeric"@en .

she:OrganicMatterClass a skos:Concept ;
    skos:exactMatch glosis_cm:organicMatterClassProperty ;
    skos:prefLabel "organic matter class"@en .

she:RockAbundance a skos:Concept ;
    skos:exactMatch glosis_cm:rockAbundanceProperty ;
    skos:prefLabel "rock abundance"@en .

she:RockShape a skos:Concept ;
    skos:exactMatch glosis_cm:rockShapeProperty ;
    skos:prefLabel "rock shape"@en .

she:RockSize a skos:Concept ;
    skos:exactMatch glosis_cm:rockSizeProperty ;
    skos:prefLabel "rock size"@en .

she:SoilDepth a skos:Concept ;
    skos:exactMatch glosis_cm:soilDepthProperty ;
    skos:prefLabel "soil depth"@en .

she:SoilDepthBedrock a skos:Concept ;
    skos:exactMatch glosis_cm:soilDepthBedrockProperty ;
    skos:prefLabel "soil depth bedrock"@en .

she:SoilDepthRootable a skos:Concept ;
    skos:exactMatch glosis_cm:soilDepthRootableProperty ;
    skos:prefLabel "soil depth rootable"@en .

she:SoilDepthRootableClass a skos:Concept ;
    skos:exactMatch glosis_cm:soilDepthRootableClassProperty ;
    skos:prefLabel "soil depth rootable class"@en .

she:SoilDepthSampled a skos:Concept ;
    skos:exactMatch glosis_cm:soilDepthSampledProperty ;
    skos:prefLabel "soil depth sampled"@en .

she:Texture a skos:Concept ;
    skos:exactMatch glosis_cm:textureProperty ;
    skos:prefLabel "texture"@en .

she:WeatheringFragments a skos:Concept ;
    skos:exactMatch glosis_cm:weatheringFragmentsProperty ;
    skos:prefLabel "weathering fragments"@en .

