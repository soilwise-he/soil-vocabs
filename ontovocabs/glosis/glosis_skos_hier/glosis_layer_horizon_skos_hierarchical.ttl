    skos:narrower she:ParticleSizeFractionsSum ;
    skos:prefLabel "particle size analysis"@en .

she:ParticleSizeFractionsSum a skos:Concept ;
    skos:broader she:ParticleSizeAnalysis ;
    skos:exactMatch glosis:particleSizeFractionsSumProperty ;
