she:VoidsDiameter a skos:Concept ;
    skos:broader she:Voids ;
    skos:exactMatch glosis:voidsDiameterProperty ;
    skos:prefLabel "voids diameter"@en .

she:Cementation a skos:Concept ;
    skos:narrower she:CementationDegree,
        she:CementationFabric ;
    skos:prefLabel "cementation"@en .

she:Consistency a skos:Concept ;
    skos:narrower she:ConsistenceDry,
        she:DryConsistency ;
    skos:prefLabel "consistency"@en .

she:Gypsum a skos:Concept ;
    skos:narrower she:GypsumForms,
        she:GypsumWeight ;
    skos:prefLabel "gypsum"@en .

she:Structure a skos:Concept ;
    skos:narrower she:StructureGrade,
        she:StructureSize ;
    skos:prefLabel "structure"@en .

she:Voids a skos:Concept ;
    skos:narrower she:VoidsClassification,
        she:VoidsDiameter ;
    skos:prefLabel "voids"@en .

she:Coating a skos:Concept ;
    skos:narrower she:CoatingAbundance,
        she:CoatingContrast,
        she:CoatingNature ;
    skos:prefLabel "coating"@en .

she:MineralConcretions a skos:Concept ;
    skos:narrower she:MineralConcKind,
        she:MineralConcNature,
        she:MineralConcShape ;
    skos:prefLabel "mineral concretions"@en .

she:Mottles a skos:Concept ;
    skos:narrower she:MottlesAbundance,
        she:MottlesColour,
        she:MottlesPresence,
        she:MottlesSize ;
    skos:prefLabel "mottles"@en .

