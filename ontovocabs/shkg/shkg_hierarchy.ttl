@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix schema: <https://schema.org/> .
@prefix soilvoc: <https://soilwise-he.github.io/soil-vocabs#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

soilvoc:EcosystemServices a skos:Concept ;
    skos:altLabel "ecosystem service"@en ;
    skos:narrower soilvoc:CulturalServices,
        soilvoc:ProvisioningServices,
        soilvoc:RegulatingServices,
        soilvoc:SupportingServices ;
    skos:prefLabel "ecosystem services"@en .

soilvoc:SoilFunctions a skos:Concept ;
    skos:altLabel "soil function"@en ;
    skos:narrower soilvoc:CarbonPools,
        soilvoc:ClimateRegulation,
        soilvoc:FoodProduction,
        soilvoc:Habitats,
        soilvoc:NutrientDynamics,
        soilvoc:SoilBiologicalFunctions,
        soilvoc:SoilChemicalFunctions,
        soilvoc:SoilPhysicalFunctions,
        soilvoc:WaterPurification,
        soilvoc:WaterRegulation ;
    skos:prefLabel "soil functions"@en .

soilvoc:SoilHealth a skos:Concept ;
    skos:definition "Soil health is the level to which soil functions are fulfilled."@en ;
    skos:prefLabel "soil health"@en .

soilvoc:SoilIndicators a skos:Concept ;
    skos:altLabel "soil indicator"@en ;
    skos:narrower soilvoc:NonsoilIndicators,
        soilvoc:SoilFunctionIndicators,
        soilvoc:SoilStructureIndex ;
    skos:prefLabel "soil indicators"@en .

soilvoc:SoilOrganisms a skos:Concept ;
    skos:altLabel "soil organism"@en ;
    skos:narrower soilvoc:Microorganisms,
        soilvoc:SoilFauna ;
    skos:prefLabel "soil organisms"@en .

soilvoc:SoilProperties a skos:Concept ;
    skos:altLabel "soil property"@en ;
    skos:narrower soilvoc:SoilBiologicalProperties,
        soilvoc:SoilChemicalProperties,
        soilvoc:SoilPhysicalProperties ;
    skos:prefLabel "soil properties"@en .

soilvoc:SoilThreats a skos:Concept ;
    skos:altLabel "soil threat"@en ;
    skos:definition [ dcterms:source <https://soilhealthbenchmarks.eu/glossary/soil-threat/> ;
            schema:text "Soil threats are processes that could degrade (some of) the functions of soils and the services that soils provide. Examples of soil threats are: acidification, compaction, contamination (pollution), decline in soil organic matter, decline in soil biodiversity, desertification, erosion, flooding and water logging, landslides, salinization."@en ] ;
    skos:narrower soilvoc:SOCLoss,
        soilvoc:Salinisation,
        soilvoc:SoilAcidification,
        soilvoc:SoilBiodiversityLoss,
        soilvoc:SoilCompaction,
        soilvoc:SoilDegradation,
        soilvoc:SoilErosion,
        soilvoc:SoilNutrientLoss,
        soilvoc:SoilPollution,
        soilvoc:SoilSealing ;
    skos:prefLabel "soil threats"@en .

soilvoc:BiomassProductivity a skos:Concept ;
    skos:prefLabel "biomass productivity"@en .

soilvoc:CarbonPools a skos:Concept ;
    skos:altLabel "carbon pool"@en ;
    skos:prefLabel "carbon pools"@en .

soilvoc:CarbonStorageCapacity a skos:Concept ;
    skos:prefLabel "carbon storage capacity"@en .

soilvoc:Climate a skos:Concept ;
    skos:prefLabel "climate"@en .

soilvoc:ClimateRegulation a skos:Concept ;
    skos:prefLabel "climate regulation"@en .

soilvoc:CulturalServices a skos:Concept ;
    skos:altLabel "cultural service"@en ;
    skos:prefLabel "cultural services"@en .

soilvoc:Emissions a skos:Concept ;
    skos:altLabel "emission"@en ;
    skos:prefLabel "emissions"@en .

soilvoc:EnvironmentalFactors a skos:Concept ;
    skos:altLabel "environmental factor"@en ;
    skos:prefLabel "environmental factors"@en .

soilvoc:ExternalFactors a skos:Concept ;
    skos:altLabel "external factor"@en ;
    skos:narrower soilvoc:Climate,
        soilvoc:Emissions,
        soilvoc:Inputs,
        soilvoc:LandUse ;
    skos:prefLabel "external factors"@en .

soilvoc:FoodProduction a skos:Concept ;
    skos:prefLabel "food production"@en .

soilvoc:GroundwaterReproduction a skos:Concept ;
    skos:prefLabel "groundwater reproduction"@en .

soilvoc:HabitatProvisionCapacity a skos:Concept ;
    skos:prefLabel "habitat provision capacity"@en .

soilvoc:Habitats a skos:Concept ;
    skos:altLabel "habitat"@en ;
    skos:prefLabel "habitats"@en .

soilvoc:Inputs a skos:Concept ;
    skos:altLabel "input"@en ;
    skos:prefLabel "inputs"@en .

soilvoc:LandUse a skos:Concept ;
    skos:definition [ dcterms:source <https://www.eea.europa.eu/help/glossary/eea-glossary/land-use> ;
            schema:text "Land use corresponds to the socio-economic description (functional dimension) of areas: areas used for residential, industrial or commercial purposes, for farming or forestry, for recreational or conservation purposes, etc. Links with land cover are possible; it may be possible to infer land use from land cover and conversely. But situations are often complicated and the link is not so evident. Contrary to land cover, land use is difficult to 'observe'. For example, it is often difficult to decide if grasslands are used or not for agricultural purposes. Distinctions between land use and land cover and their definition have impacts on the development of classification systems, data collection and information systems in general."@en ],
        [ dcterms:source <https://archive.ipcc.ch/ipccreports/sres/land_use/index.php?idp=45> ;
            schema:text "The total of arrangements, activities, and inputs that people undertake in a certain land cover type (FAO, 1997a; FAO/UNEP, 1999)."@en ] ;
    skos:prefLabel "land use"@en .

soilvoc:Microorganisms a skos:Concept ;
    skos:altLabel "microorganism"@en ;
    skos:prefLabel "microorganisms"@en .

soilvoc:NonsoilIndicators a skos:Concept ;
    skos:altLabel "non-soil indicator"@en ;
    skos:narrower soilvoc:EnvironmentalFactors,
        soilvoc:ExternalFactors ;
    skos:prefLabel "non-soil indicators"@en .

soilvoc:NutrientBufferingCapacity a skos:Concept ;
    skos:prefLabel "nutrient buffering capacity"@en .

soilvoc:NutrientDynamics a skos:Concept ;
    skos:altLabel "nutrient dynamic"@en ;
    skos:prefLabel "nutrient dynamics"@en .

soilvoc:NutrientMobilisationCapacity a skos:Concept ;
    skos:prefLabel "nutrient mobilisation capacity"@en .

soilvoc:ProvisioningServices a skos:Concept ;
    skos:altLabel "provisioning service"@en ;
    skos:prefLabel "provisioning services"@en .

soilvoc:RegulatingServices a skos:Concept ;
    skos:altLabel "regulating service"@en ;
    skos:prefLabel "regulating services"@en .

soilvoc:SOCLoss a skos:Concept ;
    skos:altLabel "SOC loss"@en ;
    skos:prefLabel "soil organic carbon loss"@en .

soilvoc:Salinisation a skos:Concept ;
    skos:prefLabel "salinisation"@en .

soilvoc:SoilAcidification a skos:Concept ;
    skos:prefLabel "soil acidification"@en .

soilvoc:SoilBiodiversityLoss a skos:Concept ;
    skos:prefLabel "soil biodiversity loss"@en .

soilvoc:SoilBiologicalDegradation a skos:Concept ;
    skos:prefLabel "soil biological degradation"@en .

soilvoc:SoilBiologicalFunctions a skos:Concept ;
    skos:altLabel "soil biological function"@en ;
    skos:prefLabel "soil biological functions"@en .

soilvoc:SoilBiologicalProperties a skos:Concept ;
    skos:altLabel "soil biological property"@en ;
    skos:definition [ dcterms:source <https://www.fao.org/soils-portal/data-hub/soil-properties/biological-properties/en/> ;
            schema:text "This concerns soil properties related to the microbial and faunal activity in soil. These organisms include earthworms, nematodes, protozoa, fungi, bacteria and different arthropods. Soil biology plays a vital role in determining many soil characteristics, yet, being a relatively new science, much remains unknown about soil biology and about how the nature of soil is affected."@en ],
        [ dcterms:source <https://www.sciencedirect.com/topics/agricultural-and-biological-sciences/soil-biological-properties> ;
            schema:text "Soil biological properties refer to the biological components in the soil, including microbial life such as bacterial and fungal colonies, which are affected by changes in soil chemical and physical properties, such as acidity and organic matter content. These properties can be assessed through indicators like enzyme activities, which vary with management practices and land use."@en ] ;
    skos:prefLabel "soil biological properties"@en ;
    skos:related soilvoc:SoilQuality .

soilvoc:SoilChemicalDegradation a skos:Concept ;
    skos:prefLabel "soil chemical degradation"@en .

soilvoc:SoilChemicalFunctions a skos:Concept ;
    skos:altLabel "soil chemical function"@en ;
    skos:prefLabel "soil chemical functions"@en .

soilvoc:SoilChemicalProperties a skos:Concept ;
    skos:altLabel "soil chemical property"@en ;
    skos:definition [ dcterms:source <https://soilhealthnexus.org/resources/soil-properties/soil-chemical-properties/> ;
            schema:text "Chemical properties of soils include the following aspects: inorganic matters of soil, organic matters in soil, colloidal properties of soil particles and soil reactions and buffering action in acidic soils and basic soils."@en ],
        [ dcterms:source <https://www.sciencedirect.com/topics/earth-and-planetary-sciences/soil-chemical-property> ;
            schema:text "Soil chemical properties refer to the chemical attributes of soil that influence its ability to supply nutrients to plants, retain harmful elements, and affect plant growth and microbial populations. These properties include nutrient concentrations, pH levels, and the presence of elements such as nitrogen, phosphorus, and potassium, which are critical for soil quality assessment and agricultural productivity."@en ] ;
    skos:prefLabel "soil chemical properties"@en ;
    skos:related soilvoc:SoilQuality .

soilvoc:SoilCompaction a skos:Concept ;
    skos:prefLabel "soil compaction"@en .

soilvoc:SoilDegradation a skos:Concept ;
    skos:narrower soilvoc:SoilBiologicalDegradation,
        soilvoc:SoilChemicalDegradation,
        soilvoc:SoilEcologicalDegradation,
        soilvoc:SoilPhysicalDegradation ;
    skos:prefLabel "soil degradation"@en .

soilvoc:SoilEcologicalDegradation a skos:Concept ;
    skos:prefLabel "soil ecological degradation"@en .

soilvoc:SoilErosion a skos:Concept ;
    skos:prefLabel "soil erosion"@en .

soilvoc:SoilFauna a skos:Concept ;
    skos:narrower soilvoc:SoilMacrofauna,
        soilvoc:SoilMesofauna,
        soilvoc:SoilMicrofauna ;
    skos:prefLabel "soil fauna"@en .

soilvoc:SoilFunctionIndicators a skos:Concept ;
    skos:altLabel "soil function indicator"@en ;
    skos:narrower soilvoc:BiomassProductivity,
        soilvoc:CarbonStorageCapacity,
        soilvoc:GroundwaterReproduction,
        soilvoc:HabitatProvisionCapacity,
        soilvoc:NutrientBufferingCapacity,
        soilvoc:NutrientMobilisationCapacity,
        soilvoc:SoilMoistureDeficit,
        soilvoc:WaterStorageCapacity ;
    skos:prefLabel "soil function indicators"@en .

soilvoc:SoilMacrofauna a skos:Concept ;
    skos:prefLabel "soil macrofauna"@en .

soilvoc:SoilMesofauna a skos:Concept ;
    skos:prefLabel "soil mesofauna"@en .

soilvoc:SoilMicrofauna a skos:Concept ;
    skos:prefLabel "soil microfauna"@en .

soilvoc:SoilMoistureDeficit a skos:Concept ;
    skos:prefLabel "soil moisture deficit"@en .

soilvoc:SoilNLoss a skos:Concept ;
    skos:altLabel "soil N loss"@en ;
    skos:prefLabel "soil nitrogen loss"@en .

soilvoc:SoilNutrientLoss a skos:Concept ;
    skos:narrower soilvoc:SoilNLoss,
        soilvoc:SoilPLoss ;
    skos:prefLabel "soil nutrient loss"@en .

soilvoc:SoilPLoss a skos:Concept ;
    skos:altLabel "soil P loss"@en ;
    skos:prefLabel "soil phosphorus loss"@en .

soilvoc:SoilPhysicalDegradation a skos:Concept ;
    skos:prefLabel "soil physical degradation"@en .

soilvoc:SoilPhysicalFunctions a skos:Concept ;
    skos:altLabel "soil physical function"@en ;
    skos:prefLabel "soil physical functions"@en .

soilvoc:SoilPhysicalProperties a skos:Concept ;
    skos:altLabel "soil physical property"@en ;
    skos:definition [ dcterms:source <https://www.cambridge.org/core/books/properties-and-management-of-soils-in-the-tropics/soil-physical-properties/275087D91E8849FA36F347D4964ED835> ;
            schema:text "Soil physical properties are those responsible for the transport of water, solutes, air and heat in the soil. The main physical soil properties are depth, temperature, texture, structure, bulk density and water-holding capacity."@en ],
        [ dcterms:source <https://www.soils.org/publications/soils-glossary?q=publications/soils-glossary/> ;
            schema:text "Those characteristics, processes, or reactions of a soil that are caused by physical forces and that can be described by, or expressed in, physical terms or equations. Examples of physical properties are bulk density, hydraulic conductivity, porosity, pore-size distribution, etc."@en ],
        [ dcterms:source <https://soilhealthnexus.org/resources/soil-properties/soil-physical-properties/> ;
            schema:text "Soil physical properties include both inherent and dynamic soil properties. Inherent properties include soil texture, soil parent materials and soil depth. Dynamic properties are those that can be influenced by management include infiltration, aggregate stability, available soil water holding capacity, soil organic matter, soil porosity, compaction layers, crusting, bulk density, and structure. Optimal soil physical properties reduce limitations to root growth and productivity, improve seedling emergence, nutrient and water retention, infiltration, and movement of air and water within the soil profile. Physical properties are directly related to optimal chemical and biological properties which together improve nutrient and water cycling and other key soil functions."@en ] ;
    skos:prefLabel "soil physical properties"@en ;
    skos:related soilvoc:SoilQuality .

soilvoc:SoilPollution a skos:Concept ;
    skos:prefLabel "soil pollution"@en ;
    skos:narrower soilvoc:SoilContaminants .

soilvoc:SoilContaminants a skos:Concept ;
    skos:prefLabel "soil contaminants"@en ;
    skos:altLabel "soil contaminant"@en .

soilvoc:SoilSealing a skos:Concept ;
    skos:prefLabel "soil sealing"@en .

soilvoc:SupportingServices a skos:Concept ;
    skos:altLabel "supporting service"@en ;
    skos:prefLabel "supporting services"@en .

soilvoc:WaterPurification a skos:Concept ;
    skos:prefLabel "water purification"@en .

soilvoc:WaterRegulation a skos:Concept ;
    skos:prefLabel "water regulation"@en .

soilvoc:WaterStorageCapacity a skos:Concept ;
    skos:prefLabel "water storage capacity"@en .

soilvoc:SoilQuality a skos:Concept ;
    skos:prefLabel "soil quality"@en .

