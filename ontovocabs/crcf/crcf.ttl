@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix eusoilvoc: <https://w3id.org/eusoilvoc#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

eusoilvoc:Activity a skos:Concept ;
    skos:broader eusoilvoc:SoilManagement ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/reg/2024/3012/oj> ;
            rdf:value "One or more practices or processes carried out by an operator, or a group of operators, resulting in a permanent carbon removal, a temporary carbon removal through carbon farming or through carbon storage in products, or soil emission reductions through carbon farming where such carbon farming, overall, reduces the emissions of carbon from soil carbon pools or increases carbon removals in biogenic carbon pools;"@en ] ;
    skos:prefLabel "activity"@en .

eusoilvoc:ActivityPeriod a skos:Concept ;
    skos:broader eusoilvoc:NonsoilIndicators ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/reg/2024/3012/oj> ;
            rdf:value "A period during which the activity generates a net carbon removal benefit or a net soil emission reduction benefit, and which is determined in the applicable certification methodology"@en ] ;
    skos:prefLabel "activity period"@en .

eusoilvoc:BiogenicCarbonPool a skos:Concept ;
    skos:broader eusoilvoc:SoilOrganicMatter ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/reg/2024/3012/oj> ;
            rdf:value "Living biomass, litter, deadwood, dead organic matter, mineral soils and organic soils as listed in Section B, points (a) to (f), of Annex I to Regulation (EU) 2018/841"@en ] ;
    skos:prefLabel "biogenic carbon pool"@en .

eusoilvoc:CarbonFarming a skos:Concept ;
    skos:broader eusoilvoc:SoilManagement ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/reg/2024/3012/oj> ;
            rdf:value "Any practice or process carried out over an activity period of at least five years, related to the management of a terrestrial or coastal environment and resulting in the capture and temporary storage of atmospheric or biogenic carbon in biogenic carbon pools, or in the reduction of soil emissions"@en ] ;
    skos:prefLabel "carbon farming"@en .

eusoilvoc:CarbonFarmingSequestrationUnit a skos:Concept ;
    skos:broader eusoilvoc:ClimateRegulation ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/reg/2024/3012/oj> ;
            rdf:value "One metric tonne of CO2 equivalent of certified temporary net carbon removal benefit generated by a carbon farming activity and registered by a certification scheme in its certification registry or, as applicable, in the Union registry provided for in Article 12"@en ] ;
    skos:prefLabel "carbon farming sequestration unit"@en .

eusoilvoc:CarbonRemoval a skos:Concept ;
    skos:broader eusoilvoc:RegulatingServices ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/reg/2024/3012/oj> ;
            rdf:value "The anthropogenic removal of carbon from the atmosphere and its durable storage in geological, terrestrial or ocean reservoirs, or in long-lasting products"@en ] ;
    skos:prefLabel "carbon removal"@en .

eusoilvoc:CarbonStorageInProductUnit a skos:Concept ;
    skos:broader eusoilvoc:ClimateRegulation ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/reg/2024/3012/oj> ;
            rdf:value "One metric tonne of CO2 equivalent of certified temporary net carbon removal benefit generated by a carbon storage in product activity and registered by a certification scheme in its certification registry or, as applicable, in the Union registry provided for in Article 12"@en ] ;
    skos:prefLabel "carbon storage in product unit"@en .

eusoilvoc:CarbonStorageInProducts a skos:Concept ;
    skos:broader eusoilvoc:ProvisioningServices ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/reg/2024/3012/oj> ;
            rdf:value "Any practice or process that captures and stores atmospheric or biogenic carbon for at least 35 years in long-lasting products, allows on-site monitoring of the carbon stored and is certified throughout the monitoring period"@en ] ;
    skos:prefLabel "carbon storage in products"@en .

eusoilvoc:CertificateOfCompliance a skos:Concept ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/reg/2024/3012/oj> ;
            rdf:value "A conformity statement issued by a certification body certifying that an activity complies with this Regulation"@en ] ;
    skos:prefLabel "certificate of compliance"@en .

eusoilvoc:CertificationAudit a skos:Concept ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/reg/2024/3012/oj> ;
            rdf:value "An audit carried out by a certification body"@en ] ;
    skos:prefLabel "certification audit"@en .

eusoilvoc:CertificationBody a skos:Concept ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/reg/2024/3012/oj> ;
            rdf:value "An accredited or recognised independent conformity assessment body that has concluded an agreement with a certification scheme to carry out certification audits and issue certificates of compliance"@en ] ;
    skos:prefLabel "certification body"@en .

eusoilvoc:CertificationScheme a skos:Concept ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/reg/2024/3012/oj> ;
            rdf:value "An organisation that certifies the compliance of activities and operators with the quality criteria and certification rules set out in this Regulation"@en ] ;
    skos:prefLabel "certification scheme"@en .

eusoilvoc:GeologicalStorageOfCO2 a skos:Concept ;
    skos:broader eusoilvoc:Lithology ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/reg/2024/3012/oj> ;
            rdf:value "Geological storage of CO2 as defined in Article 3, point 1, of Directive 2009/31/EC"@en ] ;
    skos:prefLabel "geological storage of co2"@en .

eusoilvoc:GroupOfOperators a skos:Concept ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/reg/2024/3012/oj> ;
            rdf:value "A legal entity that represents at least two operators and is responsible for ensuring that those operators comply with this Regulation;"@en ] ;
    skos:prefLabel "group of operators"@en .

eusoilvoc:MonitoringPeriod a skos:Concept ;
    skos:broader eusoilvoc:NonsoilIndicators ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/reg/2024/3012/oj> ;
            rdf:value "A period during which the soil emission reduction or storage of carbon is monitored by an operator or a group of operators, which covers at least the activity period, and which is determined in the applicable certification methodology;"@en ] ;
    skos:prefLabel "monitoring period"@en .

eusoilvoc:Operator a skos:Concept ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/reg/2024/3012/oj> ;
            rdf:value "Any natural or legal person or public entity that operates or controls an activity, or to whom or to which decisive economic power over the technical functioning of the activity has been delegated; in the case of a carbon farming activity, ‘operator’ means a farmer as defined in Article 3, point (1), of Regulation (EU) 2021/2115, any other manager of an activity in a terrestrial or coastal environment, a forest owner or manager as defined by national law, or a competent public entity"@en ] ;
    skos:prefLabel "operator"@en .

eusoilvoc:PermanentCarbonRemoval a skos:Concept ;
    skos:broader eusoilvoc:SoilManagement ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/reg/2024/3012/oj> ;
            rdf:value "Any practice or process that, under normal circumstances and using appropriate management practices, captures and stores atmospheric or biogenic carbon for several centuries, including permanently chemically bound carbon in products, and which is not combined with enhanced hydrocarbon recovery"@en ] ;
    skos:prefLabel "permanent carbon removal"@en .

eusoilvoc:PermanentCarbonRemovalUnit a skos:Concept ;
    skos:broader eusoilvoc:ClimateRegulation ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/reg/2024/3012/oj> ;
            rdf:value "One metric tonne of CO2 equivalent of certified permanent net carbon removal benefit generated by a permanent carbon removal activity and registered by a certification scheme in its certification registry or, as applicable, in the Union registry provided for in Article 12;"@en ] ;
    skos:prefLabel "permanent carbon removal unit"@en .

eusoilvoc:PermanentlyChemicallyBoundCarbonInProducts a skos:Concept ;
    skos:broader eusoilvoc:ClimateRegulation ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/reg/2024/3012/oj> ;
            rdf:value "Carbon chemically stored within a product with the result that it does not enter the atmosphere under normal use of the product, including any normal activity taking place after the end of life of the product, in accordance with Article 12(3b) of Directive 2003/87/EC"@en ] ;
    skos:prefLabel "permanently chemically bound carbon in products"@en .

eusoilvoc:ReCertificationAudit a skos:Concept ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/reg/2024/3012/oj> ;
            rdf:value "An audit carried out in the process of renewing a certificate of compliance issued by a certification body"@en ] ;
    skos:prefLabel "re-certification audit"@en .

eusoilvoc:Reversal a skos:Concept ;
    skos:broader eusoilvoc:SoilGaseousEmission ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/reg/2024/3012/oj> ;
            rdf:value "In the case of geological storage of CO2, leakage as defined in Article 3, point 5, of Directive 2009/31/EC and, for other activities, the voluntary or involuntary release back into the atmosphere of carbon captured and stored by an activity"@en ] ;
    skos:prefLabel "reversal"@en .

eusoilvoc:SoilEmissionReduction a skos:Concept ;
    skos:broader eusoilvoc:ClimateRegulation ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/reg/2024/3012/oj> ;
            rdf:value "The reduction of net greenhouse gas emissions from biogenic carbon pools as listed in Section B, points (e) and (f), of Annex I to Regulation (EU) 2018/841 or the reduction of greenhouse gas emissions from the IPCC source category of agriculture, subcategory of 3.D agricultural soils, as determined pursuant to Regulation (EU) 2018/1999 and the implementing acts adopted pursuant to it, where the relevant activity, overall, reduces the emission of carbon from soil carbon pools or increases carbon removals in biogenic carbon pools;"@en ] ;
    skos:prefLabel "soil emission reduction"@en .

eusoilvoc:SoilEmissionReductionUnit a skos:Concept ;
    skos:broader eusoilvoc:ClimateRegulation ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/reg/2024/3012/oj> ;
            rdf:value "One metric tonne of CO2 equivalent of certified net soil emission reduction benefit generated by a carbon farming activity and registered by a certification scheme in its certification registry or, as applicable, in the Union registry provided for in Article 12"@en ] ;
    skos:prefLabel "soil emission reduction unit"@en .

