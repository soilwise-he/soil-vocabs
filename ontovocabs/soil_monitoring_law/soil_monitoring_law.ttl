@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix eusoilvoc: <https://w3id.org/eusoilvoc#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

eusoilvoc:Contaminant a skos:Concept ;
    skos:broader eusoilvoc:SoilChemical ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "A substance liable to cause soil contamination or contamination of bedrock or parent material"@en ] ;
    skos:prefLabel "contaminant"@en .

eusoilvoc:ContaminatedSite a skos:Concept ;
    skos:broader eusoilvoc:SoilPollution ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "A delineated area with confirmed soil contamination or contamination of bedrock or parent material caused by anthropogenic point-source activities"@en ] ;
    skos:prefLabel "contaminated site"@en .

eusoilvoc:Desealing a skos:Concept ;
    skos:broader eusoilvoc:SoilManagement ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "The conversion of sealed soil into soil that is not sealed soil"@en ] ;
    skos:prefLabel "de-sealing"@en .

eusoilvoc:Ecosystem a skos:Concept ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "A dynamic complex of plant, animal and micro-organism communities and their non-living environment, interacting as a functional unit;"@en ] ;
    skos:prefLabel "ecosystem"@en .

eusoilvoc:Land a skos:Concept ;
    skos:broader eusoilvoc:Physiography ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "The surface of the Earth that is not regularly covered by water bodies"@en ] ;
    skos:prefLabel "land"@en .

eusoilvoc:ManagedSoils a skos:Concept ;
    skos:broader eusoilvoc:SoilManagement ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "Soils where soil management practices are carried out"@en ] ;
    skos:prefLabel "managed soils"@en .

eusoilvoc:MineralSoils a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "Mineral soils within the meaning of the 2006 IPCC Guidelines for National Greenhouse Gas Inventories"@en ] ;
    skos:prefLabel "mineral soils"@en .

eusoilvoc:NaturalLand a skos:Concept ;
    skos:broader eusoilvoc:LandCover ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "An area of land on which the natural processes are dominant and human intervention is minimal or non-existent, and on which the primary ecological functions and species composition have not been substantially modified"@en ] ;
    skos:prefLabel "natural land"@en .

eusoilvoc:NetSealing a skos:Concept ;
    skos:broader eusoilvoc:SoilSealing ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "The result of soil sealing minus de-sealing"@en ] ;
    skos:prefLabel "net sealing"@en .

eusoilvoc:OrganicSoils a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "Organic soils within the meaning of the 2006 IPCC Guidelines for National Greenhouse Gas Inventories"@en ] ;
    skos:prefLabel "organic soils"@en .

eusoilvoc:PotentiallyContaminatedSite a skos:Concept ;
    skos:broader eusoilvoc:SoilPollution ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "A delineated area where soil contamination or contamination of bedrock or parent material caused by anthropogenic point-source activities is suspected based on relevant evidence"@en ] ;
    skos:prefLabel "potentially contaminated site"@en .

eusoilvoc:PublicConcerned a skos:Concept ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "The public affected or likely to be affected by soil degradation, or having an interest in the decision-making procedures related to the implementation of the obligations under this Directive, including landowners, land managers and land users, as well as non-governmental organisations promoting the protection of human health or the environment and meeting any requirements under national law"@en ] ;
    skos:prefLabel "public concerned"@en .

eusoilvoc:Risk a skos:Concept ;
    skos:broader eusoilvoc:SoilThreats ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "The likelihood of harmful effects to human health or the environment resulting from exposure to soil contamination or to contamination of bedrock or parent material"@en ] ;
    skos:prefLabel "risk"@en .

eusoilvoc:RiskReductionMeasures a skos:Concept ;
    skos:broader eusoilvoc:SoilManagement ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "Measures that aim to reduce the risks that contaminated sites pose to human health and the environment, either by means of soil remediation or modification of the source-pathway-receptor linkage without changing the characteristics of the contamination itself."@en ] ;
    skos:prefLabel "risk reduction measures"@en .

eusoilvoc:SealedSoil a skos:Concept ;
    skos:broader eusoilvoc:SoilSealing ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "An area of soil that underwent soil sealing"@en ] ;
    skos:prefLabel "sealed soil"@en .

eusoilvoc:SettlementArea a skos:Concept ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "A settlement area within the meaning of the 2006 Guidelines of the Intergovernmental Panel on Climate Change (IPCC) for National Greenhouse Gas Inventories"@en ] ;
    skos:prefLabel "settlement area"@en .

eusoilvoc:SoilBiodiveristy a skos:Concept ;
    skos:broader eusoilvoc:SoilBiologicalProperties ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "The variation in soil life, from genes to communities of organisms, and the ecological complexes of which they are part, that is complexes ranging from soil micro-habitats to landscapes"@en ] ;
    skos:prefLabel "soil biodiveristy"@en .

eusoilvoc:SoilContamination a skos:Concept ;
    skos:broader eusoilvoc:SoilPollution ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "The presence of a substance in soil at a level that may be, directly or indirectly, harmful to human health or the environment"@en ] ;
    skos:prefLabel "soil contamination"@en .

eusoilvoc:SoilDescriptor a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "A parameter describing a physical, chemical or biological characteristic of soil health"@en ] ;
    skos:prefLabel "soil descriptor"@en .

eusoilvoc:SoilDistrict a skos:Concept ;
    skos:broader eusoilvoc:Physiography ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "A part of the territory of a Member State, which has been delineated by that Member State in accordance with this Directive"@en ] ;
    skos:prefLabel "soil district"@en .

eusoilvoc:SoilHealthAssessment a skos:Concept ;
    skos:broader eusoilvoc:SoilQuality ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "Means the evaluation of the health of soil based on the measurement or estimation of the values of soil descriptors"@en ] ;
    skos:prefLabel "soil health assessment"@en .

eusoilvoc:SoilInvestigation a skos:Concept ;
    skos:broader eusoilvoc:SoilDescription ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "A process that can be performed in multiple and iterative phases to assess the presence and levels of contaminants in soil, bedrock or parent material and, if relevant, to characterise and determine the extent of a contaminated site"@en ] ;
    skos:prefLabel "soil investigation"@en .

eusoilvoc:SoilManagementPractices a skos:Concept ;
    skos:broader eusoilvoc:SoilManagement ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "Practices that ipact the physical, chemical, or biological properties of the soil"@en ] ;
    skos:prefLabel "soil management practices"@en .

eusoilvoc:SoilRegeneration a skos:Concept ;
    skos:broader eusoilvoc:SoilManagement ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "An intentional activity aimed at changing the condition of soil from degraded to healthy"@en ] ;
    skos:prefLabel "soil regeneration"@en .

eusoilvoc:SoilRemediation a skos:Concept ;
    skos:broader eusoilvoc:SoilManagement ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "A set of actions that reduce, isolate or immobilise contaminants in soil, bedrock or parent material"@en ] ;
    skos:prefLabel "soil remediation"@en .

eusoilvoc:SoilRemoval a skos:Concept ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "The temporary or long-term total or partial removal of soil in an area"@en ] ;
    skos:prefLabel "soil removal"@en .

eusoilvoc:SoilResilience a skos:Concept ;
    skos:broader eusoilvoc:SoilIndicators ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "The ability of soil to preserve its functions and maintain its capacity to provide ecosystem services, and to withstand and recover from disturbances"@en ] ;
    skos:prefLabel "soil resilience"@en .

eusoilvoc:SoilUnit a skos:Concept ;
    skos:broader eusoilvoc:SoilClassification ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "A spatially discrete area within a soil district resulting from the intersection of sets of spatial data used as factors for statistical homogeneity within that soil district"@en ] ;
    skos:prefLabel "soil unit"@en .

eusoilvoc:TransferFunction a skos:Concept ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "A mathematical rule that enables the value of a measurement performed using a methodology different from a reference methodology to be converted into the value that would be obtained by performing the soil measurement using the reference methodology"@en ] ;
    skos:prefLabel "transfer function"@en .

eusoilvoc:EcosystemServices a skos:Concept ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "The direct or indirect contributions of ecosystems to the environmental, economic, social, cultural and other benefits that people derive from those ecosystems"@en ] ;
    skos:prefLabel "ecosystem services"@en .

eusoilvoc:Soil a skos:Concept ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "The top layer of the Earth’s crust, situated between the bedrock or the parent material and the land surface, and which is composed of mineral particles, organic matter, water, air and living organisms"@en ] ;
    skos:prefLabel "soil"@en .

eusoilvoc:SoilHealth a skos:Concept ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "The physical, chemical and biological condition of soil, determining its capacity to function as a vital living system and to provide ecosystem services"@en ] ;
    skos:prefLabel "soil health"@en .

eusoilvoc:LandCover a skos:Concept ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "The physical and biological cover of the surface of the Earth"@en ] ;
    skos:prefLabel "land cover"@en .

eusoilvoc:SoilSealing a skos:Concept ;
    skos:definition [ dcterms:source <https://eur-lex.europa.eu/eli/dir/2025/2360/oj> ;
            rdf:value "The covering of soil with completely or partially impermeable material"@en ] ;
    skos:prefLabel "soil sealing"@en .

